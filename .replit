modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"
packages = ["libuuid"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dashboard"

[[workflows.workflow]]
name = "Dashboard"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node index.js"
waitForPort = 5000

[userenv]

[userenv.shared]
DASHBOARD_PASSWORD = "arki2024"
DATABASE_PUBLIC_URL = "postgresql://postgres:cFYlRChDzHhHiGdDJmeFzeoFJVjKBRIq@yamabiko.proxy.rlwy.net:37290/railway"

[userenv.development]
DASHBOARD_ONLY = "true"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "cloudrun"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000
