<%
function nitradoCardsHtml(servers) {
  var html = '<div class="nitrado-grid">';
  servers.forEach(function(srv) {
    var isOnline = srv.status === 'started';
    var onlineCls = isOnline ? 'nitrado-online' : 'nitrado-offline';
    html += '<div class="nitrado-card ' + onlineCls + '">';
    html += '<div class="nitrado-card-header">';
    html += '<span class="nitrado-status-dot" style="background:' + (isOnline ? 'var(--success)' : '#888') + '"></span>';
    html += '<span class="nitrado-name">' + (srv.name || 'Serveur #' + srv.id) + '</span>';
    html += '</div>';
    if (srv.map) html += '<div class="nitrado-map-badge">🗺️ ' + srv.map + '</div>';
    html += '<div class="nitrado-status-label" style="color:' + (isOnline ? 'var(--success)' : 'var(--text-muted)') + '">' + (isOnline ? '🟢 En ligne' : '🔴 Hors ligne') + '</div>';
    if (isOnline) {
      var pct = srv.playersMax > 0 ? Math.round((srv.playersOnline / srv.playersMax) * 100) : 0;
      html += '<div class="nitrado-players"><span class="nitrado-players-count" style="color:var(--accent)">👥 ' + srv.playersOnline + (srv.playersMax > 0 ? '/' + srv.playersMax : '') + '</span>';
      html += '<span class="nitrado-players-label"> joueur' + (srv.playersOnline !== 1 ? 's' : '') + '</span></div>';
      if (srv.playersMax > 0) html += '<div class="top5-bar-wrap" style="margin-top:6px"><div class="top5-bar" style="width:' + pct + '%;background:var(--accent)"></div></div>';
      if (srv.playerNames && srv.playerNames.length > 0) {
        html += '<div class="nitrado-playerlist">';
        srv.playerNames.forEach(function(n) { html += '<span class="nitrado-player-tag">👤 ' + n + '</span>'; });
        html += '</div>';
      } else if (srv.playersOnline > 0) {
        html += '<div class="nitrado-playerlist-empty" style="font-size:12px;color:var(--text-muted);margin-top:6px;">Noms non disponibles via l\'API</div>';
      }
    }
    html += '</div>';
  });
  html += '</div>';
  return html;
}
%>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tableau de bord - Arki Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="layout">
    <%- include('sidebar') %>
    <main class="main-content">
      <div class="dashboard-banner">
        <img src="/images/banner.png" alt="Arki' Family">
      </div>

      <div class="page-header">
        <h1>Tableau de bord</h1>
        <p>Vue d'ensemble de votre bot Discord</p>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon">👥</div>
          <div class="stat-value"><%= memberCount.toLocaleString('fr-FR') %></div>
          <div class="stat-label">Membres</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">⏱️</div>
          <div class="stat-value"><%= Math.floor(uptime / 3600) %>h<%= Math.floor((uptime % 3600) / 60).toString().padStart(2, '0') %></div>
          <div class="stat-label">Uptime</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">🏆</div>
          <div class="stat-value"><%= top5.length > 0 ? top5[0].votes : '—' %></div>
          <div class="stat-label">Votes – 1er du mois</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">🗳️</div>
          <div class="stat-value"><%= top5.reduce((s, p) => s + p.votes, 0).toLocaleString('fr-FR') %></div>
          <div class="stat-label">Total votes top 5</div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2>🏆 Top 5 voteurs du mois</h2>
          <span style="font-size:13px;color:var(--text-muted)">Via Top-Serveurs</span>
        </div>
        <div class="card-body">
          <% if (top5.length === 0) { %>
            <div class="empty-state">
              <div class="icon">🗳️</div>
              <p>Impossible de récupérer le classement.<br>Vérifiez l'URL API dans les paramètres.</p>
            </div>
          <% } else { %>
            <div class="top5-list">
              <% const medals = ['🥇', '🥈', '🥉', '4️⃣', '5️⃣']; %>
              <% const colors = ['#ffd700', '#c0c0c0', '#cd7f32', 'var(--text-secondary)', 'var(--text-secondary)']; %>
              <% top5.forEach((player, i) => { %>
                <div class="top5-row <%= i < 3 ? 'top5-podium' : '' %>" style="<% if(i < 3) { %>border-left: 4px solid <%= colors[i] %>;<% } %>">
                  <div class="top5-rank" style="color: <%= colors[i] %>"><%= medals[i] %></div>
                  <div class="top5-name"><%= player.playername %></div>
                  <div class="top5-votes">
                    <span class="top5-votes-count"><%= player.votes %></span>
                    <span class="top5-votes-label">vote<%= player.votes > 1 ? 's' : '' %></span>
                  </div>
                  <div class="top5-bar-wrap">
                    <div class="top5-bar" style="width: <%= top5[0].votes > 0 ? Math.round((player.votes / top5[0].votes) * 100) : 0 %>%; background: <%= colors[i] %>"></div>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2>🗺️ Serveurs ARK</h2>
          <div style="display:flex;align-items:center;gap:12px;">
            <span id="nitrado-summary" style="font-size:13px;color:var(--text-muted)">
              <% const onlineCount = nitradoServers.filter(s => s.status === 'started').length; %>
              <span style="color:<%= onlineCount > 0 ? 'var(--success)' : 'var(--text-muted)' %>">●</span>
              <%= onlineCount %> / <%= nitradoServers.length %> en ligne
            </span>
            <button id="nitrado-refresh-btn" onclick="refreshNitrado()" style="background:none;border:1px solid var(--border-color);border-radius:6px;padding:3px 10px;cursor:pointer;font-size:12px;color:var(--text-secondary);">↻ Actualiser</button>
            <span id="nitrado-updated" style="font-size:11px;color:var(--text-muted)"></span>
          </div>
        </div>
        <div class="card-body" id="nitrado-body">
          <% if (nitradoServers.length === 0) { %>
            <div class="empty-state">
              <div class="icon">🖥️</div>
              <p>Aucun serveur trouvé.<br>Vérifiez que le token Nitrado est valide et que le scope "service" est activé.</p>
            </div>
          <% } else { %>
            <%- nitradoCardsHtml(nitradoServers) %>
          <% } %>
        </div>
      </div>

    </main>
  </div>

<script>
  function nitradoCardsHtmlJS(servers) {
    if (!servers || servers.length === 0) {
      return '<div class="empty-state"><div class="icon">🖥️</div><p>Aucun serveur trouvé.</p></div>';
    }
    var html = '<div class="nitrado-grid">';
    servers.forEach(function(srv) {
      var isOnline = srv.status === 'started';
      html += '<div class="nitrado-card ' + (isOnline ? 'nitrado-online' : 'nitrado-offline') + '">';

      html += '<div class="nitrado-card-header">';
      html += '<span class="nitrado-status-dot" style="background:' + (isOnline ? 'var(--success)' : '#888') + '"></span>';
      html += '<span class="nitrado-name">' + escHtml(srv.name || 'Serveur #' + srv.id) + '</span>';
      html += '</div>';

      if (srv.map) {
        html += '<div class="nitrado-map-badge">🗺️ ' + escHtml(srv.map) + '</div>';
      }

      html += '<div class="nitrado-status-label" style="color:' + (isOnline ? 'var(--success)' : 'var(--text-muted)') + '">';
      html += isOnline ? '🟢 En ligne' : '🔴 Hors ligne';
      html += '</div>';

      if (isOnline) {
        var pct = srv.playersMax > 0 ? Math.round((srv.playersOnline / srv.playersMax) * 100) : 0;
        html += '<div class="nitrado-players">';
        html += '<span class="nitrado-players-count" style="color:var(--accent)">👥 ' + srv.playersOnline + (srv.playersMax > 0 ? '/' + srv.playersMax : '') + '</span>';
        html += '<span class="nitrado-players-label"> joueur' + (srv.playersOnline !== 1 ? 's' : '') + '</span>';
        html += '</div>';
        if (srv.playersMax > 0) {
          html += '<div class="top5-bar-wrap" style="margin-top:6px"><div class="top5-bar" style="width:' + pct + '%;background:var(--accent)"></div></div>';
        }
        if (srv.playerNames && srv.playerNames.length > 0) {
          html += '<div class="nitrado-playerlist">';
          srv.playerNames.forEach(function(n) {
            html += '<span class="nitrado-player-tag">👤 ' + escHtml(n) + '</span>';
          });
          html += '</div>';
        } else if (srv.playersOnline > 0) {
          html += '<div class="nitrado-playerlist-empty" style="font-size:12px;color:var(--text-muted);margin-top:6px;">Noms non disponibles via l\'API</div>';
        }
      }

      html += '</div>';
    });
    html += '</div>';
    return html;
  }

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  var nitradoRefreshTimer;

  function refreshNitrado() {
    var btn = document.getElementById('nitrado-refresh-btn');
    if (btn) { btn.textContent = '⏳'; btn.disabled = true; }

    fetch('/api/nitrado')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (btn) { btn.textContent = '↻ Actualiser'; btn.disabled = false; }

        var onlineCount = data.servers.filter(function(s) { return s.status === 'started'; }).length;
        var summary = document.getElementById('nitrado-summary');
        if (summary) {
          summary.innerHTML = '<span style="color:' + (onlineCount > 0 ? 'var(--success)' : 'var(--text-muted)') + '">●</span> '
            + onlineCount + ' / ' + data.servers.length + ' en ligne';
        }

        var body = document.getElementById('nitrado-body');
        if (body) body.innerHTML = nitradoCardsHtmlJS(data.servers);

        var upd = document.getElementById('nitrado-updated');
        if (upd && data.updatedAt) {
          var d = new Date(data.updatedAt);
          upd.textContent = 'Mis à jour à ' + d.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }
      })
      .catch(function() {
        if (btn) { btn.textContent = '↻ Actualiser'; btn.disabled = false; }
      });
  }

  nitradoRefreshTimer = setInterval(refreshNitrado, 60000);
</script>

</body>
</html>
