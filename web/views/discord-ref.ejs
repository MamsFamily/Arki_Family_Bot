<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Référence Discord - Arki Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .ref-table { width:100%; border-collapse:collapse; font-size:13px; }
    .ref-table th { text-align:left; padding:9px 14px; background:var(--bg-input); color:var(--text-muted); font-weight:600; font-size:11px; text-transform:uppercase; letter-spacing:.06em; border-bottom:1px solid var(--border-color); position:sticky; top:0; z-index:1; }
    .ref-table td { padding:9px 14px; border-bottom:1px solid var(--border-color); vertical-align:middle; }
    .ref-table tr:last-child td { border-bottom:none; }
    .ref-table tr:hover td { background:rgba(255,255,255,.025); }
    .prop-name { font-family:monospace; font-size:12px; color:var(--accent); background:var(--bg-input); border:1px solid var(--border-color); border-radius:4px; padding:2px 7px; white-space:nowrap; }
    .type-badge { font-size:10px; font-weight:700; border-radius:3px; padding:1px 6px; white-space:nowrap; }
    .type-string  { background:#1a2a1a; color:#4caf50; }
    .type-number  { background:#1a1a2e; color:#5c9df5; }
    .type-boolean { background:#2a1a2a; color:#ce93d8; }
    .type-date    { background:#2a1a00; color:#ffb74d; }
    .type-array   { background:#1a2a2a; color:#4dd0e1; }
    .type-object  { background:#2a2a1a; color:#fff176; }
    .type-url     { background:#1a1a2a; color:#90caf9; }
    .type-enum    { background:#2a1a1a; color:#ef9a9a; }
    .example-val { font-family:monospace; font-size:12px; color:var(--text-muted); }
    .cat-header { padding:10px 14px 6px; font-size:11px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--text-muted); background:var(--bg-card); border-bottom:1px solid var(--border-color); border-top:2px solid var(--accent); display:flex; align-items:center; gap:8px; }
    .search-bar { width:100%; padding:10px 14px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-input); color:var(--text-primary); font-size:14px; margin-bottom:16px; }
    .search-bar:focus { outline:none; border-color:var(--accent); }
    .filter-tabs { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px; }
    .filter-tab { padding:5px 14px; border-radius:20px; border:1px solid var(--border-color); cursor:pointer; font-size:12px; font-weight:600; background:var(--bg-input); color:var(--text-secondary); transition:all .15s; }
    .filter-tab.active, .filter-tab:hover { background:var(--accent); color:#fff; border-color:var(--accent); }
    .ref-row { }
    .ref-row.hidden { display:none; }
    .highlight { background:rgba(99,102,241,.25); border-radius:2px; }
    .note-cell { font-size:12px; color:var(--text-muted); }
    .badge-impl { background:#0d3d1a; color:#4caf50; border-radius:3px; padding:1px 6px; font-size:10px; font-weight:700; }
    .badge-avail { background:#1a2e1a; color:#81c784; border-radius:3px; padding:1px 6px; font-size:10px; }
  </style>
</head>
<body>
  <div class="layout">
    <%- include('sidebar') %>
    <main class="main-content">
      <div class="page-header">
        <h1>📚 Référence complète — Variables Discord</h1>
        <p>Toutes les propriétés accessibles via l'API Discord.js, classées par catégorie</p>
      </div>

      <!-- Recherche + filtres -->
      <input type="text" class="search-bar" id="searchInput" placeholder="🔍 Rechercher une propriété, un exemple, une description..." oninput="filterTable()">
      <div class="filter-tabs">
        <button class="filter-tab active" onclick="filterCat('all', this)">Tout</button>
        <button class="filter-tab" onclick="filterCat('member', this)">👤 Membre</button>
        <button class="filter-tab" onclick="filterCat('user', this)">👦 Utilisateur</button>
        <button class="filter-tab" onclick="filterCat('guild', this)">🏠 Serveur</button>
        <button class="filter-tab" onclick="filterCat('channel', this)">📢 Salon</button>
        <button class="filter-tab" onclick="filterCat('role', this)">🎭 Rôle</button>
        <button class="filter-tab" onclick="filterCat('voice', this)">🎤 Vocal</button>
        <button class="filter-tab" onclick="filterCat('presence', this)">🟢 Présence</button>
        <button class="filter-tab" onclick="filterCat('message', this)">💬 Message</button>
        <button class="filter-tab" onclick="filterCat('flags', this)">🏅 Badges</button>
        <button class="filter-tab" onclick="filterCat('emoji', this)">😀 Emojis</button>
      </div>

      <div class="card" style="overflow:hidden;">
        <table class="ref-table" id="refTable">
          <thead>
            <tr>
              <th style="width:220px">Propriété Discord.js</th>
              <th>Description</th>
              <th style="width:80px">Type</th>
              <th style="width:200px">Exemple</th>
              <th style="width:90px">Notes</th>
            </tr>
          </thead>
          <tbody>

            <%# ═══════════════════════════ MEMBRE ═══════════════════════════ %>
            <tr><td colspan="5" class="cat-header" data-cat="member">👤 GuildMember — Membre du serveur</td></tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.id</span></td>
              <td>Identifiant Discord unique (snowflake) du membre</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">123456789012345678</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.displayName</span></td>
              <td>Pseudo affiché : surnom serveur en priorité, sinon globalName, sinon username</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">Zeus_ARK</span></td>
              <td><span class="badge-impl">Impl.</span></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.nickname</span></td>
              <td>Surnom personnalisé sur le serveur uniquement (null si pas défini)</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">Zeus_ARK</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.joinedAt</span></td>
              <td>Date d'arrivée du membre sur le serveur</td>
              <td><span class="type-badge type-date">Date</span></td>
              <td><span class="example-val">2024-01-05T14:32:00.000Z</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.joinedTimestamp</span></td>
              <td>Timestamp ms d'arrivée du membre (version numérique de joinedAt)</td>
              <td><span class="type-badge type-number">number</span></td>
              <td><span class="example-val">1704463920000</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.premiumSince</span></td>
              <td>Date depuis laquelle le membre booste le serveur (null si non boosteur)</td>
              <td><span class="type-badge type-date">Date</span></td>
              <td><span class="example-val">2025-06-01T00:00:00.000Z</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.premiumSinceTimestamp</span></td>
              <td>Timestamp ms du début du boost (null si non boosteur)</td>
              <td><span class="type-badge type-number">number</span></td>
              <td><span class="example-val">1748736000000</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.roles.cache</span></td>
              <td>Collection de tous les rôles du membre (Map id → Role)</td>
              <td><span class="type-badge type-object">Collection</span></td>
              <td><span class="example-val">Map { id: Role, … }</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.displayColor</span></td>
              <td>Couleur du rôle le plus haut ayant une couleur (entier RGB)</td>
              <td><span class="type-badge type-number">number</span></td>
              <td><span class="example-val">1964779</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.displayHexColor</span></td>
              <td>Couleur hex du rôle le plus haut (#000000 si aucun)</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">#1de9b6</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.communicationDisabledUntil</span></td>
              <td>Fin du timeout (null si pas en timeout)</td>
              <td><span class="type-badge type-date">Date</span></td>
              <td><span class="example-val">2026-04-01T18:00:00.000Z</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.pending</span></td>
              <td>true si le membre n'a pas encore accepté les règles (membership screening)</td>
              <td><span class="type-badge type-boolean">boolean</span></td>
              <td><span class="example-val">false</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.manageable</span></td>
              <td>true si le bot peut gérer ce membre (rôle inférieur au bot)</td>
              <td><span class="type-badge type-boolean">boolean</span></td>
              <td><span class="example-val">true</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.kickable</span></td>
              <td>true si le bot peut expulser ce membre</td>
              <td><span class="type-badge type-boolean">boolean</span></td>
              <td><span class="example-val">true</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.bannable</span></td>
              <td>true si le bot peut bannir ce membre</td>
              <td><span class="type-badge type-boolean">boolean</span></td>
              <td><span class="example-val">true</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.voice</span></td>
              <td>État vocal du membre (objet VoiceState, voir section Vocal)</td>
              <td><span class="type-badge type-object">VoiceState</span></td>
              <td><span class="example-val">VoiceState { … }</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="member">
              <td><span class="prop-name">member.isCommunicationDisabled()</span></td>
              <td>true si le membre est actuellement en timeout</td>
              <td><span class="type-badge type-boolean">boolean</span></td>
              <td><span class="example-val">false</span></td>
              <td></td>
            </tr>

            <%# ═══════════════════════════ UTILISATEUR ═══════════════════════════ %>
            <tr><td colspan="5" class="cat-header" data-cat="user">👦 User — Compte Discord</td></tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.id</span></td>
              <td>Identifiant Discord unique (snowflake) — identique à member.id</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">123456789012345678</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.username</span></td>
              <td>Identifiant unique de l'utilisateur (unique sur Discord, sans @)</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">zeus_official</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.globalName</span></td>
              <td>Nom d'affichage global choisi par l'utilisateur (peut être null)</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">Zeus</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.discriminator</span></td>
              <td>Ancien discriminateur #XXXX (désormais "0" pour tous les comptes récents)</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">0</span></td>
              <td class="note-cell">Obsolète</td>
            </tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.tag</span></td>
              <td>username#discriminator — format historique, obsolète depuis 2023</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">zeus_official#0</span></td>
              <td class="note-cell">Obsolète</td>
            </tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.bot</span></td>
              <td>true si le compte est un bot Discord</td>
              <td><span class="type-badge type-boolean">boolean</span></td>
              <td><span class="example-val">false</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.system</span></td>
              <td>true si c'est un compte système officiel Discord</td>
              <td><span class="type-badge type-boolean">boolean</span></td>
              <td><span class="example-val">false</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.createdAt</span></td>
              <td>Date de création du compte Discord (déduite du snowflake)</td>
              <td><span class="type-badge type-date">Date</span></td>
              <td><span class="example-val">2022-03-12T10:00:00.000Z</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.createdTimestamp</span></td>
              <td>Timestamp ms de création du compte</td>
              <td><span class="type-badge type-number">number</span></td>
              <td><span class="example-val">1647072000000</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.accentColor</span></td>
              <td>Couleur de profil choisie par l'utilisateur (null si pas définie)</td>
              <td><span class="type-badge type-number">number</span></td>
              <td><span class="example-val">1964779</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.hexAccentColor</span></td>
              <td>Couleur de profil en hexadécimal (null si pas définie)</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">#1de9b6</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.flags</span></td>
              <td>Badges du compte (HypeSquad, Bug Hunter, Early Supporter, etc.)</td>
              <td><span class="type-badge type-object">UserFlags</span></td>
              <td><span class="example-val">UserFlags { bitfield: 64 }</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.displayAvatarURL()</span></td>
              <td>URL de l'avatar du membre (ou avatar par défaut Discord)</td>
              <td><span class="type-badge type-url">URL</span></td>
              <td><span class="example-val">https://cdn.discordapp.com/avatars/…</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.bannerURL()</span></td>
              <td>URL de la bannière de profil (null si aucune — nécessite Nitro)</td>
              <td><span class="type-badge type-url">URL</span></td>
              <td><span class="example-val">https://cdn.discordapp.com/banners/…</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.avatarDecorationURL()</span></td>
              <td>URL de la décoration d'avatar (cadre animé Nitro, null si aucun)</td>
              <td><span class="type-badge type-url">URL</span></td>
              <td><span class="example-val">https://cdn.discordapp.com/…</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="user">
              <td><span class="prop-name">user.toString()</span></td>
              <td>Retourne la mention &lt;@id&gt; du membre</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">&lt;@123456789012345678&gt;</span></td>
              <td></td>
            </tr>

            <%# ═══════════════════════════ SERVEUR ═══════════════════════════ %>
            <tr><td colspan="5" class="cat-header" data-cat="guild">🏠 Guild — Serveur Discord</td></tr>
            <tr class="ref-row" data-cat="guild">
              <td><span class="prop-name">guild.id</span></td>
              <td>Identifiant unique du serveur</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">987654321098765432</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="guild">
              <td><span class="prop-name">guild.name</span></td>
              <td>Nom complet du serveur</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">Arki' Family</span></td>
              <td><span class="badge-impl">Impl.</span></td>
            </tr>
            <tr class="ref-row" data-cat="guild">
              <td><span class="prop-name">guild.description</span></td>
              <td>Description du serveur (null si vide — visible sur la page de découverte)</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">Serveur ARK Survival Evolved…</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="guild">
              <td><span class="prop-name">guild.memberCount</span></td>
              <td>Nombre total de membres (bots inclus)</td>
              <td><span class="type-badge type-number">number</span></td>
              <td><span class="example-val">510</span></td>
              <td><span class="badge-impl">Impl.</span></td>
            </tr>
            <tr class="ref-row" data-cat="guild">
              <td><span class="prop-name">guild.maximumMembers</span></td>
              <td>Capacité maximale de membres du serveur</td>
              <td><span class="type-badge type-number">number</span></td>
              <td><span class="example-val">250000</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="guild">
              <td><span class="prop-name">guild.ownerId</span></td>
              <td>ID du propriétaire du serveur</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">111222333444555666</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="guild">
              <td><span class="prop-name">guild.createdAt</span></td>
              <td>Date de création du serveur</td>
              <td><span class="type-badge type-date">Date</span></td>
              <td><span class="example-val">2020-04-15T12:00:00.000Z</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="guild">
              <td><span class="prop-name">guild.premiumTier</span></td>
              <td>Niveau de boost : 0 (aucun), 1, 2 ou 3 (max)</td>
              <td><span class="type-badge type-enum">enum</span></td>
              <td><span class="example-val">2</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="guild">
              <td><span class="prop-name">guild.premiumSubscriptionCount</span></td>
              <td>Nombre de boosts Nitro actifs sur le serveur</td>
              <td><span class="type-badge type-number">number</span></td>
              <td><span class="example-val">7</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="guild">
              <td><span class="prop-name">guild.vanityURLCode</span></td>
              <td>Code URL personnalisé du serveur (discord.gg/CODE — null si aucun)</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">arki-family</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="guild">
              <td><span class="prop-name">guild.verificationLevel</span></td>
              <td>Niveau de vérification : None, Low, Medium, High, VeryHigh</td>
              <td><span class="type-badge type-enum">enum</span></td>
              <td><span class="example-val">Medium</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="guild">
              <td><span class="prop-name">guild.explicitContentFilter</span></td>
              <td>Filtre contenus explicites : Disabled, MembersWithoutRoles, AllMembers</td>
              <td><span class="type-badge type-enum">enum</span></td>
              <td><span class="example-val">MembersWithoutRoles</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="guild">
              <td><span class="prop-name">guild.preferredLocale</span></td>
              <td>Langue principale du serveur (code ISO)</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">fr</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="guild">
              <td><span class="prop-name">guild.afkChannelId</span></td>
              <td>ID du salon vocal AFK (null si non défini)</td>
              <td><span class="type-badge type-string">string</span></td>
              <td><span class="example-val">123456789012345678</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="guild">
              <td><span class="prop-name">guild.afkTimeout</span></td>
              <td>Délai AFK en secondes (60, 300, 900, 1800, 3600)</td>
              <td><span class="type-badge type-number">number</span></td>
              <td><span class="example-val">300</span></td>
              <td></td>
            </tr>
            <tr class="ref-row" data-cat="guild">
