  <script>
    var currentCat = 'all';

    function filterCat(cat, btn) {
      currentCat = cat;
      document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      filterTable();
    }

    function filterTable() {
      var q = document.getElementById('searchInput').value.toLowerCase();
      document.querySelectorAll('.ref-row').forEach(function(row) {
        var catMatch = currentCat === 'all' || row.dataset.cat === currentCat;
        var text = row.textContent.toLowerCase();
        var textMatch = !q || text.includes(q);
        row.classList.toggle('hidden', !(catMatch && textMatch));
      });
      // Masquer les en-têtes de catégorie si aucune ligne visible
      document.querySelectorAll('tr[data-cat]').forEach(function(header) {
        var cat = header.dataset.cat;
        var hasVisible = Array.from(document.querySelectorAll('.ref-row[data-cat="' + cat + '"]')).some(function(r) {
          return !r.classList.contains('hidden');
        });
        header.classList.toggle('hidden', !hasVisible);
      });
    }
  </script>
