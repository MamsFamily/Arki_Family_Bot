<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Giveaways — Arki Family</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* ── Grille giveaways ── */
    .gw-grid { display:grid; grid-template-columns:1fr 1fr; gap:18px; }
    @media(max-width:900px){ .gw-grid{ grid-template-columns:1fr; } }

    /* ── Carte giveaway ── */
    .gw-card { background:var(--bg-card); border-radius:14px; overflow:hidden; border:1px solid var(--border-color); transition:box-shadow .2s; }
    .gw-card:hover { box-shadow:0 4px 20px rgba(0,0,0,.18); }
    .gw-cover { width:100%; height:130px; object-fit:cover; display:block; }
    .gw-card-header { padding:13px 16px; border-bottom:1px solid var(--border-color); display:flex; align-items:center; gap:10px; }
    .gw-status { font-size:11px; padding:3px 9px; border-radius:20px; font-weight:700; letter-spacing:.3px; }
    .gw-status.active { background:rgba(46,204,113,.15); color:#2ecc71; border:1px solid rgba(46,204,113,.3); }
    .gw-status.ended  { background:rgba(149,165,166,.12); color:#95a5a6; border:1px solid rgba(149,165,166,.25); }
    .gw-card-body { padding:14px 16px; }
    .gw-meta { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:11px; }
    .gw-meta-pill { font-size:12px; padding:3px 9px; border-radius:20px; background:var(--bg-input); color:var(--text-secondary); display:flex; align-items:center; gap:4px; }
    .gw-prize-box { background:linear-gradient(135deg,rgba(255,107,107,.08),rgba(243,156,18,.08)); border:1px solid rgba(255,107,107,.2); border-radius:10px; padding:10px 14px; margin-bottom:11px; font-size:14px; font-weight:600; }
    .gw-conditions { font-size:12px; color:var(--text-muted); margin-bottom:11px; line-height:1.5; }
    .gw-progress { background:var(--bg-input); border-radius:20px; height:5px; overflow:hidden; margin-bottom:12px; }
    .gw-progress-fill { height:100%; background:linear-gradient(90deg,#FF6B6B,#f39c12); border-radius:20px; transition:width .3s; }
    .gw-actions { display:flex; gap:7px; flex-wrap:wrap; }
    .gw-winners-box { background:rgba(241,196,15,.08); border:1px solid rgba(241,196,15,.25); border-radius:10px; padding:10px 14px; margin-bottom:11px; font-size:13px; }
    .gw-badge-ping { font-size:11px; padding:2px 7px; border-radius:10px; background:rgba(114,137,218,.2); color:#7289da; border:1px solid rgba(114,137,218,.3); font-weight:600; }

    /* ── Bannière image par défaut ── */
    .default-img-banner { background:var(--bg-card); border:1px solid var(--border-color); border-radius:14px; padding:18px 20px; margin-bottom:22px; display:flex; align-items:center; gap:16px; flex-wrap:wrap; }
    .default-img-preview { height:60px; border-radius:8px; object-fit:cover; border:1px solid var(--border-color); }
    .default-img-url { flex:1; min-width:240px; }

    /* ── Sections du modal ── */
    .modal-section { margin-bottom:20px; padding-bottom:20px; border-bottom:1px solid var(--border-color); }
    .modal-section:last-of-type { border-bottom:none; margin-bottom:0; padding-bottom:0; }
    .modal-section-title { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.8px; color:var(--text-muted); margin-bottom:12px; display:flex; align-items:center; gap:6px; }
    .form-row-2 { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    @media(max-width:600px){ .form-row-2 { grid-template-columns:1fr; } }

    /* ── Toggle @everyone ── */
    .toggle-row { display:flex; align-items:center; gap:12px; padding:12px 14px; background:var(--bg-input); border-radius:10px; cursor:pointer; border:1px solid var(--border-color); transition:border-color .15s; }
    .toggle-row:hover { border-color:var(--accent); }
    .toggle-row input[type=checkbox] { width:18px; height:18px; accent-color:var(--accent); cursor:pointer; flex-shrink:0; }
    .toggle-label { flex:1; }
    .toggle-label strong { font-size:14px; display:block; }
    .toggle-label span { font-size:12px; color:var(--text-muted); }

    /* ── Prize select ── */
    .prize-tabs { display:flex; gap:8px; margin-bottom:12px; }
    .prize-tab { flex:1; padding:8px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-input); text-align:center; font-size:13px; font-weight:600; cursor:pointer; transition:all .15s; }
    .prize-tab.active { background:rgba(255,107,107,.12); border-color:rgba(255,107,107,.4); color:#FF6B6B; }

    /* ── Image URL field ── */
    .img-url-group { position:relative; }
    .img-url-preview { width:100%; border-radius:8px; object-fit:cover; max-height:120px; margin-top:8px; display:none; border:1px solid var(--border-color); }

    /* ── Participants ── */
    .participants-list { max-height:320px; overflow-y:auto; }
    .participant-row { display:flex; align-items:center; justify-content:space-between; padding:7px 0; border-bottom:1px solid var(--border-color); font-size:13px; }
    .participant-row:last-child { border-bottom:none; }
    .winner-badge { background:#f39c12; color:#000; font-size:10px; padding:2px 7px; border-radius:10px; font-weight:700; margin-left:6px; }

    /* ── État vide ── */
    .empty-state { text-align:center; padding:60px 20px; color:var(--text-secondary); }
    .empty-state .emoji { font-size:52px; margin-bottom:14px; }
  </style>
</head>
<body>
  <%- include('sidebar') %>
  <div class="main-content">
    <div class="page-header">
      <h1>🎉 Giveaways</h1>
      <button class="btn btn-primary" onclick="openCreate()">➕ Créer un Giveaway</button>
    </div>

    <!-- Bannière image par défaut (admin uniquement) -->
    <% if (role === 'admin') { %>
    <div class="default-img-banner">
      <div style="min-width:170px;">
        <div style="font-size:13px;font-weight:700;margin-bottom:3px;">🖼️ Image par défaut</div>
        <div style="font-size:12px;color:var(--text-muted);">Appliquée à chaque nouveau giveaway</div>
      </div>
      <% if (defaultImageUrl) { %>
        <img src="<%=defaultImageUrl%>" class="default-img-preview" alt="Image par défaut" onerror="this.style.display='none'">
      <% } %>
      <div class="default-img-url">
        <div style="display:flex;gap:8px;align-items:center;">
          <input type="text" id="defaultImgUrlInput" value="<%=defaultImageUrl%>" placeholder="https://i.imgur.com/..." style="flex:1;" oninput="previewDefaultImg(this.value)">
          <button class="btn btn-primary btn-sm" onclick="saveDefaultImage()" style="white-space:nowrap;">💾 Enregistrer</button>
          <% if (defaultImageUrl) { %>
          <button class="btn btn-danger btn-sm" onclick="clearDefaultImage()" title="Retirer l'image par défaut">✕</button>
          <% } %>
        </div>
        <img id="defaultImgPreview" src="<%=defaultImageUrl%>" alt="Aperçu" style="height:40px;border-radius:6px;margin-top:6px;object-fit:cover;<%=defaultImageUrl?'':'display:none;'%>" onerror="this.style.display='none'">
      </div>
    </div>
    <% } %>

    <%
      const active = giveaways.filter(g => g.status === 'active');
      const ended = giveaways.filter(g => g.status === 'ended');
    %>

    <% if (active.length > 0) { %>
    <div style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--text-muted);margin-bottom:12px;">🟢 En cours (<%=active.length%>)</div>
    <div class="gw-grid" style="margin-bottom:28px;">
      <% for (const g of active) { %>
      <div class="gw-card">
        <% if (g.imageUrl) { %>
        <img src="<%=g.imageUrl%>" class="gw-cover" alt="Couverture" onerror="this.style.display='none'">
        <% } %>
        <div class="gw-card-header">
          <span class="gw-status active">● Actif</span>
          <strong style="flex:1;font-size:15px;"><%=g.title%></strong>
          <% if (g.pingEveryone) { %><span class="gw-badge-ping">@everyone</span><% } %>
          <code style="font-size:11px;color:var(--text-muted);background:var(--bg-input);padding:2px 6px;border-radius:4px;"><%=g.id%></code>
        </div>
        <div class="gw-card-body">
          <div class="gw-meta">
            <span class="gw-meta-pill">⏰ <%=formatTimeLeft(g.endTime)%></span>
            <span class="gw-meta-pill">👥 <%=g.participants.length%> participant(s)</span>
            <span class="gw-meta-pill">🏆 <%=g.winnerCount%> gagnant(s)</span>
            <span class="gw-meta-pill">👤 <%=g.createdByName || g.createdBy%></span>
          </div>
          <% if (g.conditions) { %><div class="gw-conditions">📋 <%=g.conditions%></div><% } %>
          <div class="gw-prize-box">
            🎁 <% if (g.prize.type==='libre') { %><%=g.prize.name%><% } else { %><%= (itemTypes.find(i=>i.id===g.prize.itemId)?.emoji||'🎁')+' '+(itemTypes.find(i=>i.id===g.prize.itemId)?.name||g.prize.name||g.prize.itemId) %><% } %> <span style="font-weight:400;color:var(--text-muted);">×<%=g.prize.quantity%></span>
          </div>
          <div class="gw-progress">
            <div class="gw-progress-fill" style="width:<%=Math.min(100,Math.max(4,((Date.now()-new Date(g.createdAt).getTime())/(new Date(g.endTime).getTime()-new Date(g.createdAt).getTime()))*100))%>%"></div>
          </div>
          <div class="gw-actions">
            <button class="btn btn-sm btn-secondary" onclick="openParticipants('<%=g.id%>')">👥 Participants</button>
            <% if (role === 'admin') { %>
            <button class="btn btn-sm btn-primary" onclick="openUpdateImage('<%=g.id%>','<%=g.imageUrl%>')">🖼️ Image</button>
            <button class="btn btn-sm" style="background:#e67e22;color:#fff;" onclick="endGiveaway('<%=g.id%>','<%=g.title%>')">⏩ Terminer</button>
            <button class="btn btn-sm btn-danger" onclick="deleteGiveaway('<%=g.id%>','<%=g.title%>')">🗑️</button>
            <% } %>
          </div>
        </div>
      </div>
      <% } %>
    </div>
    <% } %>

    <% if (ended.length > 0) { %>
    <div style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--text-muted);margin-bottom:12px;margin-top:8px;">⚫ Terminés (<%=ended.length%>)</div>
    <div class="gw-grid">
      <% for (const g of ended) { %>
      <div class="gw-card" style="opacity:.65;">
        <div class="gw-card-header">
          <span class="gw-status ended">● Terminé</span>
          <strong style="flex:1;"><%=g.title%></strong>
          <code style="font-size:11px;color:var(--text-muted);background:var(--bg-input);padding:2px 6px;border-radius:4px;"><%=g.id%></code>
        </div>
        <div class="gw-card-body">
          <div class="gw-meta">
            <span class="gw-meta-pill">👥 <%=g.participants.length%> participant(s)</span>
            <span class="gw-meta-pill">🏆 <%=g.winners.length%>/<%=g.winnerCount%> gagnant(s)</span>
          </div>
          <% if (g.winners.length > 0) { %>
          <div class="gw-winners-box">
            🏆 <strong>Gagnant(s) :</strong> <%=g.winners.map(id=>`<@${id}>`).join(', ')%>
          </div>
          <% } else { %>
          <div style="font-size:13px;color:var(--text-muted);margin-bottom:10px;">Aucun participant éligible.</div>
          <% } %>
          <div class="gw-actions">
            <button class="btn btn-sm btn-secondary" onclick="openParticipants('<%=g.id%>')">👥 Participants</button>
            <% if (role === 'admin') { %>
            <button class="btn btn-sm btn-danger" onclick="deleteGiveaway('<%=g.id%>','<%=g.title%>')">🗑️ Supprimer</button>
            <% } %>
          </div>
        </div>
      </div>
      <% } %>
    </div>
    <% } %>

    <% if (giveaways.length === 0) { %>
    <div class="empty-state">
      <div class="emoji">🎉</div>
      <p>Aucun giveaway pour le moment.</p>
      <button class="btn btn-primary" onclick="openCreate()" style="margin-top:10px;">➕ Créer le premier giveaway</button>
    </div>
    <% } %>
  </div>

  <!-- ═══════════════════ MODAL CRÉER GIVEAWAY ═══════════════════ -->
  <div id="createModal" class="modal-overlay" style="display:none;" onclick="if(event.target===this)closeCreate()">
    <div class="modal" style="max-width:920px;width:96%;max-height:92vh;overflow:hidden;" onclick="event.stopPropagation()">
      <div class="modal-header">
        <h2>🎉 Créer un Giveaway</h2>
        <button class="modal-close" onclick="closeCreate()">✕</button>
      </div>
      <form id="createForm" onsubmit="submitCreate(event)">
        <div class="modal-body" style="display:grid;grid-template-columns:1fr 1fr;gap:0;padding:0;">

          <!-- Colonne gauche : formulaire -->
          <div style="padding:20px 20px 20px 24px;border-right:1px solid var(--border-color);overflow-y:auto;max-height:72vh;">

            <!-- Section : Infos générales -->
            <div class="modal-section">
              <div class="modal-section-title">📋 Informations générales</div>
              <div class="form-group">
                <label>Titre <span style="color:#FF6B6B">*</span></label>
                <input type="text" name="title" id="gw_title" placeholder="Ex : Giveaway Pack Légendaire" required maxlength="100" oninput="updatePreview()">
              </div>
              <div class="form-group">
                <label>Description <span style="font-weight:400;color:var(--text-muted)">(optionnel)</span></label>
                <input type="text" name="description" id="gw_description" placeholder="Ex : Pack offert par Arki Family" maxlength="200" oninput="updatePreview()">
              </div>
              <div class="form-group" style="margin-bottom:0;">
                <label>Conditions <span style="font-weight:400;color:var(--text-muted)">(optionnel)</span></label>
                <input type="text" name="conditions" id="gw_conditions" placeholder="Ex : Ouvert à tous les membres" maxlength="200" oninput="updatePreview()">
              </div>
            </div>

            <!-- Section : Gain -->
            <div class="modal-section">
              <div class="modal-section-title">🎁 Gain</div>
              <div class="prize-tabs" id="prizeTabs">
                <div class="prize-tab active" onclick="setPrizeType('item')" id="tabItem">📦 Item inventaire</div>
                <div class="prize-tab" onclick="setPrizeType('libre')" id="tabLibre">✨ Occasionnel</div>
              </div>
              <input type="hidden" name="prizeType" id="prizeTypeInput" value="item">

              <div id="prizeItemSection">
                <div class="form-row-2">
                  <div class="form-group" style="margin-bottom:0;">
                    <label>Item <span style="color:#FF6B6B">*</span></label>
                    <select name="prizeItemId" id="prizeItemSelect" onchange="updatePreview()">
                      <option value="">— Choisir —</option>
                      <% for (const it of itemTypes) { %>
                      <option value="<%=it.id%>" data-label="<%=it.emoji%> <%=it.name%>"><%=it.emoji%> <%=it.name%></option>
                      <% } %>
                    </select>
                  </div>
                  <div class="form-group" style="margin-bottom:0;">
                    <label>Quantité</label>
                    <input type="number" name="prizeQuantity" id="prizeQtyItem" value="1" min="1" max="9999" oninput="updatePreview()">
                  </div>
                </div>
              </div>

              <div id="prizeLibreSection" style="display:none;">
                <div class="form-row-2">
                  <div class="form-group" style="margin-bottom:0;">
                    <label>Nom <span style="color:#FF6B6B">*</span></label>
                    <input type="text" name="prizeItemName" id="prizeItemName" placeholder="Ex : Pack Légendaire" maxlength="100" oninput="updatePreview()">
                  </div>
                  <div class="form-group" style="margin-bottom:0;">
                    <label>Quantité</label>
                    <input type="number" name="prizeQuantity2" id="prizeQtyLibre" value="1" min="1" max="9999" oninput="updatePreview()">
                  </div>
                </div>
              </div>
            </div>

            <!-- Section : Durée & Paramètres -->
            <div class="modal-section">
              <div class="modal-section-title">⏰ Durée & Paramètres</div>
              <div class="form-row-2">
                <div class="form-group">
                  <label>Heure de fin <span style="color:#FF6B6B">*</span> <span style="font-weight:400;color:var(--text-muted)">(Paris — vide = aujourd'hui ou demain)</span></label>
                  <input type="time" name="endTime" id="gw_endTime" required oninput="updatePreview()">
                </div>
                <div class="form-group">
                  <label>Nombre de gagnants</label>
                  <input type="number" name="winnerCount" value="1" min="1" max="20">
                </div>
              </div>
              <div class="form-group">
                <label>Salon Discord <span style="color:#FF6B6B">*</span></label>
                <% if (channels.length > 0) { %>
                <select name="channelId">
                  <option value="">— Choisir un salon —</option>
                  <% for (const ch of channels) { %>
                  <option value="<%=ch.id%>"># <%=ch.name%></option>
                  <% } %>
                </select>
                <% } else { %>
                <input type="text" name="channelId" placeholder="Ex : 1157994586774442085" pattern="[0-9]+" title="ID numérique du salon Discord">
                <% } %>
              </div>
              <div class="form-group" style="margin-bottom:0;">
                <label>Restriction de rôle <span style="font-weight:400;color:var(--text-muted)">(ID du rôle, optionnel)</span></label>
                <input type="text" name="roleId" placeholder="Laisser vide = ouvert à tous">
              </div>
            </div>

            <% if (role === 'admin') { %>
            <!-- Section : Image (admin uniquement) -->
            <div class="modal-section">
              <div class="modal-section-title">🖼️ Image de couverture</div>
              <div class="form-group" style="margin-bottom:0;">
                <label>URL <span style="font-weight:400;color:var(--text-muted)">(optionnel — image par défaut si vide)</span></label>
                <input type="url" name="imageUrl" id="createImgUrl" placeholder="https://i.imgur.com/..." oninput="updatePreview()">
              </div>
            </div>
            <% } %>

            <!-- Section : Options -->
            <div class="modal-section" style="border-bottom:none;margin-bottom:0;padding-bottom:0;">
              <div class="modal-section-title">⚙️ Options</div>
              <label class="toggle-row" for="pingEveryoneCheck">
                <input type="checkbox" name="pingEveryone" id="pingEveryoneCheck" value="on">
                <div class="toggle-label">
                  <strong>📢 Mentionner @everyone</strong>
                  <span>Notifie tout le serveur après la publication.</span>
                </div>
              </label>
            </div>

          </div>

          <!-- Colonne droite : aperçu embed -->
          <div style="padding:20px;overflow-y:auto;max-height:72vh;background:var(--bg-input);border-radius:0 12px 0 0;">
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--text-muted);margin-bottom:12px;">👁️ Aperçu de l'embed</div>
            <div id="embedPreview" style="background:#2b2d31;border-radius:8px;overflow:hidden;border-left:4px solid #FF6B6B;max-width:100%;">
              <div style="padding:12px 14px;">
                <div id="prev_title" style="font-size:15px;font-weight:700;color:#fff;margin-bottom:6px;word-break:break-word;">🎉 Titre du giveaway</div>
                <div id="prev_description" style="font-size:13px;color:#dbdee1;margin-bottom:8px;word-break:break-word;display:none;"></div>
                <div id="prev_prize" style="font-size:13px;color:#dbdee1;margin-bottom:4px;">🎁 —</div>
                <div id="prev_winners" style="font-size:13px;color:#dbdee1;margin-bottom:4px;">🏆 1 gagnant(s)</div>
                <div id="prev_conditions" style="font-size:12px;color:#949ba4;margin-bottom:4px;display:none;"></div>
                <div id="prev_footer" style="font-size:11px;color:#949ba4;margin-top:8px;border-top:1px solid rgba(255,255,255,.07);padding-top:8px;">⏰ Se termine à --:--</div>
              </div>
              <div id="prev_image_wrap" style="display:none;"><img id="prev_image" src="" alt="" style="width:100%;max-height:200px;object-fit:cover;display:block;" onerror="document.getElementById('prev_image_wrap').style.display='none'"></div>
            </div>
            <p style="font-size:11px;color:var(--text-muted);margin-top:10px;">L'aperçu est approximatif. Le rendu final peut légèrement différer sur Discord.</p>
          </div>

        </div>
        <div class="modal-footer" style="display:flex;justify-content:flex-end;gap:10px;padding:16px 24px;border-top:1px solid var(--border-color);">
          <button type="button" class="btn btn-secondary" onclick="closeCreate()">Annuler</button>
          <button type="submit" class="btn btn-primary" id="createBtn">🎉 Publier le Giveaway</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ═══════════════════ MODAL PARTICIPANTS ═══════════════════ -->
  <div id="participantsModal" class="modal-overlay" style="display:none;" onclick="if(event.target===this)this.style.display='none'">
    <div class="modal" style="max-width:500px;width:95%;" onclick="event.stopPropagation()">
      <div class="modal-header">
        <h2>👥 Participants</h2>
        <button class="modal-close" onclick="document.getElementById('participantsModal').style.display='none'">✕</button>
      </div>
      <div class="modal-body" id="participantsBody" style="padding:0 20px 20px;">
        <p style="color:var(--text-secondary);">Chargement...</p>
      </div>
    </div>
  </div>

  <!-- ═══════════════════ MODAL IMAGE ═══════════════════ -->
  <div id="imageModal" class="modal-overlay" style="display:none;" onclick="if(event.target===this)this.style.display='none'">
    <div class="modal" style="max-width:440px;width:95%;" onclick="event.stopPropagation()">
      <div class="modal-header">
        <h2>🖼️ Modifier l'image</h2>
        <button class="modal-close" onclick="document.getElementById('imageModal').style.display='none'">✕</button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="imageGiveawayId">
        <div class="form-group">
          <label>URL de la nouvelle image</label>
          <input type="url" id="imageUrlInput" placeholder="https://i.imgur.com/..." oninput="previewImgModal(this.value)">
          <img id="imgModalPreview" alt="Aperçu" class="img-url-preview" onerror="this.style.display='none'">
        </div>
        <div style="font-size:12px;color:var(--text-muted);margin-top:4px;">Utilisez un lien Imgur, Discord CDN ou tout hébergement d'images public.</div>
      </div>
      <div class="modal-footer" style="display:flex;justify-content:flex-end;gap:10px;padding:14px 20px;border-top:1px solid var(--border-color);">
        <button class="btn btn-secondary" onclick="document.getElementById('imageModal').style.display='none'">Annuler</button>
        <button class="btn btn-primary" onclick="submitImage()">💾 Enregistrer</button>
      </div>
    </div>
  </div>

  <script>
    /* ── Utilitaires modal ── */
    function openCreate() { document.getElementById('createModal').style.display = 'flex'; }
    function closeCreate() { document.getElementById('createModal').style.display = 'none'; }

    /* ── Type de gain ── */
    function setPrizeType(type) {
      document.getElementById('prizeTypeInput').value = type;
      document.getElementById('prizeItemSection').style.display  = type === 'item'  ? 'block' : 'none';
      document.getElementById('prizeLibreSection').style.display = type === 'libre' ? 'block' : 'none';
      document.getElementById('tabItem').classList.toggle('active', type === 'item');
      document.getElementById('tabLibre').classList.toggle('active', type === 'libre');
      if (type === 'item') {
        document.getElementById('prizeQtyItem').name = 'prizeQuantity';
        document.getElementById('prizeQtyLibre').name = 'prizeQuantity_off';
      } else {
        document.getElementById('prizeQtyItem').name = 'prizeQuantity_off';
        document.getElementById('prizeQtyLibre').name = 'prizeQuantity';
      }
      updatePreview();
    }
    setPrizeType('item');

    /* ── Aperçu live embed ── */
    function updatePreview() {
      var title = (document.getElementById('gw_title')?.value || '').trim() || 'Titre du giveaway';
      var desc  = (document.getElementById('gw_description')?.value || '').trim();
      var cond  = (document.getElementById('gw_conditions')?.value || '').trim();
      var time  = (document.getElementById('gw_endTime')?.value || '');
      var type  = document.getElementById('prizeTypeInput')?.value;
      var prizeLabel = '—';
      if (type === 'item') {
        var sel = document.getElementById('prizeItemSelect');
        var opt = sel?.options[sel.selectedIndex];
        var itemLabel = opt?.dataset?.label || opt?.text || '';
        var qty = document.getElementById('prizeQtyItem')?.value || '1';
        if (itemLabel) prizeLabel = itemLabel + ' × ' + qty;
      } else {
        var name = document.getElementById('prizeItemName')?.value || '';
        var qty2 = document.getElementById('prizeQtyLibre')?.value || '1';
        if (name) prizeLabel = name + ' × ' + qty2;
      }
      var imgUrl = document.getElementById('createImgUrl')?.value || '';

      document.getElementById('prev_title').textContent = '🎉 ' + title;
      var descEl = document.getElementById('prev_description');
      if (desc) { descEl.style.display = 'block'; descEl.textContent = desc; }
      else { descEl.style.display = 'none'; }
      document.getElementById('prev_prize').textContent = '🎁 ' + prizeLabel;
      var condEl = document.getElementById('prev_conditions');
      if (cond) { condEl.style.display = 'block'; condEl.textContent = '📋 ' + cond; }
      else { condEl.style.display = 'none'; }
      document.getElementById('prev_footer').textContent = '⏰ Se termine à ' + (time || '--:--') + ' (Paris)';
      var imgWrap = document.getElementById('prev_image_wrap');
      var imgEl = document.getElementById('prev_image');
      if (imgUrl && imgUrl.startsWith('http')) {
        imgEl.src = imgUrl; imgWrap.style.display = 'block';
      } else { imgWrap.style.display = 'none'; }
    }

    /* ── Aperçu image (modal image) ── */
    function previewImgModal(url) {
      var p = document.getElementById('imgModalPreview');
      if (url && url.startsWith('http')) { p.src = url; p.style.display = 'block'; }
      else { p.style.display = 'none'; }
    }

    /* ── Aperçu image par défaut ── */
    function previewDefaultImg(url) {
      var p = document.getElementById('defaultImgPreview');
      if (url && url.startsWith('http')) { p.src = url; p.style.display = 'inline-block'; }
      else { p.style.display = 'none'; }
    }

    /* ── Soumettre le formulaire de création ── */
    async function submitCreate(e) {
      e.preventDefault();
      var btn = document.getElementById('createBtn');
      btn.disabled = true; btn.textContent = '⏳ Publication...';
      var fd = new FormData(document.getElementById('createForm'));
      // Si type = item, retirer prizeQuantity_off
      fd.delete('prizeQuantity_off');
      var r = await fetch('/giveaways/create', { method: 'POST', body: fd });
      var d = await r.json();
      if (d.error) {
        alert('❌ ' + d.error);
        btn.disabled = false; btn.textContent = '🎉 Publier le Giveaway';
      } else {
        alert('✅ Giveaway publié avec succès !');
        location.reload();
      }
    }

    /* ── Participants ── */
    function openParticipants(id) {
      document.getElementById('participantsModal').style.display = 'flex';
      var body = document.getElementById('participantsBody');
      body.innerHTML = '<p style="color:var(--text-secondary);">Chargement...</p>';
      fetch('/giveaways/' + id + '/participants').then(r => r.json()).then(d => {
        if (!d.participants || d.participants.length === 0) {
          body.innerHTML = '<p style="color:var(--text-secondary);padding-top:10px;">Aucun participant pour le moment.</p>';
          return;
        }
        var html = '<p style="margin-bottom:12px;color:var(--text-muted);font-size:13px;">' + d.participants.length + ' participant(s)</p><div class="participants-list">';
        d.participants.forEach(function(uid) {
          var isWinner = d.winners && d.winners.includes(uid);
          html += '<div class="participant-row"><span><code>' + uid + '</code>' + (isWinner ? '<span class="winner-badge">🏆 Gagnant</span>' : '') + '</span>';
          if (d.status === 'active') html += '<button class="btn btn-sm btn-danger" onclick="removeParticipant(\'' + id + '\',\'' + uid + '\')">Retirer</button>';
          html += '</div>';
        });
        html += '</div>';
        body.innerHTML = html;
      });
    }

    async function removeParticipant(gid, uid) {
      if (!confirm('Retirer ce participant ?')) return;
      var r = await fetch('/giveaways/' + gid + '/participants/' + uid, { method: 'DELETE' });
      var d = await r.json();
      if (d.success) openParticipants(gid);
      else alert('❌ Erreur : ' + (d.error || 'inconnue'));
    }

    /* ── Modifier l'image ── */
    function openUpdateImage(id, currentUrl) {
      document.getElementById('imageGiveawayId').value = id;
      document.getElementById('imageUrlInput').value = currentUrl || '';
      previewImgModal(currentUrl || '');
      document.getElementById('imageModal').style.display = 'flex';
    }

    async function submitImage() {
      var id = document.getElementById('imageGiveawayId').value;
      var url = document.getElementById('imageUrlInput').value.trim();
      if (!url) { alert('Veuillez saisir une URL d\'image.'); return; }
      var fd = new FormData();
      fd.append('imageUrl', url);
      var r = await fetch('/giveaways/' + id + '/update-image', { method: 'POST', body: fd });
      var d = await r.json();
      if (d.error) alert('❌ ' + d.error);
      else { alert('✅ Image mise à jour !'); location.reload(); }
    }

    /* ── Terminer un giveaway ── */
    async function endGiveaway(id, title) {
      if (!confirm('Terminer le giveaway "' + title + '" et lancer le tirage maintenant ?')) return;
      var r = await fetch('/giveaways/' + id + '/end', { method: 'POST' });
      var d = await r.json();
      if (d.success) { alert('✅ Tirage effectué !'); location.reload(); }
      else alert('❌ Erreur : ' + (d.error || 'inconnue'));
    }

    /* ── Supprimer un giveaway ── */
    async function deleteGiveaway(id, title) {
      if (!confirm('Supprimer définitivement le giveaway "' + title + '" ?')) return;
      var r = await fetch('/giveaways/' + id + '/delete', { method: 'POST' });
      var d = await r.json();
      if (d.success) location.reload();
      else alert('❌ Erreur : ' + (d.error || 'inconnue'));
    }

    /* ── Image par défaut ── */
    async function saveDefaultImage() {
      var url = document.getElementById('defaultImgUrlInput').value.trim();
      var fd = new FormData(); fd.append('imageUrl', url);
      var r = await fetch('/giveaways/set-default-image', { method: 'POST', body: fd });
      var d = await r.json();
      if (d.success) { alert('✅ Image par défaut enregistrée !'); location.reload(); }
      else alert('❌ Erreur : ' + (d.error || 'inconnue'));
    }

    async function clearDefaultImage() {
      if (!confirm('Retirer l\'image par défaut ?')) return;
      var r = await fetch('/giveaways/clear-default-image', { method: 'POST' });
      var d = await r.json();
      if (d.success) location.reload();
      else alert('❌ Erreur : ' + (d.error || 'inconnue'));
    }
  </script>
</body>
</html>
