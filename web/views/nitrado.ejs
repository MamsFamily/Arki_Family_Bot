<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nitrado — Arki Dashboard</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    /* ── Layout ────────────────────────────────────────────────── */
    .nitrado-content { max-width: 1100px; margin: 0 auto; padding: 0 0 60px; }

    /* ── Token manquant ────────────────────────────────────────── */
    .no-token-box {
      background: var(--card-bg);
      border: 2px dashed var(--border);
      border-radius: 16px;
      padding: 48px 32px;
      text-align: center;
      margin-top: 32px;
    }
    .no-token-box .nt-icon { font-size: 56px; margin-bottom: 12px; }
    .no-token-box h2 { font-size: 1.4rem; margin-bottom: 8px; }
    .no-token-box p { color: var(--text-muted); margin-bottom: 20px; }
    .no-token-box code {
      display: inline-block;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 6px 16px;
      font-size: 0.9rem;
      letter-spacing: 0.03em;
    }

    /* ── En-tête global ────────────────────────────────────────── */
    .nitrado-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
      margin-bottom: 28px;
    }
    .nitrado-header h1 { font-size: 1.6rem; display: flex; align-items: center; gap: 10px; margin: 0; }
    .header-actions { display: flex; gap: 10px; flex-wrap: wrap; }

    /* ── Cartes serveurs ───────────────────────────────────────── */
    .servers-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 16px;
      margin-bottom: 36px;
    }
    .server-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 20px;
      position: relative;
      transition: box-shadow .18s;
    }
    .server-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,.15); }
    .server-card-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 14px;
    }
    .server-name { font-weight: 700; font-size: 1rem; line-height: 1.3; flex: 1; }
    .status-badge {
      font-size: 0.72rem;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 20px;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .status-badge.started   { background: #1a3a1a; color: #4caf50; }
    .status-badge.stopped   { background: #3a1a1a; color: #f44336; }
    .status-badge.restarting{ background: #3a2e00; color: #ffc107; }
    .status-badge.unknown   { background: var(--bg); color: var(--text-muted); }

    .server-meta { display: flex; flex-direction: column; gap: 5px; margin-bottom: 14px; }
    .server-meta-row {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.82rem;
      color: var(--text-muted);
    }
    .server-meta-row span:first-child { width: 16px; text-align: center; }
    .server-meta-row strong { color: var(--text); }

    .server-actions { display: flex; gap: 7px; flex-wrap: wrap; }
    .btn-sm {
      font-size: 0.78rem;
      padding: 5px 12px;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      font-weight: 600;
      transition: opacity .15s, transform .1s;
    }
    .btn-sm:active { transform: scale(.96); }
    .btn-sm:disabled { opacity: .45; cursor: not-allowed; }
    .btn-restart { background: #2a4a2a; color: #4caf50; }
    .btn-stop    { background: #3a1a1a; color: #f44336; }
    .btn-start   { background: #1a2a3a; color: #42a5f5; }
    .btn-mods    { background: var(--bg); color: var(--text-muted); border: 1px solid var(--border); }

    /* ── Sections ──────────────────────────────────────────────── */
    .nitrado-section {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 24px;
      margin-bottom: 20px;
    }
    .nitrado-section h2 {
      font-size: 1.1rem;
      margin: 0 0 18px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .section-divider {
      height: 1px;
      background: var(--border);
      margin: 18px 0;
    }

    /* ── Formulaires inline ────────────────────────────────────── */
    .inline-form {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }
    .inline-form input, .inline-form select {
      flex: 1;
      min-width: 160px;
      max-width: 320px;
      padding: 9px 14px;
      border-radius: 9px;
      border: 1px solid var(--border);
      background: var(--bg);
      color: var(--text);
      font-size: 0.88rem;
    }
    .inline-form input:focus, .inline-form select:focus {
      outline: none;
      border-color: var(--accent);
    }

    /* ── Paramètres config ─────────────────────────────────────── */
    .config-presets {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 14px;
    }
    .config-preset-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px 16px;
    }
    .config-preset-card label {
      display: block;
      font-size: 0.82rem;
      font-weight: 700;
      margin-bottom: 8px;
      color: var(--text-muted);
    }
    .config-preset-card .preset-row {
      display: flex;
      gap: 8px;
      align-items: center;
    }
    .config-preset-card input {
      flex: 1;
      padding: 7px 10px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--card-bg);
      color: var(--text);
      font-size: 0.85rem;
    }
    .config-preset-card input:focus { outline: none; border-color: var(--accent); }

    /* ── Toast notification ────────────────────────────────────── */
    #nit-toast {
      position: fixed;
      bottom: 28px;
      right: 28px;
      background: #1e2a1e;
      border: 1px solid #4caf50;
      color: #a5d6a7;
      padding: 12px 20px;
      border-radius: 12px;
      font-size: 0.88rem;
      font-weight: 600;
      max-width: 340px;
      z-index: 9999;
      opacity: 0;
      transform: translateY(12px);
      transition: opacity .25s, transform .25s;
      pointer-events: none;
    }
    #nit-toast.show { opacity: 1; transform: translateY(0); }
    #nit-toast.error { background: #2a1a1a; border-color: #f44336; color: #ef9a9a; }

    /* ── Résultats bulk ────────────────────────────────────────── */
    .bulk-results {
      margin-top: 14px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .bulk-result-row {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.82rem;
      padding: 6px 12px;
      border-radius: 8px;
      background: var(--bg);
    }
    .bulk-result-row.ok   { border-left: 3px solid #4caf50; }
    .bulk-result-row.fail { border-left: 3px solid #f44336; }

    /* ── Loader ────────────────────────────────────────────────── */
    .spin {
      display: inline-block;
      animation: spin .7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Refresh bar ───────────────────────────────────────────── */
    .refresh-bar {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-bottom: 14px;
    }
    .refresh-bar button {
      background: none;
      border: none;
      color: var(--accent);
      cursor: pointer;
      font-weight: 600;
      font-size: 0.82rem;
      padding: 0;
    }

    /* ── Modal mods ────────────────────────────────────────────── */
    .modal-overlay {
      display: none;
      position: fixed; inset: 0;
      background: rgba(0,0,0,.6);
      z-index: 1000;
      justify-content: center;
      align-items: center;
    }
    .modal-overlay.open { display: flex; }
    .modal-box {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 28px;
      width: 100%;
      max-width: 480px;
      position: relative;
    }
    .modal-box h3 { margin: 0 0 16px; font-size: 1.1rem; }
    .modal-close {
      position: absolute;
      top: 14px; right: 16px;
      background: none; border: none;
      color: var(--text-muted);
      font-size: 1.3rem;
      cursor: pointer;
    }
    .mod-list { display: flex; flex-direction: column; gap: 6px; margin: 14px 0; max-height: 280px; overflow-y: auto; }
    .mod-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: var(--bg);
      border-radius: 8px;
      padding: 7px 12px;
      font-size: 0.85rem;
    }
    .mod-item .mod-id { font-family: monospace; color: var(--accent); }
    .btn-remove-mod {
      background: #3a1a1a;
      color: #f44336;
      border: none;
      border-radius: 6px;
      padding: 3px 10px;
      font-size: 0.75rem;
      font-weight: 700;
      cursor: pointer;
    }
    .empty-mods { color: var(--text-muted); font-size: 0.85rem; text-align: center; padding: 20px 0; }

    @media (max-width: 600px) {
      .nitrado-header { flex-direction: column; align-items: flex-start; }
      .header-actions { width: 100%; }
      .header-actions .btn { flex: 1; text-align: center; }
      .config-presets { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<%- include('sidebar') %>

<main class="main-content">
  <div class="nitrado-content">

    <% if (!hasToken) { %>
    <!-- ── Token manquant ── -->
    <div class="no-token-box">
      <div class="nt-icon">🖥️</div>
      <h2>Token Nitrado non configuré</h2>
      <p>Pour utiliser le gestionnaire de serveurs, ajoute ton token Nitrado<br>dans les secrets du projet sous le nom :</p>
      <code>NITRADO_TOKEN</code>
      <p style="margin-top:16px;font-size:0.85rem;color:var(--text-muted)">
        Génère un <strong>Long-life token</strong> sur <a href="https://server.nitrado.net/developer" target="_blank" style="color:var(--accent)">server.nitrado.net → Développeurs</a><br>
        puis redémarre le dashboard.
      </p>
    </div>

    <% } else { %>

    <!-- ── En-tête ── -->
    <div class="nitrado-header">
      <h1>🖥️ Gestion Nitrado <span style="font-size:.75rem;font-weight:400;color:var(--text-muted)">ARK: Survival Ascended</span></h1>
      <div class="header-actions">
        <button class="btn btn-secondary" id="btn-refresh-all" onclick="refreshStatuses()">🔄 Actualiser</button>
        <button class="btn btn-danger" id="btn-restart-all" onclick="restartAll()">⚡ Redémarrer tout</button>
      </div>
    </div>

    <% if (error) { %>
    <div class="alert alert-error" style="margin-bottom:20px">⚠️ Erreur API Nitrado : <strong><%= error %></strong></div>
    <% } %>

    <!-- ── Refresh bar ── -->
    <div class="refresh-bar">
      <span id="last-refresh">Chargé il y a quelques secondes</span>
      <button onclick="refreshStatuses()">↺ Actualiser les statuts</button>
    </div>

    <!-- ── Grille serveurs ── -->
    <div class="servers-grid" id="servers-grid">
      <% servers.forEach(function(s) { %>
      <div class="server-card" id="card-<%= s.id %>" data-id="<%= s.id %>">
        <div class="server-card-header">
          <div class="server-name"><%= s.name %></div>
          <span class="status-badge <%= s.status %>" id="badge-<%= s.id %>">
            <%= s.status === 'started' ? '● En ligne' : s.status === 'stopped' ? '● Hors ligne' : s.status === 'restarting' ? '⟳ Redémarrage' : s.status %>
          </span>
        </div>
        <div class="server-meta">
          <div class="server-meta-row"><span>🗺️</span> Map : <strong><%= s.map %></strong></div>
          <div class="server-meta-row"><span>👥</span> Joueurs : <strong id="players-<%= s.id %>"><%= s.players %>/<%= s.maxPlayers %></strong></div>
          <div class="server-meta-row"><span>🔌</span> <strong><%= s.ip %>:<%= s.port %></strong></div>
        </div>
        <div class="server-actions">
          <button class="btn-sm btn-restart" onclick="restartOne('<%= s.id %>', '<%= s.name %>')">⚡ Restart</button>
          <% if (s.status === 'started') { %>
          <button class="btn-sm btn-stop" onclick="stopOne('<%= s.id %>')">⏹ Stop</button>
          <% } else { %>
          <button class="btn-sm btn-start" onclick="startOne('<%= s.id %>')">▶ Start</button>
          <% } %>
          <button class="btn-sm btn-mods" onclick="openModsModal('<%= s.id %>', '<%= s.name %>')">🔧 Mods</button>
        </div>
      </div>
      <% }); %>
      <% if (servers.length === 0 && !error) { %>
      <div style="color:var(--text-muted);font-size:.9rem;grid-column:1/-1">Aucun serveur de jeu trouvé sur ce compte Nitrado.</div>
      <% } %>
    </div>

    <!-- ── Section Mods globaux ── -->
    <div class="nitrado-section">
      <h2>🔧 Gestion des Mods — <em>Toutes les maps</em></h2>

      <div class="inline-form">
        <input type="text" id="mod-id-add" placeholder="ID du mod (ex: 928988)" style="font-family:monospace;">
        <button class="btn btn-success" onclick="addModToAll()">➕ Ajouter sur toutes les maps</button>
      </div>
      <div class="section-divider"></div>
      <div class="inline-form">
        <input type="text" id="mod-id-remove" placeholder="ID du mod à retirer" style="font-family:monospace;">
        <button class="btn btn-danger" onclick="removeModFromAll()">➖ Retirer de toutes les maps</button>
      </div>
      <div id="mods-bulk-results" class="bulk-results"></div>
    </div>

    <!-- ── Section Config rapide ── -->
    <div class="nitrado-section">
      <h2>⚙️ Paramètres rapides — <em>Toutes les maps</em></h2>
      <p style="font-size:.82rem;color:var(--text-muted);margin-bottom:18px">
        Modifie les multiplicateurs clés sur l'ensemble de tes serveurs en un clic.
        Laisse vide pour ne pas modifier.
      </p>

      <div class="config-presets">

        <div class="config-preset-card">
          <label>🥚 Temps de repro (MatingIntervalMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.01" min="0.01" max="10" id="cfg-mating" placeholder="ex : 0.25">
            <button class="btn-sm btn-restart" onclick="applyConfig('config', 'MatingIntervalMultiplier', 'cfg-mating')">Appliquer</button>
          </div>
        </div>

        <div class="config-preset-card">
          <label>🦖 Apprivoisement (TamingSpeedMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.1" min="0.1" max="100" id="cfg-taming" placeholder="ex : 5.0">
            <button class="btn-sm btn-restart" onclick="applyConfig('config', 'TamingSpeedMultiplier', 'cfg-taming')">Appliquer</button>
          </div>
        </div>

        <div class="config-preset-card">
          <label>🌾 Récolte (HarvestAmountMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.1" min="0.1" max="100" id="cfg-harvest" placeholder="ex : 3.0">
            <button class="btn-sm btn-restart" onclick="applyConfig('config', 'HarvestAmountMultiplier', 'cfg-harvest')">Appliquer</button>
          </div>
        </div>

        <div class="config-preset-card">
          <label>⭐ XP (XPMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.1" min="0.1" max="100" id="cfg-xp" placeholder="ex : 2.0">
            <button class="btn-sm btn-restart" onclick="applyConfig('config', 'XPMultiplier', 'cfg-xp')">Appliquer</button>
          </div>
        </div>

        <div class="config-preset-card">
          <label>🐣 Maturation (BabyMatureSpeedMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.1" min="0.1" max="1000" id="cfg-mature" placeholder="ex : 30.0">
            <button class="btn-sm btn-restart" onclick="applyConfig('config', 'BabyMatureSpeedMultiplier', 'cfg-mature')">Appliquer</button>
          </div>
        </div>

        <div class="config-preset-card">
          <label>🥗 Consommation bébé (BabyFoodConsumptionSpeedMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.01" min="0.01" max="10" id="cfg-babyfood" placeholder="ex : 0.1">
            <button class="btn-sm btn-restart" onclick="applyConfig('config', 'BabyFoodConsumptionSpeedMultiplier', 'cfg-babyfood')">Appliquer</button>
          </div>
        </div>

        <div class="config-preset-card">
          <label>🥚 Incubation (EggHatchSpeedMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.1" min="0.1" max="1000" id="cfg-hatch" placeholder="ex : 20.0">
            <button class="btn-sm btn-restart" onclick="applyConfig('config', 'EggHatchSpeedMultiplier', 'cfg-hatch')">Appliquer</button>
          </div>
        </div>

        <div class="config-preset-card">
          <label>🏥 Récupération (PlayerDamageMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.1" min="0.1" max="10" id="cfg-dmg" placeholder="ex : 1.0">
            <button class="btn-sm btn-restart" onclick="applyConfig('config', 'PlayerDamageMultiplier', 'cfg-dmg')">Appliquer</button>
          </div>
        </div>

      </div>
      <div id="config-bulk-results" class="bulk-results"></div>
    </div>

    <!-- ── Modal mods par serveur ── -->
    <div class="modal-overlay" id="mods-modal">
      <div class="modal-box">
        <button class="modal-close" onclick="closeModal()">✕</button>
        <h3 id="modal-title">Mods — Serveur</h3>
        <div class="mod-list" id="modal-mod-list">
          <div class="empty-mods">Chargement…</div>
        </div>
        <div class="inline-form" style="margin-top:8px">
          <input type="text" id="modal-mod-add" placeholder="ID du mod à ajouter" style="font-family:monospace;flex:1">
          <button class="btn btn-success" onclick="addModToServer()">➕ Ajouter</button>
        </div>
      </div>
    </div>

    <% } %>
  </div>
</main>

<!-- ── Toast ── -->
<div id="nit-toast"></div>

<script>
const serverList = <%- JSON.stringify(servers) %>;
let currentModalServerId = null;

// ── Toast ──────────────────────────────────────────────────────────────────
let toastTimer = null;
function showToast(msg, isError = false) {
  const el = document.getElementById('nit-toast');
  el.textContent = msg;
  el.className = 'show' + (isError ? ' error' : '');
  if (toastTimer) clearTimeout(toastTimer);
  toastTimer = setTimeout(() => { el.className = ''; }, 3500);
}

// ── Refresh statuts ────────────────────────────────────────────────────────
function refreshStatuses() {
  const btn = document.getElementById('btn-refresh-all');
  if (btn) { btn.disabled = true; btn.textContent = '🔄 Actualisation…'; }
  fetch('/nitrado/api/servers')
    .then(r => r.json())
    .then(data => {
      if (!data.ok) { showToast('Erreur : ' + data.error, true); return; }
      data.servers.forEach(s => {
        const badge = document.getElementById('badge-' + s.id);
        if (badge) {
          badge.className = 'status-badge ' + s.status;
          badge.textContent = s.status === 'started' ? '● En ligne'
            : s.status === 'stopped' ? '● Hors ligne'
            : s.status === 'restarting' ? '⟳ Redémarrage' : s.status;
        }
        const pl = document.getElementById('players-' + s.id);
        if (pl) pl.textContent = s.players + '/' + s.maxPlayers;
      });
      document.getElementById('last-refresh').textContent = 'Mis à jour à ' + new Date().toLocaleTimeString('fr-FR');
      showToast('Statuts actualisés ✓');
    })
    .catch(e => showToast('Erreur réseau', true))
    .finally(() => {
      if (btn) { btn.disabled = false; btn.textContent = '🔄 Actualiser'; }
    });
}

// ── Restart un serveur ────────────────────────────────────────────────────
function restartOne(id, name) {
  if (!confirm(`Redémarrer "${name}" ?`)) return;
  setLoading(id, true);
  fetch('/nitrado/api/restart/' + id, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' })
    .then(r => r.json())
    .then(d => {
      if (d.ok) showToast('✅ ' + name + ' redémarre…');
      else showToast('Erreur : ' + d.error, true);
    })
    .catch(() => showToast('Erreur réseau', true))
    .finally(() => setLoading(id, false));
}

function stopOne(id) {
  if (!confirm('Stopper ce serveur ?')) return;
  fetch('/nitrado/api/stop/' + id, { method: 'POST' })
    .then(r => r.json())
    .then(d => d.ok ? showToast('⏹ Serveur arrêté') : showToast('Erreur : ' + d.error, true));
}

function startOne(id) {
  fetch('/nitrado/api/start/' + id, { method: 'POST' })
    .then(r => r.json())
    .then(d => d.ok ? showToast('▶ Serveur démarré') : showToast('Erreur : ' + d.error, true));
}

// ── Restart tous ──────────────────────────────────────────────────────────
function restartAll() {
  if (!confirm('Redémarrer TOUS les serveurs ?')) return;
  const btn = document.getElementById('btn-restart-all');
  btn.disabled = true;
  btn.innerHTML = '<span class="spin">⟳</span> En cours…';
  fetch('/nitrado/api/restart-all', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' })
    .then(r => r.json())
    .then(d => {
      if (d.ok) {
        const ok = d.results.filter(r => r.ok).length;
        showToast(`✅ ${ok}/${d.results.length} serveurs redémarrés`);
      } else {
        showToast('Erreur : ' + d.error, true);
      }
    })
    .catch(() => showToast('Erreur réseau', true))
    .finally(() => { btn.disabled = false; btn.textContent = '⚡ Redémarrer tout'; });
}

// ── Mods bulk ─────────────────────────────────────────────────────────────
function addModToAll() {
  const modId = document.getElementById('mod-id-add').value.trim();
  if (!modId) { showToast('Entre un ID de mod', true); return; }
  if (!confirm(`Ajouter le mod ${modId} sur TOUTES les maps ?`)) return;
  apiBulkMod('/nitrado/api/mods/add-all', { modId }, 'mods-bulk-results', `Mod ${modId} ajouté`);
}

function removeModFromAll() {
  const modId = document.getElementById('mod-id-remove').value.trim();
  if (!modId) { showToast('Entre un ID de mod', true); return; }
  if (!confirm(`Retirer le mod ${modId} de TOUTES les maps ?`)) return;
  apiBulkMod('/nitrado/api/mods/remove-all', { modId }, 'mods-bulk-results', `Mod ${modId} retiré`);
}

function apiBulkMod(url, body, resultId, successMsg) {
  fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
  })
    .then(r => r.json())
    .then(d => {
      if (d.ok) {
        showToast('✅ ' + successMsg + ' sur ' + d.results.filter(r => r.ok).length + '/' + d.results.length + ' maps');
        renderBulkResults(resultId, d.results);
      } else {
        showToast('Erreur : ' + d.error, true);
      }
    })
    .catch(() => showToast('Erreur réseau', true));
}

function renderBulkResults(containerId, results) {
  const nameMap = {};
  serverList.forEach(s => { nameMap[s.id] = s.name; });
  const html = results.map(r =>
    `<div class="bulk-result-row ${r.ok ? 'ok' : 'fail'}">
      ${r.ok ? '✅' : '❌'} ${nameMap[r.id] || r.id}
      ${r.error ? `<span style="color:var(--text-muted)">${r.error}</span>` : ''}
    </div>`
  ).join('');
  document.getElementById(containerId).innerHTML = html;
}

// ── Config rapide ─────────────────────────────────────────────────────────
function applyConfig(category, key, inputId) {
  const value = document.getElementById(inputId).value.trim();
  if (!value) { showToast('Entre une valeur', true); return; }
  if (!confirm(`Appliquer ${key} = ${value} sur toutes les maps ?`)) return;

  fetch('/nitrado/api/settings/update-all', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ category, key, value }),
  })
    .then(r => r.json())
    .then(d => {
      if (d.ok) {
        showToast(`✅ ${key} = ${value} appliqué sur ${d.results.filter(r => r.ok).length}/${d.results.length} maps`);
        renderBulkResults('config-bulk-results', d.results);
      } else {
        showToast('Erreur : ' + d.error, true);
      }
    })
    .catch(() => showToast('Erreur réseau', true));
}

// ── Modal mods par serveur ────────────────────────────────────────────────
function openModsModal(id, name) {
  currentModalServerId = id;
  document.getElementById('modal-title').textContent = '🔧 Mods — ' + name;
  document.getElementById('modal-mod-list').innerHTML = '<div class="empty-mods"><span class="spin">⟳</span> Chargement…</div>';
  document.getElementById('mods-modal').classList.add('open');
  document.getElementById('modal-mod-add').value = '';
  fetchServerMods(id);
}

function closeModal() {
  document.getElementById('mods-modal').classList.remove('open');
  currentModalServerId = null;
}

function fetchServerMods(id) {
  fetch('/nitrado/api/mods/' + id)
    .then(r => r.json())
    .then(d => {
      if (!d.ok) {
        document.getElementById('modal-mod-list').innerHTML = '<div class="empty-mods">Erreur : ' + d.error + '</div>';
        return;
      }
      renderModList(d.mods, id);
    })
    .catch(() => {
      document.getElementById('modal-mod-list').innerHTML = '<div class="empty-mods">Erreur réseau</div>';
    });
}

function renderModList(mods, serverId) {
  if (!mods || mods.length === 0) {
    document.getElementById('modal-mod-list').innerHTML = '<div class="empty-mods">Aucun mod installé</div>';
    return;
  }
  document.getElementById('modal-mod-list').innerHTML = mods.map(m =>
    `<div class="mod-item">
      <span class="mod-id">${m}</span>
      <button class="btn-remove-mod" onclick="removeModFromServer('${serverId}', '${m}')">Retirer</button>
    </div>`
  ).join('');
}

function addModToServer() {
  const modId = document.getElementById('modal-mod-add').value.trim();
  if (!modId || !currentModalServerId) return;
  fetch('/nitrado/api/mods/add/' + currentModalServerId, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ modId }),
  })
    .then(r => r.json())
    .then(d => {
      if (d.ok) {
        showToast('✅ Mod ' + modId + ' ajouté');
        document.getElementById('modal-mod-add').value = '';
        fetchServerMods(currentModalServerId);
      } else {
        showToast('Erreur : ' + d.error, true);
      }
    });
}

function removeModFromServer(serverId, modId) {
  fetch('/nitrado/api/mods/remove/' + serverId, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ modId }),
  })
    .then(r => r.json())
    .then(d => {
      if (d.ok) {
        showToast('✅ Mod ' + modId + ' retiré');
        fetchServerMods(serverId);
      } else {
        showToast('Erreur : ' + d.error, true);
      }
    });
}

// ── Loading state carte ────────────────────────────────────────────────────
function setLoading(id, loading) {
  const card = document.getElementById('card-' + id);
  if (!card) return;
  card.querySelectorAll('button').forEach(b => b.disabled = loading);
}

// Fermer modal en cliquant à l'extérieur
document.getElementById('mods-modal')?.addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});
</script>
</body>
</html>
