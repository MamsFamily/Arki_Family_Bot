      '<td style="font-size:.76rem;color:var(--text-secondary)">' + maps + '</td>' +
      '<td class="sched-last">' + last + '</td>' +
      '<td style="text-align:center"><label class="toggle-switch"><input type="checkbox" ' + (s.active ? 'checked' : '') + ' onchange="toggleRestartSched(\'' + s.id + '\')"><span class="toggle-slider"></span></label></td>' +
      '<td style="white-space:nowrap">' +
        '<button class="sbt-sched-act sbt-run" onclick="runRestartNow(\'' + s.id + '\')" title="Lancer maintenant">▶ Now</button> ' +
        '<button class="sbt-sched-act sbt-del" onclick="deleteRestartSched(\'' + s.id + '\')" title="Supprimer">✕</button>' +
      '</td></tr>';
  });
  html += '</tbody></table>';
  container.innerHTML = html;
}

function openRestartModal() {
  document.getElementById('rs-nom').value = '';
  document.getElementById('rs-heure').value = '04';
  document.getElementById('rs-minute').value = '00';
  document.getElementById('rs-warn').checked = true;
  document.getElementById('rs-modal-err').style.display = 'none';
  document.querySelectorAll('.rs-srv-input').forEach(cb => cb.checked = false);
  document.getElementById('restart-modal').classList.add('open');
}
function closeRestartModal() { document.getElementById('restart-modal').classList.remove('open'); }
document.getElementById('restart-modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeRestartModal(); });

function saveRestartSchedule() {
  const errEl = document.getElementById('rs-modal-err');
  errEl.style.display = 'none';
  const nom   = document.getElementById('rs-nom').value.trim();
  const heure = document.getElementById('rs-heure').value + ':' + document.getElementById('rs-minute').value;
  const avertissements = document.getElementById('rs-warn').checked;
  const serverIds = [...document.querySelectorAll('.rs-srv-input:checked')].map(cb => cb.value);

  if (!nom) { errEl.textContent = '❌ Le nom est obligatoire.'; errEl.style.display = ''; return; }

  post('/nitrado/api/restart-schedules', { nom, heure, avertissements, serverIds })
    .then(d => {
      if (d.ok) { toast('✅ Redémarrage programmé créé — le bot le prendra en charge au prochain démarrage'); closeRestartModal(); loadRestartSchedules(); }
      else { errEl.textContent = '❌ ' + d.error; errEl.style.display = ''; }
    })
    .catch(() => { errEl.textContent = '❌ Erreur réseau'; errEl.style.display = ''; });
}

function toggleRestartSched(id) {
  fetch('/nitrado/api/restart-schedules/' + id + '/toggle', { method: 'PATCH' })
    .then(r => r.json())
    .then(d => {
      if (d.ok) toast(d.active ? '✅ Planning activé' : '⏸ Planning désactivé');
      else toast('Erreur : ' + d.error, true);
      loadRestartSchedules();
    });
}

function deleteRestartSched(id) {
  if (!confirm('Supprimer ce planning de redémarrage ?')) return;
  fetch('/nitrado/api/restart-schedules/' + id, { method: 'DELETE' })
    .then(r => r.json())
    .then(d => { if (d.ok) { toast('✅ Supprimé'); loadRestartSchedules(); } else toast('Erreur : ' + d.error, true); });
}

function runRestartNow(id) {
  if (!confirm('Lancer le redémarrage MAINTENANT (SaveWorld puis restart) sur toutes les maps cibles ?')) return;
  toast('⏳ Redémarrage en cours…');
  post('/nitrado/api/restart-schedules/' + id + '/run-now', {})
    .then(d => {
      if (d.ok) {
        const ok = d.results.filter(r => r.ok).length;
        toast('✅ Redémarrage sur ' + ok + '/' + d.results.length + ' serveur(s)');
        loadRestartSchedules();
      } else toast('❌ ' + d.error, true);
    })
    .catch(() => toast('❌ Erreur réseau', true));
}

// Charger les redémarrages au démarrage
loadRestartSchedules();

function toggleSched(id) {
  fetch('/nitrado/api/scheduled/' + id + '/toggle', { method: 'PATCH' })
    .then(r => r.json())
    .then(d => {
      if (d.ok) toast(d.active ? '✅ Activée' : '⏸ Désactivée');
      else toast('Erreur : ' + d.error, true);
    });
}

function deleteSched(id) {
  if (!confirm('Supprimer cette commande programmée ?')) return;
  fetch('/nitrado/api/scheduled/' + id, { method: 'DELETE' })
    .then(r => r.json())
    .then(d => { if (d.ok) { toast('✅ Supprimée'); loadScheduled(); } else toast('Erreur : ' + d.error, true); });
}

function runSchedNow(id) {
  post('/nitrado/api/scheduled/' + id + '/run-now', {})
    .then(d => {
      if (d.ok) {
        const ok = d.results.filter(r => r.ok).length;
        toast('✅ Exécutée sur ' + ok + '/' + d.results.length + ' serveurs');
        loadScheduled();
      } else toast('Erreur : ' + d.error, true);
    });
}

document.getElementById('sched-modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeSchedModal(); });

// Charger les commandes programmées au démarrage
loadScheduled();

// ── RCON direct config ────────────────────────────────────────────────────
let _rconDirectCfg = {};

function loadRconDirectCfg() {
  fetch('/nitrado/api/rcon-direct-cfg').then(r => r.json()).then(d => {
    if (d.ok) { _rconDirectCfg = d.cfg || {}; renderRconDirectList(); }
  });
}

function renderRconDirectList() {
  const el = document.getElementById('rcon-direct-list');
  if (!el) return;
  el.innerHTML = '';
  SRV.forEach(s => {
    const sname = shortName(s.name);
    const cfg = _rconDirectCfg[s.id] || {};
    // IP : priorité config sauvegardée > IP Nitrado auto
    const ip       = cfg.ip       || s.ip  || '';
    const rconPort = cfg.rconPort || '';
    const isConfigured = !!(cfg.ip);
    const row = document.createElement('div');
    row.style.cssText = 'background:var(--bg-primary);border:1px solid var(--border);border-radius:10px;padding:12px 14px;';
    row.innerHTML =
      '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">' +
        '<strong style="font-size:.88rem">' + escHtml(sname) + '</strong>' +
        '<span style="font-size:.72rem;padding:2px 8px;border-radius:20px;background:' +
          (isConfigured ? 'rgba(76,175,80,.15);color:#81c784;border:1px solid rgba(76,175,80,.3)' : 'rgba(255,255,255,.05);color:var(--text-muted);border:1px solid var(--border)') +
        '">' + (isConfigured ? '✅ Configuré' : '⚙️ Non configuré') + '</span>' +
      '</div>' +
      '<div style="display:grid;grid-template-columns:1fr 120px 1fr auto;gap:8px;align-items:end">' +
        '<div><label style="font-size:.72rem;color:var(--text-muted);display:block;margin-bottom:3px">IP publique <span style="color:#81c784;opacity:.7">(Nitrado)</span></label>' +
          '<input class="rcon-field" style="font-size:.82rem;opacity:.7" id="rd-ip-' + s.id + '" placeholder="auto" value="' + escHtml(ip) + '" readonly></div>' +
        '<div><label style="font-size:.72rem;color:var(--text-muted);display:block;margin-bottom:3px">Port RCON ' +
          '<button onclick="autodetectRcon(\'' + s.id + '\')" style="background:none;border:none;color:var(--accent);font-size:.7rem;cursor:pointer;padding:0;margin-left:4px">🔍 Détecter</button>' +
          '</label>' +
          '<input class="rcon-field" style="font-size:.82rem" id="rd-port-' + s.id + '" placeholder="11190" value="' + escHtml(String(rconPort)) + '"></div>' +
        '<div><label style="font-size:.72rem;color:var(--text-muted);display:block;margin-bottom:3px">ServerAdminPassword</label>' +
          '<input class="rcon-field" style="font-size:.82rem" type="password" id="rd-pass-' + s.id + '" placeholder="mot de passe admin" value="' + escHtml(cfg.rconPassword || '') + '"></div>' +
        '<div style="display:flex;gap:6px;margin-top:18px">' +
          '<button class="btn btn-primary" style="padding:7px 12px;font-size:.78rem" onclick="saveRconDirect(\'' + s.id + '\')" title="Sauvegarder">💾</button>' +
          '<button class="btn" style="padding:7px 10px;font-size:.78rem;background:var(--bg-input);color:var(--text-secondary)" onclick="testRconDirect(\'' + s.id + '\')" title="Tester la connexion">🔌</button>' +
          (isConfigured ? '<button class="btn btn-danger" style="padding:7px 10px;font-size:.78rem" onclick="clearRconDirect(\'' + s.id + '\')" title="Supprimer la config">✕</button>' : '') +
        '</div>' +
      '</div>' +
      '<div id="rd-status-' + s.id + '" style="margin-top:8px;font-size:.75rem;display:none"></div>';
    el.appendChild(row);
  });
}

async function autodetectRcon(serviceId) {
  showRdStatus(serviceId, '⟳ Lecture de la config Nitrado…', false);
  try {
    const r = await fetch('/nitrado/api/rcon-autodetect/' + serviceId);
    const d = await r.json();
    if (!d.ok) { showRdStatus(serviceId, '❌ ' + d.error, true); return; }
    const ipEl   = document.getElementById('rd-ip-'   + serviceId);
    const portEl = document.getElementById('rd-port-' + serviceId);
    if (d.ip   && ipEl)   ipEl.value   = d.ip;
    if (d.rconPort && portEl) portEl.value = d.rconPort;
    showRdStatus(serviceId,
      '✅ Détecté — IP : ' + (d.ip || '?') + ' · Port RCON : ' + (d.rconPort || 'non trouvé dans la config'), false);
  } catch (e) {
    showRdStatus(serviceId, '❌ Erreur réseau', true);
  }
}

async function saveRconDirect(serviceId) {
  const srv = SRV.find(s => s.id == serviceId) || {};
  // IP : champ (auto-rempli depuis Nitrado) ou fallback Nitrado
  const ip       = (document.getElementById('rd-ip-'   + serviceId)?.value || srv.ip || '').trim();
  const rconPort = document.getElementById('rd-port-' + serviceId)?.value.trim();
  const rconPassword = document.getElementById('rd-pass-' + serviceId)?.value;
  if (!ip) { showRdStatus(serviceId, '❌ IP introuvable — clique sur 🔍 Détecter d\'abord.', true); return; }
  if (!rconPort) { showRdStatus(serviceId, '❌ Port RCON manquant — clique sur 🔍 Détecter.', true); return; }
  const d = await post('/nitrado/api/rcon-direct-cfg', { serviceId, ip, rconPort: parseInt(rconPort), rconPassword });
  if (d.ok) {
    _rconDirectCfg[serviceId] = { ip, rconPort: parseInt(rconPort), rconPassword };
    renderRconDirectList();
    toast('✅ Config RCON sauvegardée pour ' + shortName(srv.name || serviceId));
  } else {
    showRdStatus(serviceId, '❌ ' + d.error, true);
  }
}

async function testRconDirect(serviceId) {
  const srv = SRV.find(s => s.id == serviceId) || {};
  const ip       = (document.getElementById('rd-ip-'   + serviceId)?.value || srv.ip || '').trim();
  const rconPort = document.getElementById('rd-port-' + serviceId)?.value.trim();
  const rconPassword = document.getElementById('rd-pass-' + serviceId)?.value;
  if (!ip || !rconPort) { showRdStatus(serviceId, '❌ Clique sur 🔍 Détecter d\'abord.', true); return; }
  showRdStatus(serviceId, '⟳ Test de connexion RCON en cours…', false);
  const d = await post('/nitrado/api/rcon-direct-test', { ip, rconPort: parseInt(rconPort), rconPassword });
  if (d.ok) showRdStatus(serviceId, '✅ Connexion réussie — ' + (d.response || '(pas de réponse, normal pour ARK SA)'), false);
  else      showRdStatus(serviceId, '❌ Échec : ' + d.error, true);
}

async function clearRconDirect(serviceId) {
  if (!confirm('Supprimer la config RCON directe pour ce serveur ?')) return;
  const d = await post('/nitrado/api/rcon-direct-cfg', { serviceId, ip: '' });
  if (d.ok) {
    delete _rconDirectCfg[serviceId];
    renderRconDirectList();
    toast('✅ Config RCON directe supprimée');
  }
}

function showRdStatus(serviceId, msg, isError) {
  const el = document.getElementById('rd-status-' + serviceId);
  if (!el) return;
  el.style.display = '';
  el.style.color = isError ? '#ef9a9a' : '#81c784';
  el.textContent = msg;
}

loadRconDirectCfg();
</script>
</body>
</html>
