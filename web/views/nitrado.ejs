<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nitrado — Arki Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* ── Server cards ── */
    .servers-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 14px;
      margin-bottom: 24px;
    }
    .server-card {
      background: var(--bg-input);
      border: 1.5px solid var(--border);
      border-radius: 14px;
      padding: 18px;
      cursor: pointer;
      transition: border-color .18s, box-shadow .18s;
      position: relative;
      user-select: none;
    }
    .server-card:hover { border-color: rgba(124,92,252,.45); box-shadow: 0 4px 18px rgba(0,0,0,.18); }
    .server-card.selected {
      border-color: var(--accent);
      background: rgba(124,92,252,.08);
      box-shadow: 0 0 0 3px rgba(124,92,252,.18);
    }
    .card-checkbox-wrap { position: absolute; top: 14px; right: 14px; }
    .card-checkbox { width: 18px; height: 18px; cursor: pointer; accent-color: var(--accent); }
    .server-top { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 12px; padding-right: 28px; }
    .server-name { font-weight: 700; font-size: 0.88rem; line-height: 1.3; flex: 1; color: var(--text-primary); }

    .status-pill {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 0.7rem; font-weight: 700; padding: 3px 10px;
      border-radius: 20px; white-space: nowrap; flex-shrink: 0;
    }
    .status-pill::before { content: '●'; font-size: 0.6rem; }
    .status-pill.started    { background: rgba(76,175,80,.15); color: #4caf50; }
    .status-pill.stopped    { background: rgba(244,67,54,.15); color: #f44336; }
    .status-pill.restarting { background: rgba(255,193,7,.15); color: #ffc107; }
    .status-pill.unknown    { background: var(--bg-card); color: var(--text-muted); }

    .server-info { display: flex; flex-direction: column; gap: 5px; margin-bottom: 14px; }
    .server-info-row { display: flex; align-items: center; gap: 7px; font-size: 0.8rem; color: var(--text-secondary); }
    .server-info-row .icon { font-size: 0.85rem; width: 18px; text-align: center; flex-shrink: 0; }
    .server-info-row strong { color: var(--text-primary); }

    .server-btns { display: flex; gap: 6px; flex-wrap: wrap; }
    .sbt {
      font-size: 0.74rem; padding: 5px 11px; border-radius: 8px; border: none;
      cursor: pointer; font-weight: 700; transition: opacity .15s, transform .1s;
      line-height: 1;
    }
    .sbt:active { transform: scale(.95); }
    .sbt:disabled { opacity: .35; cursor: not-allowed; }
    .sbt-restart { background: rgba(76,175,80,.18); color: #4caf50; }
    .sbt-stop    { background: rgba(244,67,54,.18); color: #f44336; }
    .sbt-start   { background: rgba(66,165,245,.18); color: #42a5f5; }
    .sbt-mods    { background: var(--bg-card); color: var(--text-secondary); border: 1px solid var(--border); }

    /* ── Selection bar ── */
    .sel-bar {
      display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
      background: var(--bg-input); border: 1px solid var(--border);
      border-radius: 12px; padding: 11px 16px; margin-bottom: 16px;
    }
    .sel-count {
      font-size: 0.8rem; font-weight: 800; padding: 3px 11px;
      border-radius: 20px; white-space: nowrap;
    }
    .sel-count.has  { background: var(--accent); color: #fff; }
    .sel-count.none { background: var(--bg-card); color: var(--text-muted); border: 1px solid var(--border); }
    .sel-text { font-size: 0.81rem; color: var(--text-secondary); flex: 1; min-width: 120px; }
    .sel-actions { display: flex; gap: 7px; flex-wrap: wrap; }
    .sbt-sel {
      font-size: 0.77rem; padding: 5px 12px; border-radius: 8px;
      border: 1px solid var(--border); background: var(--bg-card);
      color: var(--text-secondary); cursor: pointer; font-weight: 600;
      transition: all .15s;
    }
    .sbt-sel:hover { border-color: var(--accent); color: var(--accent); }

    /* ── Scope indicator ── */
    .scope-row {
      display: flex; align-items: center; gap: 8px;
      font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 16px;
    }
    .scope-pill {
      display: inline-block; font-size: 0.73rem; font-weight: 700;
      padding: 2px 11px; border-radius: 20px;
    }
    .scope-pill.sel { background: rgba(124,92,252,.2); color: var(--accent); }
    .scope-pill.all { background: var(--bg-card); color: var(--text-muted); border: 1px solid var(--border); }

    /* ── Mod row ── */
    .mod-add-row, .mod-remove-row {
      display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
    }
    .mod-add-row input, .mod-remove-row input {
      flex: 1; min-width: 160px; max-width: 320px;
      padding: 10px 14px; border-radius: 9px; border: 1px solid var(--border);
      background: var(--bg-primary); color: var(--text-primary);
      font-size: 0.88rem; font-family: monospace;
    }
    .mod-add-row input:focus, .mod-remove-row input:focus { outline: none; border-color: var(--accent); }
    .mod-sep { height: 1px; background: var(--border); margin: 14px 0; }

    /* ── Config grid ── */
    .cfg-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 12px;
    }
    .cfg-card {
      background: var(--bg-primary); border: 1px solid var(--border);
      border-radius: 10px; padding: 13px 14px;
    }
    .cfg-card label {
      display: block; font-size: 0.78rem; font-weight: 600;
      color: var(--text-secondary); margin-bottom: 8px;
    }
    .cfg-card .cfg-row { display: flex; gap: 7px; align-items: center; }
    .cfg-card input {
      flex: 1; padding: 8px 11px; border-radius: 8px;
      border: 1px solid var(--border); background: var(--bg-input);
      color: var(--text-primary); font-size: 0.84rem;
    }
    .cfg-card input:focus { outline: none; border-color: var(--accent); }
    .cfg-apply {
      background: rgba(76,175,80,.18); color: #4caf50; border: none;
      border-radius: 8px; padding: 8px 12px; font-weight: 700;
      font-size: 0.8rem; cursor: pointer; transition: background .15s;
    }
    .cfg-apply:hover { background: rgba(76,175,80,.3); }

    /* ── Bulk results ── */
    .bulk-results { display: flex; flex-direction: column; gap: 5px; margin-top: 14px; }
    .br-row {
      display: flex; align-items: center; gap: 8px; font-size: 0.8rem;
      padding: 6px 12px; border-radius: 8px; background: var(--bg-input);
    }
    .br-row.ok   { border-left: 3px solid #4caf50; }
    .br-row.fail { border-left: 3px solid #f44336; }
    .br-err { color: var(--text-muted); margin-left: auto; font-size: 0.75rem; }

    /* ── Modal mods ── */
    .modal-bg {
      display: none; position: fixed; inset: 0; background: rgba(0,0,0,.65);
      z-index: 2000; justify-content: center; align-items: center;
      padding: 16px; box-sizing: border-box;
    }
    .modal-bg.open { display: flex; }
    .modal-box {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 16px; padding: 24px; width: 100%; max-width: 440px;
      position: relative; max-height: min(85vh, 700px);
      display: flex; flex-direction: column;
      overflow-y: auto; -webkit-overflow-scrolling: touch;
    }
    .modal-box h3 { margin: 0 0 14px; font-size: 1rem; font-weight: 700; flex-shrink: 0; }
    @media (max-width: 500px) {
      .modal-bg { align-items: flex-end; padding: 0; }
      .modal-box {
        max-width: 100%; border-radius: 20px 20px 0 0;
        max-height: 92dvh; padding: 20px 18px 24px;
      }
    }
    .modal-close {
      position: absolute; top: 12px; right: 14px; background: none; border: none;
      color: var(--text-muted); font-size: 1.2rem; cursor: pointer; padding: 4px;
    }
    .modal-mod-list { flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 5px; margin-bottom: 14px; }
    .modal-mod-item {
      display: flex; align-items: center; justify-content: space-between;
      background: var(--bg-input); border-radius: 8px; padding: 8px 12px;
    }
    .mod-id { font-family: monospace; color: var(--accent); font-size: 0.85rem; }
    .sbt-rm-mod {
      background: rgba(244,67,54,.15); color: #f44336; border: none;
      border-radius: 6px; padding: 3px 9px; font-size: 0.73rem; font-weight: 700; cursor: pointer;
    }
    .modal-add-row { display: flex; gap: 8px; }
    .modal-add-row input {
      flex: 1; padding: 9px 12px; border-radius: 8px; border: 1px solid var(--border);
      background: var(--bg-input); color: var(--text-primary); font-family: monospace; font-size: 0.84rem;
    }
    .modal-add-row input:focus { outline: none; border-color: var(--accent); }
    .empty-mods { color: var(--text-muted); font-size: 0.84rem; text-align: center; padding: 20px 0; }

    /* ── No-token box ── */
    .no-token {
      background: var(--bg-input); border: 2px dashed var(--border);
      border-radius: 16px; padding: 48px 32px; text-align: center; max-width: 500px; margin: 40px auto;
    }
    .no-token .nt-icon { font-size: 52px; margin-bottom: 12px; }
    .no-token h2 { margin-bottom: 8px; }
    .no-token code {
      display: inline-block; background: var(--bg-primary); border: 1px solid var(--border);
      border-radius: 8px; padding: 6px 16px; font-size: 0.9rem; margin: 8px 0;
    }
    .no-token p { color: var(--text-secondary); font-size: 0.87rem; margin-top: 10px; }

    /* ── Toast ── */
    #nit-toast {
      position: fixed; bottom: 28px; right: 28px;
      background: var(--bg-card); border: 1px solid #4caf50; color: #4caf50;
      padding: 12px 20px; border-radius: 12px; font-size: 0.86rem; font-weight: 600;
      max-width: 360px; z-index: 9999; opacity: 0; transform: translateY(10px);
      transition: opacity .22s, transform .22s; pointer-events: none; box-shadow: 0 4px 20px rgba(0,0,0,.3);
    }
    #nit-toast.show { opacity: 1; transform: translateY(0); }
    #nit-toast.err  { border-color: #f44336; color: #f44336; }

    /* ── Refresh bar ── */
    .refresh-bar { font-size: 0.8rem; color: var(--text-muted); margin-bottom: 12px; display: flex; gap: 10px; align-items: center; }
    .refresh-bar button { background: none; border: none; color: var(--accent); cursor: pointer; font-weight: 600; font-size: 0.8rem; }

    /* ── Sélecteurs de fréquence ── */
    .sched-freq-tabs { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 2px; }
    .sched-freq-tab {
      font-size: .78rem; padding: 6px 13px; border-radius: 8px; cursor: pointer; font-weight: 600;
      border: 1.5px solid var(--border); background: var(--bg-input); color: var(--text-secondary);
      transition: all .15s;
    }
    .sched-freq-tab.active { border-color: var(--accent); background: rgba(124,92,252,.12); color: var(--accent); }
    .sched-freq-tab:hover:not(.active) { border-color: var(--accent); color: var(--accent); }
    .sched-freq-panel { padding: 10px 12px; background: var(--bg-primary); border-radius: 8px; border: 1px solid var(--border); }
    .sched-select {
      background: var(--bg-input); border: 1px solid var(--border); border-radius: 7px;
      color: var(--text-primary); padding: 6px 10px; font-size: .84rem; cursor: pointer; outline: none;
    }
    .sched-select:focus { border-color: var(--accent); }

    /* ── Notes et calculateur de stats ── */
    .cfg-note {
      font-size: .72rem; color: var(--text-muted); margin: 5px 0 9px;
      line-height: 1.5; display: flex; align-items: flex-start; gap: 5px;
    }
    .cfg-note::before { content: 'ℹ'; font-size: .7rem; opacity: .55; flex-shrink: 0; margin-top: 1px; }
    .cfg-preview {
      font-size: .72rem; border-radius: 7px; padding: 6px 10px; margin-top: 8px;
      line-height: 1.6; font-weight: 500;
      color: var(--text-muted); background: var(--bg-primary);
      border: 1px dashed rgba(255,255,255,.09); font-style: italic;
      transition: all .2s;
    }
    .cfg-preview.has-val {
      color: #a0d4ff; background: rgba(100,180,255,.07);
      border: 1px solid rgba(100,180,255,.2); font-style: normal;
    }
    .cfg-preview strong { color: #c8e6ff; }

    /* ── RCON console ── */
    .rcon-presets { display: flex; flex-wrap: wrap; gap: 6px; }
    .rcon-preset {
      font-size: 0.76rem; padding: 4px 11px; border-radius: 8px;
      border: 1px solid var(--border); background: var(--bg-input);
      color: var(--text-secondary); cursor: pointer; font-weight: 500;
      transition: all .13s; white-space: nowrap;
    }
    .rcon-preset:hover { border-color: var(--accent); color: var(--accent); background: rgba(124,92,252,.08); }
    .rcon-input-row {
      display: flex; align-items: center; gap: 8px;
      background: var(--bg-primary); border: 1.5px solid var(--border);
      border-radius: 10px; padding: 4px 4px 4px 14px; margin-bottom: 12px;
    }
    .rcon-input-row:focus-within { border-color: var(--accent); }
    .rcon-prompt { font-family: monospace; color: var(--accent); font-size: 1rem; font-weight: 700; flex-shrink: 0; }
    .rcon-field {
      flex: 1; background: transparent; border: none; outline: none;
      color: var(--text-primary); font-family: monospace; font-size: 0.88rem;
      padding: 7px 0;
    }
    .rcon-field::placeholder { color: var(--text-muted); }
    .rcon-log {
      background: var(--bg-primary); border: 1px solid var(--border);
      border-radius: 10px; min-height: 100px; max-height: 260px; overflow-y: auto;
      padding: 12px 14px; font-family: monospace; font-size: 0.8rem;
      display: flex; flex-direction: column; gap: 6px;
    }
    .rcon-log-empty { color: var(--text-muted); font-style: italic; text-align: center; padding: 20px 0; }
    .rcon-entry { display: flex; flex-direction: column; gap: 2px; }
    .rcon-entry .rcon-sent { color: var(--accent); }
    .rcon-entry .rcon-sent::before { content: '▶ '; opacity: .6; }
    .rcon-entry .rcon-resp { color: #a5d6a7; padding-left: 14px; }
    .rcon-entry .rcon-resp.err { color: #ef9a9a; }
    .rcon-entry .rcon-meta { font-size: 0.72rem; color: var(--text-muted); padding-left: 14px; }

    /* ── Scheduled commands ── */
    .sched-empty { color: var(--text-muted); font-size: .85rem; text-align: center; padding: 24px 0; }
    .sched-table { width: 100%; border-collapse: collapse; margin-top: 8px; }
    .sched-table th {
      font-size: .73rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em;
      color: var(--text-muted); padding: 8px 12px; text-align: left;
      border-bottom: 1px solid var(--border);
    }
    .sched-table td { padding: 10px 12px; font-size: .83rem; border-bottom: 1px solid rgba(58,61,92,.4); vertical-align: middle; }
    .sched-table tr:last-child td { border-bottom: none; }
    .sched-table tr:hover td { background: rgba(124,92,252,.04); }
    .sched-cmd-code { font-family: monospace; color: var(--accent); font-size: .8rem; }
    .sched-cron-code { font-family: monospace; color: var(--text-secondary); font-size: .78rem; }
    .sched-last { font-size: .75rem; color: var(--text-muted); }
    .toggle-switch { position: relative; display: inline-block; width: 36px; height: 20px; }
    .toggle-switch input { opacity: 0; width: 0; height: 0; }
    .toggle-slider {
      position: absolute; inset: 0; background: var(--border);
      border-radius: 20px; cursor: pointer; transition: .2s;
    }
    .toggle-slider::before {
      content: ''; position: absolute; width: 14px; height: 14px;
      left: 3px; bottom: 3px; background: white; border-radius: 50%; transition: .2s;
    }
    .toggle-switch input:checked + .toggle-slider { background: var(--accent); }
    .toggle-switch input:checked + .toggle-slider::before { transform: translateX(16px); }
    .sched-srv-cb {
      display: inline-flex; align-items: center; gap: 5px; font-size: .77rem;
      padding: 3px 9px; border-radius: 20px; border: 1px solid var(--border);
      cursor: pointer; background: var(--bg-input); color: var(--text-secondary);
      transition: all .13s;
    }
    .sched-srv-cb:has(input:checked) { border-color: var(--accent); background: rgba(124,92,252,.1); color: var(--accent); }
    .sbt-sched-act {
      background: none; border: none; cursor: pointer; font-size: .75rem;
      padding: 3px 8px; border-radius: 6px; font-weight: 600; transition: background .13s;
    }
    .sbt-run { color: #4caf50; }  .sbt-run:hover { background: rgba(76,175,80,.15); }
    .sbt-del { color: #f44336; }  .sbt-del:hover { background: rgba(244,67,54,.15); }

    /* ── Spinner ── */
    .spin { display: inline-block; animation: sp .7s linear infinite; }
    @keyframes sp { to { transform: rotate(360deg); } }

    /* ── Header actions ── */
    .nit-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-bottom: 24px; }
    .nit-header h1 { font-size: 1.5rem; font-weight: 700; display: flex; align-items: center; gap: 10px; margin: 0; color: var(--text-primary); }
    .nit-header h1 small { font-size: 0.7rem; font-weight: 400; color: var(--text-muted); }
    .nit-header-actions { display: flex; gap: 10px; flex-wrap: wrap; }

    @media (max-width: 580px) {
      .nit-header { flex-direction: column; align-items: flex-start; }
      .nit-header-actions { width: 100%; }
      .nit-header-actions .btn { flex: 1; justify-content: center; }
      .cfg-grid { grid-template-columns: 1fr; }
      .sel-actions { width: 100%; }
    }
  </style>
</head>
<body>
  <div class="layout">
    <%- include('sidebar') %>
    <main class="main-content">

    <% if (!hasToken) { %>
      <div class="no-token">
        <div class="nt-icon">🖥️</div>
        <h2>Token Nitrado manquant</h2>
        <p>Ajoute ton token dans les variables d'environnement sous le nom :</p>
        <code>NITRADO_TOKEN</code>
        <p>Génère un <strong>Long-life token</strong> (scope <em>service</em>) sur
          <a href="https://server.nitrado.net/developer" target="_blank" style="color:var(--accent)">server.nitrado.net → Développeurs</a>
        </p>
      </div>

    <% } else { %>

      <!-- En-tête -->
      <div class="nit-header">
        <h1>🖥️ Nitrado <small>ARK: Survival Ascended</small></h1>
        <div class="nit-header-actions">
          <button class="btn btn-secondary" onclick="refreshStatuses()">🔄 Actualiser</button>
          <button class="btn btn-danger" id="btn-restart-sel" onclick="restartSelected()">⚡ Redémarrer la sélection</button>
        </div>
      </div>

      <% if (error) { %>
      <div class="alert alert-error">⚠️ Erreur API Nitrado : <strong><%= error %></strong></div>
      <% } %>

      <!-- Refresh -->
      <div class="refresh-bar">
        <span id="last-refresh">Chargé à l'ouverture</span>
        <button onclick="refreshStatuses()">↺ Rafraîchir les statuts</button>
      </div>

      <!-- Barre de sélection -->
      <div class="sel-bar">
        <span class="sel-count none" id="sel-count">0</span>
        <span class="sel-text" id="sel-text">Aucune sélection — les actions s'appliquent à toutes les maps</span>
        <div class="sel-actions">
          <button class="sbt-sel" onclick="selectAll()">Tout</button>
          <button class="sbt-sel" onclick="selectNone()">Aucun</button>
          <button class="sbt-sel" onclick="invertSel()">Inverser</button>
        </div>
      </div>

      <!-- Grille des serveurs -->
      <div class="servers-grid" id="servers-grid">
        <% servers.forEach(function(s) { %>
        <div class="server-card" id="card-<%= s.id %>" data-id="<%= s.id %>" onclick="toggleCard(this)">
          <div class="card-checkbox-wrap">
            <input type="checkbox" class="card-checkbox srv-cb" data-id="<%= s.id %>"
              onclick="event.stopPropagation(); syncCard(this)">
          </div>
          <div class="server-top">
            <div class="server-name"><%= s.name %></div>
            <span class="status-pill <%= s.status %>" id="badge-<%= s.id %>">
              <%= s.status === 'started' ? 'En ligne' : s.status === 'stopped' ? 'Hors ligne' : s.status === 'restarting' ? 'Redémarre' : s.status %>
            </span>
          </div>
          <div class="server-info">
            <div class="server-info-row"><span class="icon">🗺️</span> <strong id="map-<%= s.id %>"><%= s.map %></strong></div>
            <div class="server-info-row"><span class="icon">👥</span> <strong id="pl-<%= s.id %>"><%= s.players %>/<%= s.maxPlayers %></strong> joueurs</div>
            <div class="server-info-row"><span class="icon">🔌</span> <strong><%= s.ip %>:<%= s.port %></strong></div>
          </div>
          <div class="server-btns" onclick="event.stopPropagation()">
            <button class="sbt sbt-restart" onclick="restartOne('<%= s.id %>', '<%= s.name %>')">⚡ Restart</button>
            <% if (s.status === 'started') { %>
            <button class="sbt sbt-stop" onclick="stopOne('<%= s.id %>')">⏹ Stop</button>
            <% } else { %>
            <button class="sbt sbt-start" onclick="startOne('<%= s.id %>')">▶ Start</button>
            <% } %>
            <button class="sbt sbt-mods" onclick="openMods('<%= s.id %>', '<%= s.name %>')">🔧 Mods</button>
          </div>
        </div>
        <% }); %>
        <% if (!servers.length && !error) { %>
        <p style="color:var(--text-muted);font-size:.9rem;grid-column:1/-1">Aucun serveur de jeu trouvé.</p>
        <% } %>
      </div>

      <!-- Section Mods -->
      <div class="card">
        <div class="card-header">
          <h2>🔧 Gestion des mods</h2>
          <div class="scope-row" style="margin:0">
            Cible : <span class="scope-pill all" id="mods-scope">toutes les maps</span>
          </div>
        </div>
        <div class="card-body">
          <div class="mod-add-row">
            <input type="text" id="mod-id-add" placeholder="ID du mod à ajouter  (ex: 928988)">
            <button class="btn btn-primary" onclick="addModSelected()">➕ Ajouter</button>
          </div>
          <div class="mod-sep"></div>
          <div class="mod-remove-row">
            <input type="text" id="mod-id-remove" placeholder="ID du mod à retirer">
            <button class="btn btn-danger" onclick="removeModSelected()">➖ Retirer</button>
          </div>
          <div id="mods-results" class="bulk-results"></div>
          <div style="margin-top:10px;text-align:right">
            <button class="btn" style="font-size:.75rem;opacity:.6;padding:4px 10px" onclick="debugSettings()">🔍 Debug clés settings</button>
          </div>
        </div>
      </div>

      <!-- Section Paramètres -->
      <div class="card">
        <div class="card-header">
          <h2>⚙️ Paramètres rapides</h2>
          <div class="scope-row" style="margin:0">
            Cible : <span class="scope-pill all" id="cfg-scope">toutes les maps</span>
          </div>
        </div>
        <div class="card-body">
          <p style="font-size:.82rem;color:var(--text-secondary);margin-bottom:18px">
            Entre la valeur souhaitée puis clique ✓ — ne s'applique qu'aux maps sélectionnées (ou toutes si aucune sélection).
          </p>
          <div class="cfg-grid">

            <!-- Temps de repro -->
            <div class="cfg-card">
              <label>🥚 Temps de repro<br><span style="font-weight:400;opacity:.7">MatingIntervalMultiplier</span></label>
              <p class="cfg-note">Durée entre deux reproductions. <strong>Plus bas = plus fréquent.</strong> Vanilla : 18 h min → 48 h max. Valeur 1 = vanilla, 0.1 = 10× plus fréquent.</p>
              <div class="cfg-row">
                <input type="number" step="0.01" min="0.01" id="cfg-mating" placeholder="ex : 0.25"
                  oninput="updateCfgPreview('mating', this.value)">
                <button class="cfg-apply" onclick="applyConfig('config','MatingIntervalMultiplier','cfg-mating')">✓</button>
              </div>
              <div class="cfg-preview" id="cfg-mating-preview">⏱️ Entre une valeur pour voir l'intervalle calculé</div>
            </div>

            <!-- Apprivoisement -->
            <div class="cfg-card">
              <label>🦖 Apprivoisement<br><span style="font-weight:400;opacity:.7">TamingSpeedMultiplier</span></label>
              <p class="cfg-note">Vitesse de montée de la barre de tame. <strong>×5 = 5× plus rapide.</strong> N'affecte pas l'efficacité. Vanilla = 1.</p>
              <div class="cfg-row">
                <input type="number" step="0.1" min="0.1" id="cfg-taming" placeholder="ex : 5.0"
                  oninput="updateCfgPreview('taming', this.value)">
                <button class="cfg-apply" onclick="applyConfig('config','TamingSpeedMultiplier','cfg-taming')">✓</button>
              </div>
              <div class="cfg-preview" id="cfg-taming-preview">⏱️ Entre une valeur pour voir la durée calculée</div>
            </div>

            <!-- Récolte -->
            <div class="cfg-card">
              <label>🌾 Récolte<br><span style="font-weight:400;opacity:.7">HarvestAmountMultiplier</span></label>
              <p class="cfg-note">Quantité de ressources par coup (bois, pierre, métal…). <strong>×3 = 3× plus de matériaux.</strong> Vanilla = 1.</p>
              <div class="cfg-row">
                <input type="number" step="0.1" min="0.1" id="cfg-harvest" placeholder="ex : 3.0"
                  oninput="updateCfgPreview('harvest', this.value)">
                <button class="cfg-apply" onclick="applyConfig('config','HarvestAmountMultiplier','cfg-harvest')">✓</button>
              </div>
              <div class="cfg-preview" id="cfg-harvest-preview">📦 Entre une valeur pour voir les quantités calculées</div>
            </div>

            <!-- Expérience -->
            <div class="cfg-card">
              <label>⭐ Expérience<br><span style="font-weight:400;opacity:.7">XPMultiplier</span></label>
              <p class="cfg-note">XP gagnée par toutes les actions. <strong>×2 = monte de niveau 2× plus vite.</strong> Vanilla = 1. S'applique aussi aux dinos.</p>
              <div class="cfg-row">
                <input type="number" step="0.1" min="0.1" id="cfg-xp" placeholder="ex : 2.0"
                  oninput="updateCfgPreview('xp', this.value)">
                <button class="cfg-apply" onclick="applyConfig('config','XPMultiplier','cfg-xp')">✓</button>
              </div>
              <div class="cfg-preview" id="cfg-xp-preview">⭐ Entre une valeur pour voir les XP calculés</div>
            </div>

            <!-- Maturation -->
            <div class="cfg-card">
              <label>🐣 Maturation<br><span style="font-weight:400;opacity:.7">BabyMatureSpeedMultiplier</span></label>
              <p class="cfg-note">Vitesse de croissance des bébés (bébé → adulte). <strong>×30 = grandit 30× plus vite.</strong> Vanilla : Rex ≈ 13,5 jours.</p>
              <div class="cfg-row">
                <input type="number" step="1" min="1" id="cfg-mature" placeholder="ex : 30"
                  oninput="updateCfgPreview('mature', this.value)">
                <button class="cfg-apply" onclick="applyConfig('config','BabyMatureSpeedMultiplier','cfg-mature')">✓</button>
              </div>
              <div class="cfg-preview" id="cfg-mature-preview">⏱️ Entre une valeur pour voir la durée calculée</div>
            </div>

            <!-- Nourriture bébé -->
            <div class="cfg-card">
              <label>🥗 Nourriture bébé<br><span style="font-weight:400;opacity:.7">BabyFoodConsumptionSpeedMultiplier</span></label>
              <p class="cfg-note">Vitesse de consommation de nourriture des bébés. <strong>Plus bas = moins on les nourrit souvent.</strong> Vanilla = 1. Valeur 0.1 = très autonome.</p>
              <div class="cfg-row">
                <input type="number" step="0.01" min="0.01" id="cfg-babyfood" placeholder="ex : 0.1"
                  oninput="updateCfgPreview('babyfood', this.value)">
                <button class="cfg-apply" onclick="applyConfig('config','BabyFoodConsumptionSpeedMultiplier','cfg-babyfood')">✓</button>
              </div>
              <div class="cfg-preview" id="cfg-babyfood-preview">⏱️ Entre une valeur pour voir l'intervalle de repas</div>
            </div>

            <!-- Incubation -->
            <div class="cfg-card">
              <label>🥚 Incubation<br><span style="font-weight:400;opacity:.7">EggHatchSpeedMultiplier</span></label>
              <p class="cfg-note">Vitesse d'éclosion des œufs. <strong>×20 = 20× plus rapide.</strong> Vanilla : Rex ≈ 5 h, Wyverne ≈ 6 h, Raptor ≈ 2 h.</p>
              <div class="cfg-row">
                <input type="number" step="1" min="1" id="cfg-hatch" placeholder="ex : 20"
                  oninput="updateCfgPreview('hatch', this.value)">
                <button class="cfg-apply" onclick="applyConfig('config','EggHatchSpeedMultiplier','cfg-hatch')">✓</button>
              </div>
              <div class="cfg-preview" id="cfg-hatch-preview">⏱️ Entre une valeur pour voir la durée calculée</div>
            </div>

            <!-- Dégâts joueurs -->
            <div class="cfg-card">
              <label>💀 Dégâts joueurs<br><span style="font-weight:400;opacity:.7">PlayerDamageMultiplier</span></label>
              <p class="cfg-note">Dégâts infligés par les joueurs (armes + corps à corps). <strong>×2 = double tous les dégâts.</strong> Vanilla = 1.</p>
              <div class="cfg-row">
                <input type="number" step="0.1" min="0.1" id="cfg-dmg" placeholder="ex : 1.0"
                  oninput="updateCfgPreview('dmg', this.value)">
                <button class="cfg-apply" onclick="applyConfig('config','PlayerDamageMultiplier','cfg-dmg')">✓</button>
              </div>
              <div class="cfg-preview" id="cfg-dmg-preview">💥 Entre une valeur pour voir les dégâts calculés</div>
            </div>

          </div>
          <div id="cfg-results" class="bulk-results"></div>
          <div style="margin-top:12px;padding:10px 14px;background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.25);border-radius:10px;font-size:.8rem;color:#4ade80">
            ✏️ <strong>Écriture directe dans le fichier .ini</strong> — Les valeurs sont écrites directement dans <code>Game.ini</code> ou <code>GameUserSettings.ini</code> via l'API fichiers Nitrado (méthode fiable). <strong>Redémarre la map</strong> après pour que les changements soient pris en compte par ARK.
          </div>

          <!-- Diagnostic INI direct -->
          <div style="margin-top:18px;padding:14px;background:var(--bg-secondary);border-radius:12px;border:1px solid var(--border)">
            <div style="font-weight:700;font-size:.85rem;margin-bottom:4px">🔬 Diagnostic fichier .ini</div>
            <div style="font-size:.78rem;color:var(--text-secondary);margin-bottom:12px">Lit le fichier .ini directement sur le serveur Nitrado pour vérifier si les changements sont bien écrits.</div>

            <!-- Sélecteur fichier + chemin custom -->
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px;align-items:flex-end">
              <div>
                <label style="font-size:.75rem;color:var(--text-muted);display:block;margin-bottom:4px">Fichier</label>
                <select id="ini-file-sel" style="padding:8px 10px;border-radius:8px;border:1px solid var(--border);background:var(--bg-input);color:var(--text-primary);font-size:.82rem">
                  <option value="gameIni">Game.ini</option>
                  <option value="gameUserSettings">GameUserSettings.ini</option>
                </select>
              </div>
              <div style="flex:1;min-width:200px">
                <label style="font-size:.75rem;color:var(--text-muted);display:block;margin-bottom:4px">Chemin personnalisé (optionnel)</label>
                <input type="text" id="ini-custom-path" placeholder="ex : /ShooterGame/Saved/Config/WindowsServer/Game.ini" style="width:100%;padding:8px 10px;border-radius:8px;border:1px solid var(--border);background:var(--bg-input);color:var(--text-primary);font-size:.82rem">
              </div>
              <button onclick="readIniFile()" style="padding:8px 16px;background:var(--accent);color:#fff;border:none;border-radius:8px;cursor:pointer;font-weight:700;font-size:.82rem;white-space:nowrap">📄 Lire</button>
              <button onclick="listIniDir()" style="padding:8px 14px;background:var(--bg-card);color:var(--text-primary);border:1px solid var(--border);border-radius:8px;cursor:pointer;font-size:.82rem;white-space:nowrap" title="Lister les fichiers accessibles (marche serveur OFF)">📁 Lister</button>
              <button onclick="discoverIniPath()" style="padding:8px 14px;background:#065f46;color:#6ee7b7;border:1px solid #047857;border-radius:8px;cursor:pointer;font-size:.82rem;white-space:nowrap;font-weight:700" title="Trouve automatiquement le bon chemin (serveur OFF)">🔍 Détecter</button>
            </div>

            <!-- Test écriture d'une clé -->
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px;align-items:flex-end">
              <div style="flex:1;min-width:160px">
                <label style="font-size:.75rem;color:var(--text-muted);display:block;margin-bottom:4px">Clé à tester (écriture)</label>
                <input type="text" id="diag-key" placeholder="ex : MatingIntervalMultiplier" style="width:100%;padding:8px 10px;border-radius:8px;border:1px solid var(--border);background:var(--bg-input);color:var(--text-primary);font-size:.82rem">
              </div>
              <div style="width:120px">
                <label style="font-size:.75rem;color:var(--text-muted);display:block;margin-bottom:4px">Valeur test</label>
                <input type="text" id="diag-value" placeholder="ex : 0.25" style="width:100%;padding:8px 10px;border-radius:8px;border:1px solid var(--border);background:var(--bg-input);color:var(--text-primary);font-size:.82rem">
              </div>
              <button onclick="runDiagnose()" style="padding:8px 16px;background:#7c3aed;color:#fff;border:none;border-radius:8px;cursor:pointer;font-weight:700;font-size:.82rem;white-space:nowrap">🔬 Tester écriture</button>
            </div>

            <div id="diag-result" style="margin-top:10px;font-size:.78rem;font-family:monospace;display:none;padding:10px;border-radius:8px;background:var(--bg-card);border:1px solid var(--border);white-space:pre-wrap;line-height:1.7;max-height:400px;overflow-y:auto"></div>
          </div>

        </div>
      </div>

      <!-- ══ Redémarrages automatiques ══ -->
      <div class="card">
        <div class="card-header" style="flex-wrap:wrap;gap:10px">
          <h2>🔄 Redémarrages automatiques</h2>
          <button class="btn btn-primary" onclick="openRestartModal()">+ Programmer</button>
        </div>
        <div class="card-body" style="padding-top:0">
          <p style="font-size:.8rem;color:var(--text-muted);margin-bottom:12px">
            🛈 Les redémarrages s'exécutent chaque jour à l'heure fixée. Des alertes in-game (30/15/5/1 min) sont envoyées automatiquement avant chaque redémarrage. Les jobs sont gérés par le bot Railway.
          </p>
          <div id="restart-sched-list">
            <div class="sched-empty">Chargement…</div>
          </div>
        </div>
      </div>

      <!-- ══ Config RCON direct ══ -->
      <div class="card" id="rcon-direct-card">
        <div class="card-header">
          <h2>🔌 Connexion RCON directe</h2>
          <span style="font-size:.75rem;color:var(--text-muted)">Bypasse l'API Nitrado · obligatoire si l'API retourne une erreur 500</span>
        </div>
        <div class="card-body">
          <p style="font-size:.78rem;color:var(--text-muted);margin-bottom:14px;line-height:1.6">
            Configure l'IP publique, le port RCON et le <code style="background:var(--bg-input);padding:1px 5px;border-radius:4px">ServerAdminPassword</code> pour chaque serveur. Une fois configuré, les commandes RCON iront directement au jeu sans passer par Nitrado.
          </p>
          <div id="rcon-direct-list" style="display:flex;flex-direction:column;gap:10px"></div>
        </div>
      </div>

      <!-- ══ Console RCON temps réel ══ -->
      <div class="card">
        <div class="card-header">
          <h2>💻 Console RCON</h2>
          <div class="scope-row" style="margin:0">
            Cible : <span class="scope-pill all" id="rcon-scope">toutes les maps</span>
          </div>
        </div>
        <div class="card-body">

          <!-- Note ARK SA -->
          <div style="background:rgba(255,193,7,.06);border:1px solid rgba(255,193,7,.2);border-radius:9px;padding:9px 13px;margin-bottom:14px;font-size:.76rem;color:#ffd54f;line-height:1.6">
            ⚠️ <strong>ARK SA RCON</strong> — les commandes ne renvoient souvent <strong>aucune réponse</strong> même si elles ont fonctionné (comportement normal du jeu).
            Le terme <code style="background:rgba(0,0,0,.3);padding:1px 5px;border-radius:4px">wipe</code> n'existe pas dans ARK SA — utilise <code style="background:rgba(0,0,0,.3);padding:1px 5px;border-radius:4px">DestroyWildDinos</code> (bouton ci-dessous).
          </div>

          <!-- Presets discrets -->
          <div style="margin-bottom:14px">
            <p style="font-size:.77rem;color:var(--text-muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:.04em;font-weight:600">Raccourcis</p>
            <div class="rcon-presets">
              <button class="rcon-preset" onclick="fillRcon('SaveWorld')">💾 Sauvegarder</button>
              <button class="rcon-preset" onclick="fillRcon('DestroyWildDinos')">🧹 Wipe sauvages</button>
              <button class="rcon-preset" onclick="fillRcon('ListPlayers')">👥 Joueurs connectés</button>
              <button class="rcon-preset" onclick="fillRcon('SetTimeOfDay 12:00:00')">🌞 Passer à midi</button>
              <button class="rcon-preset" onclick="fillRcon('SetTimeOfDay 06:00:00')">🌅 Passer au matin</button>
              <button class="rcon-preset" onclick="fillRcon('Broadcast ')">📢 Broadcast…</button>
              <button class="rcon-preset" onclick="fillRcon('ServerChat ')">💬 Chat global…</button>
              <button class="rcon-preset" onclick="fillRcon('GiveItemToPlayer ')">🎁 Donner item…</button>
              <button class="rcon-preset" onclick="fillRcon('KickPlayer ')">🚫 Kick…</button>
              <button class="rcon-preset" onclick="fillRcon('BanPlayer ')">⛔ Ban…</button>
            </div>
          </div>

          <!-- Champ commande -->
          <div class="rcon-input-row">
            <span class="rcon-prompt">$</span>
            <input type="text" id="rcon-cmd" class="rcon-field" placeholder="Entrez une commande RCON…" autocomplete="off" spellcheck="false"
              onkeydown="if(event.key==='Enter') sendRconNow()">
            <button class="btn btn-primary" onclick="sendRconNow()">Envoyer</button>
          </div>

          <!-- Log de réponses -->
          <div class="rcon-log" id="rcon-log">
            <div class="rcon-log-empty">Les réponses RCON s'afficheront ici</div>
          </div>
        </div>
      </div>

      <!-- ══ Commandes programmées ══ -->
      <div class="card">
        <div class="card-header" style="flex-wrap:wrap;gap:10px">
          <h2>⏱️ Commandes programmées</h2>
          <button class="btn btn-primary" onclick="openSchedModal()">+ Nouvelle</button>
        </div>
        <div class="card-body" style="padding-top:0">
          <div id="sched-list">
            <div class="sched-empty">Chargement…</div>
          </div>
        </div>
      </div>

    <% } %>
    </main>
  </div>

  <!-- Modal mods -->
  <div class="modal-bg" id="mods-modal">
    <div class="modal-box">
      <button class="modal-close" onclick="closeMods()">✕</button>
      <h3 id="modal-title">🔧 Mods</h3>
      <div class="modal-mod-list" id="modal-list">
        <div class="empty-mods">Chargement…</div>
      </div>
      <div class="modal-add-row">
        <input type="text" id="modal-mod-input" placeholder="ID du mod à ajouter">
        <button class="btn btn-primary" onclick="addModServer()">➕</button>
      </div>
    </div>
  </div>

  <!-- Modal debug settings -->
  <div class="modal-bg" id="debug-modal">
    <div class="modal-box" style="max-width:700px">
      <button class="modal-close" onclick="document.getElementById('debug-modal').classList.remove('open')">✕</button>
      <h3>🔍 Settings bruts — <span id="debug-modal-id"></span></h3>
      <input type="text" id="debug-search" placeholder="Rechercher une clé…" oninput="filterDebugKeys()" style="width:100%;margin-bottom:12px;padding:8px;border-radius:6px;border:1px solid var(--border);background:var(--bg-input);color:var(--text)">
      <div id="debug-modal-body" style="max-height:60vh;overflow-y:auto;font-size:.8rem;font-family:monospace;white-space:pre-wrap;background:var(--bg-secondary);padding:12px;border-radius:8px;line-height:1.6"></div>
    </div>
  </div>

  <!-- Modal redémarrage automatique -->
  <div class="modal-bg" id="restart-modal">
    <div class="modal-box" style="max-width:500px">
      <button class="modal-close" onclick="closeRestartModal()">✕</button>
      <h3>🔄 Programmer un redémarrage</h3>
      <p style="font-size:.78rem;color:var(--text-muted);margin-bottom:16px">
        Le bot enverra des alertes in-game 30, 15, 5 et 1 minute avant de redémarrer les serveurs.
      </p>

      <div class="form-group">
        <label>Nom du planning</label>
        <input type="text" id="rs-nom" class="rcon-field" placeholder="ex : Redémarrage nocturne">
      </div>

      <div class="form-group">
        <label>Heure du redémarrage <span style="font-weight:400;opacity:.6">(Europe/Paris)</span></label>
        <div style="display:flex;align-items:center;gap:10px">
          <select id="rs-heure" class="sched-select" style="width:80px">
            <% for(let h=0;h<24;h++){ %><option value="<%= String(h).padStart(2,'0') %>"><%= String(h).padStart(2,'0') %>h</option><% } %>
          </select>
          <select id="rs-minute" class="sched-select" style="width:80px">
            <option value="00">00 min</option>
            <option value="15">15 min</option>
            <option value="30">30 min</option>
            <option value="45">45 min</option>
          </select>
        </div>
        <p style="font-size:.73rem;color:var(--text-muted);margin-top:6px">
          💡 Conseil : choisissez une heure creuse (ex: 04h00, 05h00).
        </p>
      </div>

      <div class="form-group">
        <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
          <label class="toggle-switch">
            <input type="checkbox" id="rs-warn" checked>
            <span class="toggle-slider"></span>
          </label>
          <span>Alertes in-game (30 / 15 / 5 / 1 min avant)</span>
        </label>
      </div>

      <div class="form-group">
        <label>Maps cibles <span style="font-weight:400;opacity:.6">(aucune cochée = toutes)</span></label>
        <div id="rs-servers-list" style="display:flex;flex-wrap:wrap;gap:7px;margin-top:4px">
          <% servers.forEach(function(s) { %>
          <label class="sched-srv-cb">
            <input type="checkbox" class="rs-srv-input" value="<%= s.id %>">
            <span><%= s.name.replace(/\[FR\] ARKI'FAMILY ~/,'').replace(/~ - \(.*\)/,'').trim() %></span>
          </label>
          <% }); %>
        </div>
      </div>

      <div id="rs-modal-err" style="display:none;color:#ef9a9a;font-size:.8rem;margin-bottom:8px"></div>
      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:4px">
        <button class="btn btn-secondary" onclick="closeRestartModal()">Annuler</button>
        <button class="btn btn-primary" onclick="saveRestartSchedule()">✅ Créer</button>
      </div>
    </div>
  </div>

  <!-- Modal commande programmée -->
  <div class="modal-bg" id="sched-modal">
    <div class="modal-box" style="max-width:540px">
      <button class="modal-close" onclick="closeSchedModal()">✕</button>
      <h3>⏱️ Nouvelle commande programmée</h3>

      <div class="form-group" style="margin-top:4px">
        <label>Nom</label>
        <input type="text" id="sched-name" class="rcon-field" placeholder="ex : SaveWorld toutes les heures">
      </div>

      <div class="form-group">
        <label>Commande RCON</label>
        <input type="text" id="sched-cmd-input" class="rcon-field" placeholder="ex : SaveWorld" style="font-family:monospace">
        <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:6px">
          <button class="rcon-preset" onclick="document.getElementById('sched-cmd-input').value='SaveWorld'">💾 Save</button>
          <button class="rcon-preset" onclick="document.getElementById('sched-cmd-input').value='DestroyWildDinos'">🧹 Wipe sauvages</button>
          <button class="rcon-preset" onclick="document.getElementById('sched-cmd-input').value='Broadcast '">📢 Broadcast…</button>
          <button class="rcon-preset" onclick="document.getElementById('sched-cmd-input').value='ServerChat '">💬 Chat…</button>
          <button class="rcon-preset" onclick="document.getElementById('sched-cmd-input').value='SetTimeOfDay 12:00:00'">🌞 Midi</button>
        </div>
      </div>

      <!-- Planification simplifiée -->
      <div class="form-group">
        <label>Fréquence</label>
        <div class="sched-freq-tabs" id="sched-freq-tabs">
          <button class="sched-freq-tab active" onclick="setSchedFreq('interval',this)">🔁 Toutes les X heures/min</button>
          <button class="sched-freq-tab" onclick="setSchedFreq('daily',this)">📅 Chaque jour à une heure fixe</button>
        </div>

        <!-- Intervalle -->
        <div id="sched-freq-interval" class="sched-freq-panel" style="margin-top:10px">
          <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
            <span style="color:var(--text-secondary);font-size:.85rem">Toutes les</span>
            <select id="sched-interval-val" class="sched-select">
              <option value="*/15 * * * *">15 minutes</option>
              <option value="*/30 * * * *">30 minutes</option>
              <option value="0 * * * *" selected>1 heure</option>
              <option value="0 */2 * * *">2 heures</option>
              <option value="0 */3 * * *">3 heures</option>
              <option value="0 */4 * * *">4 heures</option>
              <option value="0 */6 * * *">6 heures</option>
              <option value="0 */8 * * *">8 heures</option>
              <option value="0 */12 * * *">12 heures</option>
            </select>
          </div>
          <p style="font-size:.73rem;color:var(--text-muted);margin-top:6px">
            ℹ️ La commande sera exécutée à intervalle régulier, 24h/24.
          </p>
        </div>

        <!-- Heure fixe -->
        <div id="sched-freq-daily" class="sched-freq-panel" style="display:none;margin-top:10px">
          <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
            <span style="color:var(--text-secondary);font-size:.85rem">Chaque jour à</span>
            <select id="sched-daily-h" class="sched-select" style="width:70px">
              <% for(let h=0;h<24;h++){ %><option value="<%= h %>"><%= String(h).padStart(2,'0') %>h</option><% } %>
            </select>
            <select id="sched-daily-m" class="sched-select" style="width:70px">
              <option value="0">00 min</option>
              <option value="15">15 min</option>
              <option value="30">30 min</option>
              <option value="45">45 min</option>
            </select>
            <span style="color:var(--text-muted);font-size:.75rem">(Europe/Paris)</span>
          </div>
          <p style="font-size:.73rem;color:var(--text-muted);margin-top:6px">
            ℹ️ La commande sera exécutée une fois par jour à l'heure choisie.
          </p>
        </div>
      </div>

      <div class="form-group">
        <label>Maps cibles <span style="font-weight:400;opacity:.6">(aucune cochée = toutes les maps)</span></label>
        <div id="sched-servers-list" style="display:flex;flex-wrap:wrap;gap:7px;margin-top:4px">
          <% servers.forEach(function(s) { %>
          <label class="sched-srv-cb">
            <input type="checkbox" class="sched-srv-input" value="<%= s.id %>">
            <span><%= s.name.replace(/\[FR\] ARKI'FAMILY ~/,'').replace(/~ - \(.*\)/,'').trim() %></span>
          </label>
          <% }); %>
        </div>
      </div>

      <div id="sched-modal-err" style="display:none;color:#ef9a9a;font-size:.8rem;margin-bottom:8px"></div>
      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:4px">
        <button class="btn btn-secondary" onclick="closeSchedModal()">Annuler</button>
        <button class="btn btn-primary" onclick="saveScheduled()">✅ Créer</button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="nit-toast"></div>

<script>
const SRV = <%- JSON.stringify(servers) %>;
let curModalId = null;

// ── Sélection ─────────────────────────────────────────────────────────────
function getSelIds() {
  return [...document.querySelectorAll('.srv-cb:checked')].map(c => c.dataset.id);
}

function updateSelUI() {
  const ids = getSelIds();
  const n = ids.length;
  const cnt = document.getElementById('sel-count');
  const txt = document.getElementById('sel-text');
  cnt.textContent = n;
  cnt.className = 'sel-count ' + (n ? 'has' : 'none');
  txt.textContent = n === 0 ? 'Aucune sélection — les actions s\'appliquent à toutes les maps'
    : n + ' map' + (n > 1 ? 's' : '') + ' sélectionnée' + (n > 1 ? 's' : '');
  const label = n === 0 ? 'toutes les maps' : n + ' map' + (n > 1 ? 's' : '');
  const cls = n === 0 ? 'scope-pill all' : 'scope-pill sel';
  ['mods-scope','cfg-scope','rcon-scope'].forEach(id => {
    const el = document.getElementById(id);
    if (el) { el.textContent = label; el.className = cls; }
  });
}

function toggleCard(card) {
  const cb = card.querySelector('.srv-cb');
  if (!cb) return;
  cb.checked = !cb.checked;
  card.classList.toggle('selected', cb.checked);
  updateSelUI();
}
function syncCard(cb) {
  const card = document.getElementById('card-' + cb.dataset.id);
  if (card) card.classList.toggle('selected', cb.checked);
  updateSelUI();
}
function selectAll()  { document.querySelectorAll('.srv-cb').forEach(cb => { cb.checked = true;  syncCard(cb); }); }
function selectNone() { document.querySelectorAll('.srv-cb').forEach(cb => { cb.checked = false; syncCard(cb); }); }
function invertSel()  { document.querySelectorAll('.srv-cb').forEach(cb => { cb.checked = !cb.checked; syncCard(cb); }); }

// ── Toast ─────────────────────────────────────────────────────────────────
let _tt;
function toast(msg, err) {
  const el = document.getElementById('nit-toast');
  el.textContent = msg; el.className = 'show' + (err ? ' err' : '');
  clearTimeout(_tt); _tt = setTimeout(() => el.className = '', 3500);
}

// ── Refresh ───────────────────────────────────────────────────────────────
function refreshStatuses() {
  fetch('/nitrado/api/servers').then(r => r.json()).then(d => {
    if (!d.ok) { toast('Erreur : ' + d.error, true); return; }
    d.servers.forEach(s => {
      const badge = document.getElementById('badge-' + s.id);
      if (badge) {
        badge.className = 'status-pill ' + s.status;
        badge.textContent = s.status === 'started' ? 'En ligne' : s.status === 'stopped' ? 'Hors ligne' : s.status === 'restarting' ? 'Redémarre' : s.status;
      }
      const pl = document.getElementById('pl-' + s.id); if (pl) pl.textContent = s.players + '/' + s.maxPlayers;
      const mp = document.getElementById('map-' + s.id); if (mp) mp.textContent = s.map;
    });
    document.getElementById('last-refresh').textContent = 'Mis à jour à ' + new Date().toLocaleTimeString('fr-FR');
    toast('✅ Statuts actualisés');
  }).catch(() => toast('Erreur réseau', true));
}

// ── Actions individuelles ──────────────────────────────────────────────────
function restartOne(id, name) {
  if (!confirm('Redémarrer "' + name + '" ?')) return;
  post('/nitrado/api/restart/' + id, {}).then(d => d.ok ? toast('✅ ' + name + ' redémarre…') : toast('Erreur : ' + d.error, true));
}
function stopOne(id) {
  if (!confirm('Stopper ce serveur ?')) return;
  post('/nitrado/api/stop/' + id, {}).then(d => d.ok ? toast('⏹ Serveur stoppé') : toast('Erreur : ' + d.error, true));
}
function startOne(id) {
  post('/nitrado/api/start/' + id, {}).then(d => d.ok ? toast('▶ Serveur démarré') : toast('Erreur : ' + d.error, true));
}

// ── Restart sélection ─────────────────────────────────────────────────────
function restartSelected() {
  const ids = getSelIds();
  const n = ids.length;
  if (!confirm('Redémarrer ' + (n === 0 ? 'TOUTES les maps' : n + ' map(s)') + ' ?')) return;
  const btn = document.getElementById('btn-restart-sel');
  btn.disabled = true; btn.innerHTML = '<span class="spin">⟳</span> En cours…';
  post('/nitrado/api/restart-all', { serviceIds: ids }).then(d => {
    if (d.ok) toast('✅ ' + d.results.filter(r => r.ok).length + '/' + d.results.length + ' maps redémarrées');
    else toast('Erreur : ' + d.error, true);
  }).finally(() => { btn.disabled = false; btn.textContent = '⚡ Redémarrer la sélection'; });
}

// ── Mods bulk ─────────────────────────────────────────────────────────────
function addModSelected() {
  const modId = document.getElementById('mod-id-add').value.trim();
  if (!modId) { toast('Entre un ID de mod', true); return; }
  const ids = getSelIds();
  if (!confirm('Ajouter le mod ' + modId + ' sur ' + (ids.length === 0 ? 'TOUTES les maps' : ids.length + ' map(s)') + ' ?')) return;
  bulkMod('/nitrado/api/mods/add-all', { modId, serviceIds: ids }, 'mods-results', 'Mod ' + modId + ' ajouté');
}
function removeModSelected() {
  const modId = document.getElementById('mod-id-remove').value.trim();
  if (!modId) { toast('Entre un ID de mod', true); return; }
  const ids = getSelIds();
  if (!confirm('Retirer le mod ' + modId + ' de ' + (ids.length === 0 ? 'TOUTES les maps' : ids.length + ' map(s)') + ' ?')) return;
  bulkMod('/nitrado/api/mods/remove-all', { modId, serviceIds: ids }, 'mods-results', 'Mod ' + modId + ' retiré');
}
function bulkMod(url, body, resultId, msg) {
  post(url, body).then(d => {
    if (d.ok) { toast('✅ ' + msg + ' sur ' + d.results.filter(r => r.ok).length + '/' + d.results.length + ' maps'); showResults(resultId, d.results); }
    else toast('Erreur : ' + d.error, true);
  }).catch(() => toast('Erreur réseau', true));
}
let _debugRaw = null;
function debugSettings() {
  const ids = getSelIds();
  const targetId = ids.length > 0 ? ids[0] : (SRV.length > 0 ? SRV[0].id : null);
  if (!targetId) { toast('Aucun serveur disponible', true); return; }
  document.getElementById('debug-modal-id').textContent = targetId;
  document.getElementById('debug-modal-body').textContent = 'Chargement…';
  document.getElementById('debug-search').value = '';
  document.getElementById('debug-modal').classList.add('open');
  fetch('/nitrado/api/settings-raw/' + targetId).then(r => r.json()).then(d => {
    if (!d.ok) { document.getElementById('debug-modal-body').textContent = 'Erreur : ' + d.error; return; }
    _debugRaw = d.raw;
    renderDebugKeys('');
  }).catch(() => { document.getElementById('debug-modal-body').textContent = 'Erreur réseau'; });
}
function renderDebugKeys(search) {
  if (!_debugRaw) return;
  const q = search.toLowerCase();
  let out = '';
  for (const [cat, catVal] of Object.entries(_debugRaw)) {
    if (typeof catVal !== 'object' || catVal === null) continue;
    const keys = Object.keys(catVal).filter(k => !q || k.toLowerCase().includes(q) || cat.toLowerCase().includes(q));
    if (!keys.length) continue;
    out += `\n[${cat}]\n`;
    for (const k of keys) {
      const v = catVal[k]?.value ?? catVal[k];
      out += `  ${k} = ${v}\n`;
    }
  }
  document.getElementById('debug-modal-body').textContent = out.trim() || 'Aucun résultat';
}
function filterDebugKeys() {
  renderDebugKeys(document.getElementById('debug-search').value);
}
document.getElementById('debug-modal').addEventListener('click', e => { if (e.target === e.currentTarget) e.currentTarget.classList.remove('open'); });

// ── Config ────────────────────────────────────────────────────────────────
function applyConfig(cat, key, inputId) {
  const raw = document.getElementById(inputId).value.trim();
  if (!raw) { toast('Entre une valeur', true); return; }
  // Normalise la virgule décimale en point (ex: "0,0002" → "0.0002")
  const value = raw.replace(',', '.');
  const ids = getSelIds();
  if (!confirm(key + ' = ' + value + '\nsur ' + (ids.length === 0 ? 'TOUTES les maps' : ids.length + ' map(s)') + ' ?\n\n⚠️ Le fichier .ini sera modifié directement — redémarre la map après.')) return;
  // Écriture directe dans le fichier .ini — méthode fiable vs l'API Settings
  post('/nitrado/api/ini/update-all', { key, value, serviceIds: ids }).then(d => {
    if (d.ok) {
      const ok = d.results.filter(r => r.ok).length;
      const fail = d.results.length - ok;
      const failedServers = d.results.filter(r => !r.ok);
      const isLocked = failedServers.some(r => r.error && r.error.includes('500'));

      if (fail > 0 && isLocked) {
        // Fichiers verrouillés (serveur en marche) → proposer le mode avec redémarrage
        if (confirm(`⚠️ Le fichier .ini est verrouillé (serveur en marche).\n\nVeux-tu appliquer "${key} = ${value}" via un redémarrage automatique ?\n\n→ Le(s) serveur(s) seront stoppés, le fichier modifié, puis redémarrés (~2 min de downtime).`)) {
          applyConfigWithRestart([{ key, value }], ids);
        }
      } else {
        const cats = d.file ? ` [→ ${d.file.split('/').pop()}]` : '';
        const errMsg = fail > 0 ? ' — ' + fail + ' erreur(s)' : '';
        toast('✅ ' + key + ' = ' + value + ' — ' + ok + '/' + d.results.length + ' maps' + cats + errMsg, fail > 0);
        showResults('cfg-results', d.results);
      }
    } else {
      toast('❌ ' + key + ' : ' + d.error, true);
      console.error('[Nitrado applyConfig]', key, d.error);
    }
  }).catch(e => { toast('Erreur réseau', true); console.error('[Nitrado applyConfig] réseau:', e); });
}

// Déclenche le redémarrage en utilisant les params stockés dans _restartPending
function triggerPendingRestart() {
  if (!window._restartPending) { toast('Aucun paramètre en attente', true); return; }
  const { settings, serviceIds } = window._restartPending;
  applyConfigWithRestart(settings, serviceIds);
}

// Applique des paramètres .ini en faisant stop → édition fichier → start
async function applyConfigWithRestart(settings, serviceIds) {
  const box = document.getElementById('diag-result');
  box.style.display = 'block';
  box.style.color = 'var(--text-primary)';
  box.style.whiteSpace = 'pre-wrap';
  const ids = serviceIds && serviceIds.length ? serviceIds : getSelIds();
  const maps = ids.length === 0 ? 'toutes les maps' : ids.length + ' map(s)';
  box.textContent = `⏳ Arrêt des serveurs en cours (${maps})…\nCela peut prendre 2-3 minutes, ne ferme pas la page.`;

  try {
    const res = await fetch('/nitrado/api/ini/apply-with-restart', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ settings, serviceIds: ids }),
    });
    const d = await res.json();
    const logText = (d.log || []).join('\n');
    if (d.ok) {
      box.style.color = '#4ade80';
      box.textContent = `✅ TERMINÉ — Paramètres appliqués + serveurs redémarrés\n\n${logText}`;
      toast('✅ Paramètres appliqués avec redémarrage', false);
    } else {
      box.style.color = '#f87171';
      box.textContent = `❌ ERREUR\n${d.error}\n\nLog :\n${logText}`;
      toast('❌ Erreur lors de l\'application', true);
    }
  } catch (e) {
    box.style.color = '#f87171';
    box.textContent = '❌ Erreur réseau : ' + e.message;
  }
}

// ── Diagnostic INI ────────────────────────────────────────────────────────

// Découvre automatiquement le bon répertoire config ARK SA (serveur OFF recommandé)
async function discoverIniPath() {
  const ids = getSelIds();
  const serviceId = ids.length > 0 ? ids[0] : (SRV.length > 0 ? SRV[0].id : null);
  if (!serviceId) { toast('Aucun serveur sélectionné', true); return; }
  const box = document.getElementById('diag-result');
  box.style.display = 'block'; box.style.color = 'var(--text-primary)'; box.style.whiteSpace = 'pre-wrap';
  box.textContent = `⏳ Découverte du répertoire config (serveur ${serviceId})…\nTest de plusieurs chemins possibles…`;
  try {
    const r = await fetch(`/nitrado/api/ini/discover?${new URLSearchParams({ serviceId })}`);
    const d = await r.json();
    if (d.ok) {
      // Prérempli le champ de chemin personnalisé avec le répertoire trouvé
      document.getElementById('ini-custom-path').value = d.dir + '/Game.ini';
      const fileList = (d.entries || []).map(e => `  ${e.type === 'dir' ? '📁' : '📄'} ${e.name}`).join('\n') || '  (vide)';
      box.style.color = '#4ade80';
      box.textContent = `✅ RÉPERTOIRE TROUVÉ !\n\nChemin : ${d.dir}\n\nFichiers dans ce répertoire :\n${fileList}\n\n→ Le champ "Chemin personnalisé" a été mis à jour automatiquement.\n→ Tu peux maintenant cliquer "📄 Lire" pour voir le contenu du Game.ini.`;
    } else {
      const roots = (d.rootEntries || []).map(e => `  ${e.type === 'dir' ? '📁' : '📄'} ${e.name}`).join('\n') || '  (vide ou inaccessible)';
      box.style.color = '#fbbf24';
      box.textContent = `⚠️ Aucun répertoire config trouvé automatiquement.\n\nChemins testés :\n${(d.candidates || []).map(c => '  - ' + c).join('\n')}\n\nRacine "/" du serveur :\n${roots}\n\n💡 Peut-être que le serveur est en marche (éteins-le d'abord), ou le chemin est différent.\n→ Utilise "📁 Lister" avec "/" pour explorer la racine.`;
    }
  } catch (e) { box.style.color = '#f87171'; box.textContent = '❌ Erreur réseau : ' + e.message; }
}

// Liste les fichiers d'un répertoire Nitrado (marche quand serveur OFF)
async function listIniDir() {
  const ids = getSelIds();
  const serviceId = ids.length > 0 ? ids[0] : (SRV.length > 0 ? SRV[0].id : null);
  if (!serviceId) { toast('Aucun serveur sélectionné', true); return; }
  const customPath = document.getElementById('ini-custom-path').value.trim() || '/';
  const box = document.getElementById('diag-result');
  box.style.display = 'block';
  box.style.color = 'var(--text-primary)';
  box.textContent = `⏳ Liste des fichiers dans "${customPath}" (serveur ${serviceId})…`;
  try {
    const r = await fetch(`/nitrado/api/ini/list?${new URLSearchParams({ serviceId, dir: customPath })}`);
    const d = await r.json();
    if (!d.ok) {
      box.style.color = '#f87171';
      box.textContent = `❌ ERREUR (${customPath})\n${d.error}\n\n💡 Essaie d'éteindre le serveur puis relance cette commande.\n   Si ça marche OFF, l'API fichiers est verrouillée pendant le jeu.`;
    } else {
      const list = (d.entries || []).map(e => `  ${e.type === 'dir' ? '📁' : '📄'} ${e.name}`).join('\n') || '  (vide)';
      box.style.color = 'var(--text-primary)';
      box.textContent = `✅ Contenu de "${d.dir}" (serveur ${serviceId})\n${'─'.repeat(40)}\n${list}`;
    }
  } catch (e) { box.style.color = '#f87171'; box.textContent = '❌ Erreur réseau : ' + e.message; }
}

// Lit un fichier .ini sur le premier serveur sélectionné et affiche son contenu
async function readIniFile() {
  const ids = getSelIds();
  const serviceId = ids.length > 0 ? ids[0] : (SRV.length > 0 ? SRV[0].id : null);
  if (!serviceId) { toast('Aucun serveur sélectionné', true); return; }

  const fileKey = document.getElementById('ini-file-sel').value;
  const customPath = document.getElementById('ini-custom-path').value.trim();
  const box = document.getElementById('diag-result');
  box.style.display = 'block';
  box.style.color = 'var(--text-primary)';
  box.textContent = `⏳ Lecture du fichier en cours (serveur ${serviceId})…`;

  const params = new URLSearchParams({ serviceId, file: customPath || fileKey });
  try {
    const res = await fetch('/nitrado/api/ini/read?' + params);
    const d = await res.json();
    if (!d.ok) {
      box.style.color = '#f87171';
      box.textContent = `❌ ERREUR LECTURE\n\nServeur  : ${serviceId}\nFichier  : ${d.filePath || fileKey}\nErreur   : ${d.error}\n\n💡 Le fichier n'existe peut-être pas à ce chemin, ou l'API fichiers Nitrado n'est pas disponible.\n→ Essaie un chemin personnalisé différent.`;
    } else {
      const lineCount = (d.content || '').split('\n').length;
      box.style.color = 'var(--text-primary)';
      box.textContent = `✅ FICHIER LU (${lineCount} lignes)\nChemin   : ${d.filePath}\nServeur  : ${serviceId}\n\n${'─'.repeat(50)}\n${d.content || '(vide)'}`;
    }
  } catch (e) {
    box.style.color = '#f87171';
    box.textContent = '❌ Erreur réseau : ' + e.message;
  }
}

// Teste l'écriture d'une clé dans le fichier .ini et relit pour confirmer
async function runDiagnose() {
  const key = document.getElementById('diag-key').value.trim();
  const value = document.getElementById('diag-value').value.trim();
  if (!key || !value) { toast('Entre une clé et une valeur', true); return; }

  const ids = getSelIds();
  const serviceId = ids.length > 0 ? ids[0] : (SRV.length > 0 ? SRV[0].id : null);
  if (!serviceId) { toast('Aucun serveur sélectionné', true); return; }

  const box = document.getElementById('diag-result');
  box.style.display = 'block';
  box.style.color = 'var(--text-primary)';
  box.textContent = `⏳ Test écriture INI en cours…\n  Serveur : ${serviceId}\n  Clé     : ${key}\n  Valeur  : ${value.replace(',', '.')}`;

  const normalizedVal = value.replace(',', '.');

  try {
    // 1. Écriture directe dans le .ini
    const writeRes = await fetch('/nitrado/api/ini/update-all', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ key, value: normalizedVal, serviceIds: [serviceId] }),
    });
    const writeData = await writeRes.json();

    if (!writeData.ok) {
      box.style.color = '#f87171';
      box.textContent = `❌ ÉCRITURE ÉCHOUÉE\n\nErreur : ${writeData.error}`;
      return;
    }
    const writeResult = writeData.results?.[0];
    if (writeResult && !writeResult.ok) {
      const isLocked = writeResult.error && writeResult.error.includes('500');
      box.style.color = '#f87171';
      if (isLocked) {
        // Stocke les params dans une variable globale pour éviter les problèmes de guillemets dans onclick
        window._restartPending = { settings: [{key, value: normalizedVal}], serviceIds: [serviceId] };
        box.style.whiteSpace = 'normal';
        box.innerHTML = [
          `<span style="color:#f87171;font-weight:700">❌ Fichier verrouillé — serveur en marche (erreur 500 Nitrado)</span>`,
          `<br><br>`,
          `Fichier visé : <code>${writeData.file || 'inconnu'}</code><br>`,
          `Section      : <code>${writeData.section || 'inconnue'}</code>`,
          `<br><br>`,
          `<span style="color:#fbbf24">Solution : arrêter le serveur, modifier le fichier, redémarrer (~2 min de downtime).</span>`,
          `<br><br>`,
          `<button onclick="triggerPendingRestart()" style="padding:10px 20px;background:#dc2626;color:#fff;border:none;border-radius:8px;cursor:pointer;font-weight:700;font-size:.85rem;width:100%">`,
          `🔄 Appliquer avec redémarrage automatique</button>`,
        ].join('');
      } else {
        box.textContent = `❌ ÉCRITURE ÉCHOUÉE sur le serveur ${serviceId}\n\nErreur : ${writeResult.error}\n\nFichier visé : ${writeData.file || 'inconnu'}\nSection      : ${writeData.section || 'inconnue'}`;
      }
      return;
    }

    // 2. Relire le fichier pour confirmer
    box.textContent += '\n✅ Écriture OK — Relecture du fichier…';
    const fileKey = writeData.file?.includes('GameUserSettings') ? 'gameUserSettings' : 'gameIni';
    const readParams = new URLSearchParams({ serviceId, file: fileKey });
    const readRes = await fetch('/nitrado/api/ini/read?' + readParams);
    const readData = await readRes.json();

    if (!readData.ok) {
      box.style.color = '#fbbf24';
      box.textContent = [
        `⚠️ Écriture envoyée mais impossible de relire le fichier`,
        ``,
        `Écriture  : OK (${writeData.file?.split('/').pop()})`,
        `Section   : ${writeData.section}`,
        `Clé       : ${key}=${normalizedVal}`,
        ``,
        `Erreur relecture : ${readData.error}`,
      ].join('\n');
      return;
    }

    // Cherche la clé dans le contenu relu
    const lines = readData.content?.split('\n') || [];
    const found = lines.find(l => l.trim().startsWith(key + '=') || l.trim().startsWith(key + ' ='));
    const inFile = found ? found.trim() : null;

    if (inFile && inFile.includes(normalizedVal)) {
      box.style.color = '#4ade80';
      box.textContent = [
        `✅ CONFIRMÉ — La valeur est bien écrite dans le fichier !`,
        ``,
        `Fichier  : ${writeData.file?.split('/').pop()}`,
        `Section  : ${writeData.section}`,
        `Ligne    : ${inFile}`,
        ``,
        `→ Redémarre la map pour appliquer en jeu.`,
      ].join('\n');
    } else if (inFile) {
      box.style.color = '#fbbf24';
      box.textContent = [
        `⚠️ Fichier modifié mais valeur différente`,
        ``,
        `Fichier  : ${writeData.file?.split('/').pop()}`,
        `Ligne    : ${inFile}`,
        `Attendu  : ${key}=${normalizedVal}`,
      ].join('\n');
    } else {
      box.style.color = '#fbbf24';
      box.textContent = [
        `⚠️ Écriture OK mais clé non trouvée dans le fichier relu`,
        ``,
        `Fichier  : ${writeData.file?.split('/').pop()}`,
        `Cherché  : ${key}`,
        ``,
        `Contenu du fichier :`,
        `${'─'.repeat(40)}`,
        readData.content || '(vide)',
      ].join('\n');
    }
  } catch (e) {
    box.style.color = '#f87171';
    box.textContent = '❌ Erreur réseau : ' + e.message;
  }
}

