<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nitrado — Arki Dashboard</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .nitrado-content { max-width: 1100px; margin: 0 auto; padding: 0 0 60px; }

    /* ── Token manquant ── */
    .no-token-box {
      background: var(--card-bg); border: 2px dashed var(--border);
      border-radius: 16px; padding: 48px 32px; text-align: center; margin-top: 32px;
    }
    .no-token-box .nt-icon { font-size: 56px; margin-bottom: 12px; }
    .no-token-box h2 { font-size: 1.4rem; margin-bottom: 8px; }
    .no-token-box p { color: var(--text-muted); margin-bottom: 20px; }
    .no-token-box code {
      display: inline-block; background: var(--bg); border: 1px solid var(--border);
      border-radius: 8px; padding: 6px 16px; font-size: 0.9rem;
    }

    /* ── En-tête ── */
    .nitrado-header {
      display: flex; align-items: center; justify-content: space-between;
      gap: 16px; flex-wrap: wrap; margin-bottom: 20px;
    }
    .nitrado-header h1 { font-size: 1.6rem; display: flex; align-items: center; gap: 10px; margin: 0; }
    .header-actions { display: flex; gap: 10px; flex-wrap: wrap; }

    /* ── Barre de sélection ── */
    .selection-bar {
      display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
      background: var(--card-bg); border: 1px solid var(--border);
      border-radius: 12px; padding: 12px 16px; margin-bottom: 16px;
    }
    .selection-counter {
      font-size: 0.88rem; font-weight: 700;
      background: var(--accent); color: #fff;
      padding: 3px 12px; border-radius: 20px; min-width: 28px; text-align: center;
    }
    .selection-counter.none { background: var(--bg); color: var(--text-muted); border: 1px solid var(--border); }
    .selection-label { font-size: 0.85rem; color: var(--text-muted); flex: 1; }
    .btn-sel {
      font-size: 0.78rem; padding: 5px 12px; border-radius: 8px;
      border: 1px solid var(--border); background: var(--bg);
      color: var(--text); cursor: pointer; font-weight: 600; white-space: nowrap;
    }
    .btn-sel:hover { border-color: var(--accent); color: var(--accent); }
    .btn-sel.danger:hover { border-color: #f44336; color: #f44336; }

    /* ── Grille serveurs ── */
    .servers-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 14px; margin-bottom: 28px;
    }
    .server-card {
      background: var(--card-bg); border: 1px solid var(--border);
      border-radius: 14px; padding: 18px; position: relative;
      transition: box-shadow .18s, border-color .18s;
      cursor: default;
    }
    .server-card:hover { box-shadow: 0 4px 18px rgba(0,0,0,.13); }
    .server-card.selected {
      border-color: var(--accent);
      box-shadow: 0 0 0 2px rgba(114,137,218,.25);
    }

    /* checkbox custom */
    .card-checkbox-wrap {
      position: absolute; top: 14px; right: 14px; z-index: 2;
    }
    .card-checkbox {
      width: 20px; height: 20px; cursor: pointer; accent-color: var(--accent);
    }

    .server-card-header {
      display: flex; align-items: flex-start; gap: 8px; margin-bottom: 12px;
      padding-right: 28px;
    }
    .server-name { font-weight: 700; font-size: 0.95rem; line-height: 1.3; flex: 1; }
    .status-badge {
      font-size: 0.7rem; font-weight: 700; padding: 3px 9px;
      border-radius: 20px; white-space: nowrap; flex-shrink: 0;
    }
    .status-badge.started    { background: #1a3a1a; color: #4caf50; }
    .status-badge.stopped    { background: #3a1a1a; color: #f44336; }
    .status-badge.restarting { background: #3a2e00; color: #ffc107; }
    .status-badge.unknown    { background: var(--bg); color: var(--text-muted); }

    .server-meta { display: flex; flex-direction: column; gap: 4px; margin-bottom: 13px; }
    .server-meta-row {
      display: flex; align-items: center; gap: 6px;
      font-size: 0.8rem; color: var(--text-muted);
    }
    .server-meta-row span:first-child { width: 16px; text-align: center; }
    .server-meta-row strong { color: var(--text); }

    .server-actions { display: flex; gap: 6px; flex-wrap: wrap; }
    .btn-sm {
      font-size: 0.76rem; padding: 5px 11px; border-radius: 8px; border: none;
      cursor: pointer; font-weight: 600; transition: opacity .15s, transform .1s;
    }
    .btn-sm:active { transform: scale(.96); }
    .btn-sm:disabled { opacity: .4; cursor: not-allowed; }
    .btn-restart { background: #2a4a2a; color: #4caf50; }
    .btn-stop    { background: #3a1a1a; color: #f44336; }
    .btn-start   { background: #1a2a3a; color: #42a5f5; }
    .btn-mods    { background: var(--bg); color: var(--text-muted); border: 1px solid var(--border); }

    /* ── Sections bulk ── */
    .nitrado-section {
      background: var(--card-bg); border: 1px solid var(--border);
      border-radius: 14px; padding: 22px; margin-bottom: 18px;
    }
    .nitrado-section h2 {
      font-size: 1.05rem; margin: 0 0 6px;
      display: flex; align-items: center; gap: 8px;
    }
    .section-scope {
      font-size: 0.78rem; color: var(--text-muted);
      margin-bottom: 16px; display: flex; align-items: center; gap: 6px;
    }
    .scope-badge {
      font-size: 0.72rem; font-weight: 700; padding: 2px 10px;
      border-radius: 20px; background: var(--accent); color: #fff;
    }
    .scope-badge.all { background: #555; }
    .section-divider { height: 1px; background: var(--border); margin: 16px 0; }

    .inline-form { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
    .inline-form input, .inline-form select {
      flex: 1; min-width: 160px; max-width: 320px;
      padding: 9px 14px; border-radius: 9px; border: 1px solid var(--border);
      background: var(--bg); color: var(--text); font-size: 0.88rem;
    }
    .inline-form input:focus, .inline-form select:focus { outline: none; border-color: var(--accent); }

    /* ── Config presets ── */
    .config-presets {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(255px, 1fr)); gap: 12px;
    }
    .config-preset-card {
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 10px; padding: 13px 15px;
    }
    .config-preset-card label {
      display: block; font-size: 0.79rem; font-weight: 700; margin-bottom: 7px; color: var(--text-muted);
    }
    .config-preset-card .preset-row { display: flex; gap: 8px; align-items: center; }
    .config-preset-card input {
      flex: 1; padding: 6px 10px; border-radius: 8px; border: 1px solid var(--border);
      background: var(--card-bg); color: var(--text); font-size: 0.84rem;
    }
    .config-preset-card input:focus { outline: none; border-color: var(--accent); }

    /* ── Bulk results ── */
    .bulk-results { margin-top: 12px; display: flex; flex-direction: column; gap: 5px; }
    .bulk-result-row {
      display: flex; align-items: center; gap: 8px; font-size: 0.8rem;
      padding: 5px 11px; border-radius: 8px; background: var(--bg);
    }
    .bulk-result-row.ok   { border-left: 3px solid #4caf50; }
    .bulk-result-row.fail { border-left: 3px solid #f44336; }

    /* ── Loader / Toast ── */
    .spin { display: inline-block; animation: spin .7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    #nit-toast {
      position: fixed; bottom: 28px; right: 28px; background: #1e2a1e;
      border: 1px solid #4caf50; color: #a5d6a7; padding: 12px 20px;
      border-radius: 12px; font-size: 0.88rem; font-weight: 600; max-width: 360px;
      z-index: 9999; opacity: 0; transform: translateY(12px);
      transition: opacity .25s, transform .25s; pointer-events: none;
    }
    #nit-toast.show { opacity: 1; transform: translateY(0); }
    #nit-toast.error { background: #2a1a1a; border-color: #f44336; color: #ef9a9a; }

    /* ── Refresh bar ── */
    .refresh-bar {
      display: flex; align-items: center; gap: 10px; font-size: 0.82rem;
      color: var(--text-muted); margin-bottom: 12px;
    }
    .refresh-bar button {
      background: none; border: none; color: var(--accent);
      cursor: pointer; font-weight: 600; font-size: 0.82rem; padding: 0;
    }

    /* ── Modal mods ── */
    .modal-overlay {
      display: none; position: fixed; inset: 0; background: rgba(0,0,0,.6);
      z-index: 1000; justify-content: center; align-items: center;
    }
    .modal-overlay.open { display: flex; }
    .modal-box {
      background: var(--card-bg); border: 1px solid var(--border);
      border-radius: 16px; padding: 26px; width: 100%; max-width: 460px; position: relative;
    }
    .modal-box h3 { margin: 0 0 14px; font-size: 1.05rem; }
    .modal-close {
      position: absolute; top: 14px; right: 16px; background: none; border: none;
      color: var(--text-muted); font-size: 1.3rem; cursor: pointer;
    }
    .mod-list {
      display: flex; flex-direction: column; gap: 5px;
      margin: 12px 0; max-height: 260px; overflow-y: auto;
    }
    .mod-item {
      display: flex; align-items: center; justify-content: space-between;
      background: var(--bg); border-radius: 8px; padding: 7px 12px; font-size: 0.84rem;
    }
    .mod-id { font-family: monospace; color: var(--accent); }
    .btn-remove-mod {
      background: #3a1a1a; color: #f44336; border: none; border-radius: 6px;
      padding: 3px 10px; font-size: 0.73rem; font-weight: 700; cursor: pointer;
    }
    .empty-mods { color: var(--text-muted); font-size: 0.84rem; text-align: center; padding: 18px 0; }

    @media (max-width: 600px) {
      .nitrado-header { flex-direction: column; align-items: flex-start; }
      .config-presets { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<%- include('sidebar') %>

<main class="main-content">
  <div class="nitrado-content">

  <% if (!hasToken) { %>
    <div class="no-token-box">
      <div class="nt-icon">🖥️</div>
      <h2>Token Nitrado non configuré</h2>
      <p>Ajoute ton token Nitrado dans les secrets sous le nom :</p>
      <code>NITRADO_TOKEN</code>
      <p style="margin-top:16px;font-size:0.85rem;color:var(--text-muted)">
        Génère un <strong>Long-life token</strong> (scope <strong>service</strong>) sur
        <a href="https://server.nitrado.net/developer" target="_blank" style="color:var(--accent)">server.nitrado.net → Développeurs</a>
      </p>
    </div>

  <% } else { %>

    <!-- En-tête -->
    <div class="nitrado-header">
      <h1>🖥️ Nitrado <span style="font-size:.72rem;font-weight:400;color:var(--text-muted)">ARK: Survival Ascended</span></h1>
      <div class="header-actions">
        <button class="btn btn-secondary" onclick="refreshStatuses()">🔄 Actualiser</button>
        <button class="btn btn-danger" id="btn-restart-sel" onclick="restartSelected()">⚡ Redémarrer la sélection</button>
      </div>
    </div>

    <% if (error) { %>
    <div class="alert alert-error" style="margin-bottom:16px">⚠️ Erreur API : <strong><%= error %></strong></div>
    <% } %>

    <div class="refresh-bar">
      <span id="last-refresh">Chargé à l'ouverture de la page</span>
      <button onclick="refreshStatuses()">↺ Actualiser</button>
    </div>

    <!-- Barre de sélection -->
    <div class="selection-bar">
      <span class="selection-counter none" id="sel-count">0</span>
      <span class="selection-label" id="sel-label">map sélectionnée — Les actions s'appliqueront uniquement à la sélection (0 = toutes)</span>
      <button class="btn-sel" onclick="selectAll()">Tout sélectionner</button>
      <button class="btn-sel" onclick="selectNone()">Tout désélectionner</button>
      <button class="btn-sel danger" onclick="invertSelection()">Inverser</button>
    </div>

    <!-- Grille serveurs -->
    <div class="servers-grid" id="servers-grid">
      <% servers.forEach(function(s) { %>
      <div class="server-card" id="card-<%= s.id %>" data-id="<%= s.id %>" onclick="toggleCard(this)">
        <div class="card-checkbox-wrap">
          <input type="checkbox" class="card-checkbox server-checkbox" data-id="<%= s.id %>"
            onclick="event.stopPropagation(); syncCard(this)" aria-label="Sélectionner <%= s.name %>">
        </div>
        <div class="server-card-header">
          <div class="server-name"><%= s.name %></div>
          <span class="status-badge <%= s.status %>" id="badge-<%= s.id %>">
            <%= s.status === 'started' ? '● En ligne' : s.status === 'stopped' ? '● Hors ligne' : s.status === 'restarting' ? '⟳ Redémarre' : s.status %>
          </span>
        </div>
        <div class="server-meta">
          <div class="server-meta-row"><span>🗺️</span> <strong id="map-<%= s.id %>"><%= s.map %></strong></div>
          <div class="server-meta-row"><span>👥</span> <strong id="players-<%= s.id %>"><%= s.players %>/<%= s.maxPlayers %></strong></div>
          <div class="server-meta-row"><span>🔌</span> <strong><%= s.ip %>:<%= s.port %></strong></div>
        </div>
        <div class="server-actions" onclick="event.stopPropagation()">
          <button class="btn-sm btn-restart" onclick="restartOne('<%= s.id %>', '<%= s.name %>')">⚡ Restart</button>
          <% if (s.status === 'started') { %>
          <button class="btn-sm btn-stop" onclick="stopOne('<%= s.id %>')">⏹ Stop</button>
          <% } else { %>
          <button class="btn-sm btn-start" onclick="startOne('<%= s.id %>')">▶ Start</button>
          <% } %>
          <button class="btn-sm btn-mods" onclick="openModsModal('<%= s.id %>', '<%= s.name %>')">🔧 Mods</button>
        </div>
      </div>
      <% }); %>
      <% if (servers.length === 0 && !error) { %>
      <div style="color:var(--text-muted);font-size:.9rem;grid-column:1/-1">Aucun serveur trouvé.</div>
      <% } %>
    </div>

    <!-- Section Mods -->
    <div class="nitrado-section">
      <h2>🔧 Gestion des Mods</h2>
      <div class="section-scope">
        Cible : <span class="scope-badge" id="mods-scope-badge">toutes les maps</span>
        <span id="mods-scope-label">— modifie la sélection dans les cartes ci-dessus</span>
      </div>

      <div class="inline-form">
        <input type="text" id="mod-id-add" placeholder="ID du mod (ex: 928988)" style="font-family:monospace">
        <button class="btn btn-success" onclick="addModSelected()">➕ Ajouter</button>
      </div>
      <div class="section-divider"></div>
      <div class="inline-form">
        <input type="text" id="mod-id-remove" placeholder="ID du mod à retirer" style="font-family:monospace">
        <button class="btn btn-danger" onclick="removeModSelected()">➖ Retirer</button>
      </div>
      <div id="mods-bulk-results" class="bulk-results"></div>
    </div>

    <!-- Section Paramètres -->
    <div class="nitrado-section">
      <h2>⚙️ Paramètres rapides</h2>
      <div class="section-scope">
        Cible : <span class="scope-badge" id="cfg-scope-badge">toutes les maps</span>
        <span id="cfg-scope-label">— modifie la sélection dans les cartes ci-dessus</span>
      </div>

      <div class="config-presets">

        <div class="config-preset-card">
          <label>🥚 Temps de repro (MatingIntervalMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.01" min="0.01" max="10" id="cfg-mating" placeholder="ex : 0.25">
            <button class="btn-sm btn-restart" onclick="applyConfig('config','MatingIntervalMultiplier','cfg-mating')">✓</button>
          </div>
        </div>

        <div class="config-preset-card">
          <label>🦖 Apprivoisement (TamingSpeedMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.1" min="0.1" max="100" id="cfg-taming" placeholder="ex : 5.0">
            <button class="btn-sm btn-restart" onclick="applyConfig('config','TamingSpeedMultiplier','cfg-taming')">✓</button>
          </div>
        </div>

        <div class="config-preset-card">
          <label>🌾 Récolte (HarvestAmountMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.1" min="0.1" max="100" id="cfg-harvest" placeholder="ex : 3.0">
            <button class="btn-sm btn-restart" onclick="applyConfig('config','HarvestAmountMultiplier','cfg-harvest')">✓</button>
          </div>
        </div>

        <div class="config-preset-card">
          <label>⭐ XP (XPMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.1" min="0.1" max="100" id="cfg-xp" placeholder="ex : 2.0">
            <button class="btn-sm btn-restart" onclick="applyConfig('config','XPMultiplier','cfg-xp')">✓</button>
          </div>
        </div>

        <div class="config-preset-card">
          <label>🐣 Maturation (BabyMatureSpeedMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.1" min="0.1" max="1000" id="cfg-mature" placeholder="ex : 30.0">
            <button class="btn-sm btn-restart" onclick="applyConfig('config','BabyMatureSpeedMultiplier','cfg-mature')">✓</button>
          </div>
        </div>

        <div class="config-preset-card">
          <label>🥗 Nourriture bébé (BabyFoodConsumptionSpeedMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.01" min="0.01" max="10" id="cfg-babyfood" placeholder="ex : 0.1">
            <button class="btn-sm btn-restart" onclick="applyConfig('config','BabyFoodConsumptionSpeedMultiplier','cfg-babyfood')">✓</button>
          </div>
        </div>

        <div class="config-preset-card">
          <label>🥚 Incubation (EggHatchSpeedMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.1" min="0.1" max="1000" id="cfg-hatch" placeholder="ex : 20.0">
            <button class="btn-sm btn-restart" onclick="applyConfig('config','EggHatchSpeedMultiplier','cfg-hatch')">✓</button>
          </div>
        </div>

        <div class="config-preset-card">
          <label>💀 Dégâts joueurs (PlayerDamageMultiplier)</label>
          <div class="preset-row">
            <input type="number" step="0.1" min="0.1" max="10" id="cfg-dmg" placeholder="ex : 1.0">
            <button class="btn-sm btn-restart" onclick="applyConfig('config','PlayerDamageMultiplier','cfg-dmg')">✓</button>
          </div>
        </div>

      </div>
      <div id="config-bulk-results" class="bulk-results"></div>
    </div>

    <!-- Modal mods -->
    <div class="modal-overlay" id="mods-modal">
      <div class="modal-box">
        <button class="modal-close" onclick="closeModal()">✕</button>
        <h3 id="modal-title">Mods</h3>
        <div class="mod-list" id="modal-mod-list">
          <div class="empty-mods">Chargement…</div>
        </div>
        <div class="inline-form" style="margin-top:8px">
          <input type="text" id="modal-mod-add" placeholder="ID du mod à ajouter" style="font-family:monospace;flex:1">
          <button class="btn btn-success" onclick="addModToServer()">➕</button>
        </div>
      </div>
    </div>

  <% } %>
  </div>
</main>

<div id="nit-toast"></div>

<script>
const serverList = <%- JSON.stringify(servers) %>;
let currentModalServerId = null;

// ── Sélection ─────────────────────────────────────────────────────────────

function getSelectedIds() {
  return [...document.querySelectorAll('.server-checkbox:checked')].map(c => c.dataset.id);
}

function updateSelectionUI() {
  const ids = getSelectedIds();
  const n = ids.length;
  const counter = document.getElementById('sel-count');
  const label = document.getElementById('sel-label');

  counter.textContent = n;
  if (n === 0) {
    counter.className = 'selection-counter none';
    label.textContent = 'map sélectionnée — aucune sélection = toutes les maps';
  } else {
    counter.className = 'selection-counter';
    label.textContent = n === 1 ? 'map sélectionnée' : 'maps sélectionnées';
  }

  const scopeText = n === 0 ? 'toutes les maps' : n + (n === 1 ? ' map' : ' maps');
  const isAll = n === 0;

  ['mods-scope-badge', 'cfg-scope-badge'].forEach(id => {
    const el = document.getElementById(id);
    if (el) { el.textContent = scopeText; el.className = 'scope-badge' + (isAll ? ' all' : ''); }
  });
}

function toggleCard(card) {
  const cb = card.querySelector('.server-checkbox');
  if (!cb) return;
  cb.checked = !cb.checked;
  card.classList.toggle('selected', cb.checked);
  updateSelectionUI();
}

function syncCard(checkbox) {
  const card = document.getElementById('card-' + checkbox.dataset.id);
  if (card) card.classList.toggle('selected', checkbox.checked);
  updateSelectionUI();
}

function selectAll() {
  document.querySelectorAll('.server-checkbox').forEach(cb => {
    cb.checked = true;
    const card = document.getElementById('card-' + cb.dataset.id);
    if (card) card.classList.add('selected');
  });
  updateSelectionUI();
}

function selectNone() {
  document.querySelectorAll('.server-checkbox').forEach(cb => {
    cb.checked = false;
    const card = document.getElementById('card-' + cb.dataset.id);
    if (card) card.classList.remove('selected');
  });
  updateSelectionUI();
}

function invertSelection() {
  document.querySelectorAll('.server-checkbox').forEach(cb => {
    cb.checked = !cb.checked;
    const card = document.getElementById('card-' + cb.dataset.id);
    if (card) card.classList.toggle('selected', cb.checked);
  });
  updateSelectionUI();
}

// ── Toast ─────────────────────────────────────────────────────────────────
let toastTimer;
function showToast(msg, isError = false) {
  const el = document.getElementById('nit-toast');
  el.textContent = msg;
  el.className = 'show' + (isError ? ' error' : '');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.className = '', 3500);
}

// ── Refresh statuts ────────────────────────────────────────────────────────
function refreshStatuses() {
  fetch('/nitrado/api/servers')
    .then(r => r.json())
    .then(data => {
      if (!data.ok) { showToast('Erreur : ' + data.error, true); return; }
      data.servers.forEach(s => {
        const badge = document.getElementById('badge-' + s.id);
        if (badge) {
          badge.className = 'status-badge ' + s.status;
          badge.textContent = s.status === 'started' ? '● En ligne'
            : s.status === 'stopped' ? '● Hors ligne'
            : s.status === 'restarting' ? '⟳ Redémarre' : s.status;
        }
        const pl = document.getElementById('players-' + s.id);
        if (pl) pl.textContent = s.players + '/' + s.maxPlayers;
        const mp = document.getElementById('map-' + s.id);
        if (mp) mp.textContent = s.map;
      });
      document.getElementById('last-refresh').textContent = 'Actualisé à ' + new Date().toLocaleTimeString('fr-FR');
      showToast('✅ Statuts mis à jour');
    })
    .catch(() => showToast('Erreur réseau', true));
}

// ── Actions individuelles ──────────────────────────────────────────────────
function restartOne(id, name) {
  if (!confirm('Redémarrer "' + name + '" ?')) return;
  fetch('/nitrado/api/restart/' + id, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' })
    .then(r => r.json())
    .then(d => d.ok ? showToast('✅ ' + name + ' redémarre…') : showToast('Erreur : ' + d.error, true));
}
function stopOne(id) {
  if (!confirm('Stopper ce serveur ?')) return;
  fetch('/nitrado/api/stop/' + id, { method: 'POST' })
    .then(r => r.json()).then(d => d.ok ? showToast('⏹ Stoppé') : showToast('Erreur : ' + d.error, true));
}
function startOne(id) {
  fetch('/nitrado/api/start/' + id, { method: 'POST' })
    .then(r => r.json()).then(d => d.ok ? showToast('▶ Démarré') : showToast('Erreur : ' + d.error, true));
}

// ── Restart sélection ─────────────────────────────────────────────────────
function restartSelected() {
  const ids = getSelectedIds();
  const n = ids.length;
  const msg = n === 0
    ? 'Redémarrer TOUTES les maps ?'
    : 'Redémarrer ' + n + ' map' + (n > 1 ? 's' : '') + ' sélectionnée' + (n > 1 ? 's' : '') + ' ?';
  if (!confirm(msg)) return;

  const btn = document.getElementById('btn-restart-sel');
  btn.disabled = true; btn.innerHTML = '<span class="spin">⟳</span> En cours…';

  fetch('/nitrado/api/restart-all', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ serviceIds: ids }),
  })
    .then(r => r.json())
    .then(d => {
      if (d.ok) showToast('✅ ' + d.results.filter(r => r.ok).length + '/' + d.results.length + ' redémarrés');
      else showToast('Erreur : ' + d.error, true);
    })
    .catch(() => showToast('Erreur réseau', true))
    .finally(() => { btn.disabled = false; btn.textContent = '⚡ Redémarrer la sélection'; });
}

// ── Mods bulk ─────────────────────────────────────────────────────────────
function addModSelected() {
  const modId = document.getElementById('mod-id-add').value.trim();
  if (!modId) { showToast('Entre un ID de mod', true); return; }
  const ids = getSelectedIds();
  const n = ids.length;
  if (!confirm('Ajouter le mod ' + modId + ' sur ' + (n === 0 ? 'TOUTES les maps' : n + ' map(s)') + ' ?')) return;
  bulkModAction('/nitrado/api/mods/add-all', { modId, serviceIds: ids }, 'mods-bulk-results', 'Mod ' + modId + ' ajouté');
}

function removeModSelected() {
  const modId = document.getElementById('mod-id-remove').value.trim();
  if (!modId) { showToast('Entre un ID de mod', true); return; }
  const ids = getSelectedIds();
  const n = ids.length;
  if (!confirm('Retirer le mod ' + modId + ' de ' + (n === 0 ? 'TOUTES les maps' : n + ' map(s)') + ' ?')) return;
  bulkModAction('/nitrado/api/mods/remove-all', { modId, serviceIds: ids }, 'mods-bulk-results', 'Mod ' + modId + ' retiré');
}

function bulkModAction(url, body, resultId, msg) {
  fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
    .then(r => r.json())
    .then(d => {
      if (d.ok) {
        showToast('✅ ' + msg + ' sur ' + d.results.filter(r => r.ok).length + '/' + d.results.length + ' maps');
        renderBulkResults(resultId, d.results);
      } else showToast('Erreur : ' + d.error, true);
    })
    .catch(() => showToast('Erreur réseau', true));
}

// ── Config ────────────────────────────────────────────────────────────────
function applyConfig(category, key, inputId) {
  const value = document.getElementById(inputId).value.trim();
  if (!value) { showToast('Entre une valeur', true); return; }
  const ids = getSelectedIds();
  const n = ids.length;
  if (!confirm(key + ' = ' + value + ' sur ' + (n === 0 ? 'TOUTES les maps' : n + ' map(s)') + ' ?')) return;

  fetch('/nitrado/api/settings/update-all', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ category, key, value, serviceIds: ids }),
  })
    .then(r => r.json())
    .then(d => {
      if (d.ok) {
        showToast('✅ ' + key + ' = ' + value + ' — ' + d.results.filter(r => r.ok).length + '/' + d.results.length + ' maps');
        renderBulkResults('config-bulk-results', d.results);
      } else showToast('Erreur : ' + d.error, true);
    })
    .catch(() => showToast('Erreur réseau', true));
}

// ── Résultats bulk ────────────────────────────────────────────────────────
function renderBulkResults(containerId, results) {
  const nameMap = {};
  serverList.forEach(s => { nameMap[s.id] = s.name; });
  document.getElementById(containerId).innerHTML = results.map(r =>
    '<div class="bulk-result-row ' + (r.ok ? 'ok' : 'fail') + '">' +
    (r.ok ? '✅' : '❌') + ' ' + (nameMap[r.id] || r.id) +
    (r.error ? ' <span style="color:var(--text-muted);margin-left:auto">' + r.error + '</span>' : '') +
    '</div>'
  ).join('');
}

// ── Modal mods ────────────────────────────────────────────────────────────
function openModsModal(id, name) {
  currentModalServerId = id;
  document.getElementById('modal-title').textContent = '🔧 Mods — ' + name;
  document.getElementById('modal-mod-list').innerHTML = '<div class="empty-mods"><span class="spin">⟳</span> Chargement…</div>';
  document.getElementById('modal-mod-add').value = '';
  document.getElementById('mods-modal').classList.add('open');
  fetchServerMods(id);
}
function closeModal() {
  document.getElementById('mods-modal').classList.remove('open');
  currentModalServerId = null;
}
function fetchServerMods(id) {
  fetch('/nitrado/api/mods/' + id)
    .then(r => r.json())
    .then(d => d.ok ? renderModList(d.mods, id) :
      (document.getElementById('modal-mod-list').innerHTML = '<div class="empty-mods">Erreur : ' + d.error + '</div>'))
    .catch(() => (document.getElementById('modal-mod-list').innerHTML = '<div class="empty-mods">Erreur réseau</div>'));
}
function renderModList(mods, serverId) {
  if (!mods || !mods.length) {
    document.getElementById('modal-mod-list').innerHTML = '<div class="empty-mods">Aucun mod installé</div>';
    return;
  }
  document.getElementById('modal-mod-list').innerHTML = mods.map(m =>
    '<div class="mod-item"><span class="mod-id">' + m + '</span>' +
    '<button class="btn-remove-mod" onclick="removeModFromServer(\'' + serverId + '\',\'' + m + '\')">Retirer</button></div>'
  ).join('');
}
function addModToServer() {
  const modId = document.getElementById('modal-mod-add').value.trim();
  if (!modId || !currentModalServerId) return;
  fetch('/nitrado/api/mods/add/' + currentModalServerId, {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ modId }),
  }).then(r => r.json()).then(d => {
    if (d.ok) { showToast('✅ Mod ' + modId + ' ajouté'); document.getElementById('modal-mod-add').value = ''; fetchServerMods(currentModalServerId); }
    else showToast('Erreur : ' + d.error, true);
  });
}
function removeModFromServer(serverId, modId) {
  fetch('/nitrado/api/mods/remove/' + serverId, {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ modId }),
  }).then(r => r.json()).then(d => {
    if (d.ok) { showToast('✅ Mod ' + modId + ' retiré'); fetchServerMods(serverId); }
    else showToast('Erreur : ' + d.error, true);
  });
}

document.getElementById('mods-modal')?.addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(); });
</script>
</body>
</html>
