<button class="mobile-menu-btn" onclick="document.querySelector('.sidebar').classList.add('open');document.querySelector('.sidebar-overlay').classList.add('show')" aria-label="Menu">
  <img src="/images/logo-brut.png" alt="Menu" class="mobile-menu-logo">
</button>
<div class="sidebar-overlay" onclick="document.querySelector('.sidebar').classList.remove('open');this.classList.remove('show')"></div>
<aside class="sidebar">
  <div class="sidebar-header">
    <div class="bot-avatar">
      <img src="/images/logo-brut.png" alt="Arki Family">
    </div>
    <div class="bot-info">
      <h2><%= botUser ? botUser.username : 'Arki Bot' %></h2>
      <span>● En ligne</span>
    </div>
    <button class="sidebar-close" onclick="document.querySelector('.sidebar').classList.remove('open');document.querySelector('.sidebar-overlay').classList.remove('show')" aria-label="Fermer">✕</button>
  </div>
  <nav class="sidebar-nav">
    <% if (role === 'admin') { %>
    <a href="/" class="nav-link <%= path === '/' ? 'active' : '' %>">
      <span class="icon">🏠</span> Tableau de bord
    </a>
    <a href="/roulette" class="nav-link <%= path === '/roulette' ? 'active' : '' %>">
      <span class="icon">🎰</span> Roulette
    </a>

    <div class="nav-section">Votes</div>
    <a href="/votes" class="nav-link <%= path === '/votes' ? 'active' : '' %>">
      <span class="icon">📊</span> Classement
    </a>
    <a href="/rewards" class="nav-link <%= path === '/rewards' ? 'active' : '' %>">
      <span class="icon">💎</span> Récompenses
    </a>
    <a href="/message" class="nav-link <%= path === '/message' ? 'active' : '' %>">
      <span class="icon">📝</span> Message publié
    </a>
    <% } %>

    <div class="nav-section">Shop</div>
    <a href="/shop" class="nav-link <%= path === '/shop' ? 'active' : '' %>">
      <span class="icon">🛒</span> Gestion Shop
    </a>
    <a href="/dinos" class="nav-link <%= path === '/dinos' ? 'active' : '' %>">
      <span class="icon">🦖</span> Prix Dinos
    </a>

    <div class="nav-section">Inventaires</div>
    <a href="/inventory" class="nav-link <%= path === '/inventory' ? 'active' : '' %>">
      <span class="icon">📦</span> Inventaires
    </a>

    <% if (role === 'admin') { %>
    <div class="nav-section">Système</div>
    <a href="/settings" class="nav-link <%= path === '/settings' ? 'active' : '' %>">
      <span class="icon">⚙️</span> Paramètres
    </a>
    <% } %>
  </nav>
  <div class="sidebar-footer">
    <a href="/logout" class="nav-link">
      <span class="icon">🚪</span> Déconnexion
    </a>
  </div>
</aside>
