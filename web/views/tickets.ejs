<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tickets — Arki Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .tk-accordion {
      border: 1px solid var(--border-color);
      border-radius: 14px;
      overflow: hidden;
      margin-bottom: 18px;
      background: var(--bg-card);
    }
    .tk-header {
      padding: 16px 20px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 12px;
      user-select: none;
      transition: background .15s;
    }
    .tk-header:hover { background: var(--bg-hover, rgba(255,255,255,.04)); }
    .tk-icon { font-size: 20px; flex-shrink: 0; }
    .tk-title { flex: 1; font-size: 15px; font-weight: 700; }
    .tk-subtitle { font-size: 12px; color: var(--text-muted); font-weight: 400; margin-top: 2px; }
    .tk-badge {
      font-size: 11px;
      padding: 3px 10px;
      border-radius: 20px;
      font-weight: 700;
      flex-shrink: 0;
    }
    .tk-badge-active  { background: rgba(46,204,113,.15); color: #2ecc71; border: 1px solid rgba(46,204,113,.3); }
    .tk-badge-soon    { background: rgba(149,165,166,.12); color: #95a5a6; border: 1px solid rgba(149,165,166,.25); }
    .tk-chevron { font-size: 12px; color: var(--text-muted); transition: transform .2s; flex-shrink: 0; }
    .tk-accordion.open .tk-chevron { transform: rotate(180deg); }
    .tk-body {
      display: none;
      padding: 22px 24px;
      border-top: 1px solid var(--border-color);
      background: var(--bg-main, var(--bg-card));
    }
    .tk-accordion.open .tk-body { display: block; }
    .tk-section-title {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .8px;
      color: var(--text-muted);
      margin: 0 0 14px 0;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .tk-section-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border-color);
    }
    .tk-form-row { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 16px; }
    .tk-form-row .form-group { flex: 1; min-width: 220px; }
    .file-upload-label {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 9px 16px; border-radius: 8px; cursor: pointer;
      background: var(--input-bg, #1e1f22); border: 1.5px dashed var(--border-color, #3a3c40);
      color: var(--text-muted); font-size: 13px; transition: border-color .2s, color .2s;
    }
    .file-upload-label:hover { border-color: var(--accent, #5865f2); color: var(--accent, #5865f2); }
    .file-upload-icon { font-size: 16px; }
    .tk-soon-banner {
      padding: 28px 24px;
      text-align: center;
      color: var(--text-muted);
      font-size: 14px;
    }
    .tk-soon-banner span { font-size: 32px; display: block; margin-bottom: 8px; }

    /* ── Sélecteur de rôles ── */
    .role-picker { position: relative; }
    .role-picker-trigger {
      display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
      min-height: 42px; padding: 6px 12px;
      background: var(--bg-input); border: 1px solid var(--border-color);
      border-radius: 8px; cursor: pointer; transition: border-color .15s;
    }
    .role-picker-trigger:hover, .role-picker.open .role-picker-trigger {
      border-color: var(--accent);
    }
    .role-picker-placeholder { color: var(--text-muted); font-size: 14px; }
    .role-tag {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 3px 8px; border-radius: 20px; font-size: 12px; font-weight: 600;
      background: rgba(114,137,218,.18); color: #7289da;
      border: 1px solid rgba(114,137,218,.3);
    }
    .role-tag-dot {
      width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
    }
    .role-tag-remove {
      cursor: pointer; opacity: .7; font-size: 13px; line-height: 1;
      background: none; border: none; color: inherit; padding: 0;
    }
    .role-tag-remove:hover { opacity: 1; }
    .role-picker-chevron { margin-left: auto; color: var(--text-muted); font-size: 12px; flex-shrink: 0; transition: transform .2s; }
    .role-picker.open .role-picker-chevron { transform: rotate(180deg); }
    .role-picker-dropdown {
      display: none; position: absolute; top: calc(100% + 6px); left: 0; right: 0;
      background: var(--bg-card); border: 1px solid var(--border-color);
      border-radius: 10px; box-shadow: 0 8px 24px rgba(0,0,0,.25);
      z-index: 200; max-height: 260px; overflow-y: auto;
    }
    .role-picker.open .role-picker-dropdown { display: block; }
    .role-picker-search {
      padding: 10px 12px; border-bottom: 1px solid var(--border-color);
    }
    .role-picker-search input {
      width: 100%; background: var(--bg-input); border: 1px solid var(--border-color);
      border-radius: 6px; padding: 6px 10px; color: var(--text-primary); font-size: 13px;
      outline: none;
    }
    .role-option {
      display: flex; align-items: center; gap: 10px;
      padding: 9px 14px; cursor: pointer; transition: background .1s;
    }
    .role-option:hover { background: var(--bg-hover, rgba(255,255,255,.04)); }
    .role-option input[type=checkbox] { width: 15px; height: 15px; accent-color: var(--accent); flex-shrink: 0; cursor: pointer; }
    .role-option-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .role-option-name { font-size: 13px; flex: 1; }
    .role-option.checked { background: rgba(114,137,218,.07); }
  </style>
</head>
<body>
  <div class="layout">
    <%- include('sidebar') %>
    <main class="main-content">
      <div class="page-header">
        <h1>🎫 Tickets</h1>
        <p>Configuration des syst&egrave;mes de tickets du serveur</p>
      </div>

      <% if (success) { %>
        <div class="alert alert-success">&#x2705; <%= success %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-error">&#x274C; <%= error %></div>
      <% } %>

      <!-- ══ Tickets Shop ══════════════════════════════════════════════════════ -->
      <div class="tk-accordion open" id="tk-shop">
        <div class="tk-header" onclick="tkToggle('tk-shop')">
          <span class="tk-icon">🛒</span>
          <div style="flex:1">
            <div class="tk-title">Tickets Shop</div>
            <div class="tk-subtitle">Commandes via le système de tickets privés</div>
          </div>
          <span class="tk-badge tk-badge-active">Actif</span>
          <span class="tk-chevron">▼</span>
        </div>
        <div class="tk-body">
          <form method="POST" action="/tickets/shop">

            <p class="tk-section-title">🔧 Configuration Discord</p>
            <div class="tk-form-row">
              <div class="form-group">
                <label for="shopTicketChannelId">🎫 Salon de log tickets</label>
                <select id="shopTicketChannelId" name="shopTicketChannelId" class="form-control">
                  <option value="">-- Sélectionner --</option>
                  <% channels.forEach(ch => { %>
                    <option value="<%= ch.id %>" <%= shop.shopTicketChannelId === ch.id ? 'selected' : '' %>>
                      <% if (ch.category) { %>[<%= ch.category %>] <% } %># <%= ch.name %>
                    </option>
                  <% }); %>
                </select>
                <p class="help-text">Salon admin où apparaissent les rapports d'achat</p>
              </div>
              <div class="form-group">
                <label for="shopTicketNotifChannelId">🔔 Salon de notification de nouvelle commande</label>
                <select id="shopTicketNotifChannelId" name="shopTicketNotifChannelId" class="form-control">
                  <option value="">-- Aucun (désactivé) --</option>
                  <% channels.forEach(ch => { %>
                    <option value="<%= ch.id %>" <%= shop.shopTicketNotifChannelId === ch.id ? 'selected' : '' %>>
                      <% if (ch.category) { %>[<%= ch.category %>] <% } %># <%= ch.name %>
                    </option>
                  <% }); %>
                </select>
                <p class="help-text">Salon où un message "Nouvelle commande" est envoyé à chaque ouverture de ticket</p>
              </div>
            </div>
            <div class="tk-form-row">
              <div class="form-group">
                <label for="shopTicketCategoryId">📂 Catégorie Discord des tickets</label>
                <select id="shopTicketCategoryId" name="shopTicketCategoryId" class="form-control">
                  <option value="">-- Aucune (racine du serveur) --</option>
                  <% (discordCategories || []).forEach(cat => { %>
                    <option value="<%= cat.id %>" <%= shop.shopTicketCategoryId === cat.id ? 'selected' : '' %>>
                      📁 <%= cat.name %>
                    </option>
                  <% }); %>
                </select>
                <p class="help-text">Catégorie où sont créés les salons tickets</p>
              </div>
            </div>

            <p class="tk-section-title" style="margin-top:8px">🛡️ Permissions</p>
            <div class="tk-form-row">
              <div class="form-group" style="max-width:520px">
                <label>Rôles autorisés à voir et gérer les tickets shop</label>
                <div class="role-picker" id="rolePickerShop">
                  <div class="role-picker-trigger" onclick="rpToggle('rolePickerShop')">
                    <span class="role-picker-placeholder" id="rpPlaceholderShop" style="display:<%= (shop.shopTicketAdminRoleIds||[]).length ? 'none' : 'inline' %>">Sélectionner des rôles…</span>
                    <span id="rpTagsShop" style="display:contents"></span>
                    <span class="role-picker-chevron">▼</span>
                  </div>
                  <div class="role-picker-dropdown">
                    <div class="role-picker-search">
                      <input type="text" placeholder="Rechercher un rôle…" oninput="rpFilter(this,'rolePickerShop')">
                    </div>
                    <% (discordRoles || []).forEach(r => {
                      const selected = (shop.shopTicketAdminRoleIds || []).includes(r.id);
                    %>
                    <label class="role-option <%= selected ? 'checked' : '' %>" data-role-id="<%= r.id %>" data-role-name="<%= r.name %>" data-role-color="<%= r.color || '#7289da' %>">
                      <input type="checkbox" name="shopTicketAdminRoleIds" value="<%= r.id %>" <%= selected ? 'checked' : '' %> onchange="rpUpdate('rolePickerShop')">
                      <span class="role-option-dot" style="background:<%= r.color || '#7289da' %>"></span>
                      <span class="role-option-name"><%= r.name %></span>
                    </label>
                    <% }); %>
                    <% if (!discordRoles || discordRoles.length === 0) { %>
                    <div style="padding:14px;text-align:center;color:var(--text-muted);font-size:13px">Aucun rôle disponible (bot hors ligne ?)</div>
                    <% } %>
                  </div>
                </div>
                <p class="help-text">Ces rôles peuvent voir et gérer tous les tickets shop. Le rôle Modo (paramètres globaux) est toujours inclus.</p>
              </div>
            </div>

            <div style="margin-top:4px">
              <button type="submit" class="btn btn-primary">💾 Sauvegarder</button>
            </div>
          </form>
        </div>
      </div>

      <!-- ══ Tickets Spawn Joueur ════════════════════════════════════════════ -->
      <div class="tk-accordion" id="tk-spawn">
        <div class="tk-header" onclick="tkToggle('tk-spawn')">
          <span class="tk-icon">🐣</span>
          <div style="flex:1">
            <div class="tk-title">Tickets Spawn Joueur</div>
            <div class="tk-subtitle">Admission des nouveaux joueurs — âge, plateforme, gamertag, checklist staff</div>
          </div>
          <span class="tk-badge tk-badge-active">Actif</span>
          <span class="tk-chevron">▼</span>
        </div>
        <div class="tk-body">
          <form method="POST" action="/tickets/spawn" enctype="multipart/form-data">

            <p class="tk-section-title">🔧 Configuration Discord</p>
            <div class="tk-form-row">
              <div class="form-group">
                <label for="spawnTicketCategoryId">📂 Catégorie Discord des tickets</label>
                <select id="spawnTicketCategoryId" name="spawnTicketCategoryId" class="form-control">
                  <option value="">-- Aucune (racine du serveur) --</option>
                  <% (discordCategories || []).forEach(cat => { %>
                    <option value="<%= cat.id %>" <%= (spawnTicket.ticketCategoryId === cat.id) ? 'selected' : '' %>>
                      📁 <%= cat.name %>
                    </option>
                  <% }); %>
                </select>
                <p class="help-text">Catégorie où sont créés les salons spawn-joueur-xxx</p>
              </div>
              <div class="form-group">
                <label for="spawnWelcomeChannelId">🎉 Salon de bienvenue</label>
                <select id="spawnWelcomeChannelId" name="spawnWelcomeChannelId" class="form-control">
                  <option value="">-- Sélectionner --</option>
                  <% channels.forEach(ch => { %>
                    <option value="<%= ch.id %>" <%= (spawnTicket.welcomeChannelId === ch.id) ? 'selected' : '' %>>
                      <% if (ch.category) { %>[<%= ch.category %>] <% } %># <%= ch.name %>
                    </option>
                  <% }); %>
                </select>
                <p class="help-text">Salon où le bot poste le message de bienvenue après l'admission</p>
              </div>
              <div class="form-group">
                <label for="spawnLogChannelId">📋 Salon de log admissions</label>
                <select id="spawnLogChannelId" name="spawnLogChannelId" class="form-control">
                  <option value="">-- Sélectionner --</option>
                  <% channels.forEach(ch => { %>
                    <option value="<%= ch.id %>" <%= (spawnTicket.logChannelId === ch.id) ? 'selected' : '' %>>
                      <% if (ch.category) { %>[<%= ch.category %>] <% } %># <%= ch.name %>
                    </option>
                  <% }); %>
                </select>
                <p class="help-text">Salon admin pour les logs d'ouverture et de finalisation</p>
              </div>
            </div>

            <p class="tk-section-title" style="margin-top:8px">🛡️ Permissions & Rôles</p>
            <div class="tk-form-row">
              <div class="form-group">
                <label>Rôles staff autorisés à gérer les tickets spawn</label>
                <div class="role-picker" id="rolePickerSpawn">
                  <div class="role-picker-trigger" onclick="rpToggle('rolePickerSpawn')">
                    <span class="role-picker-placeholder" id="rpPlaceholderSpawn" style="display:<%= (spawnTicket.adminRoleIds||[]).length ? 'none' : 'inline' %>">Sélectionner des rôles…</span>
                    <span id="rpTagsSpawn" style="display:contents"></span>
                    <span class="role-picker-chevron">▼</span>
                  </div>
                  <div class="role-picker-dropdown">
                    <div class="role-picker-search">
                      <input type="text" placeholder="Rechercher un rôle…" oninput="rpFilter(this,'rolePickerSpawn')">
                    </div>
                    <% (discordRoles || []).forEach(r => {
                      const sel = (spawnTicket.adminRoleIds || []).includes(r.id);
                    %>
                    <label class="role-option <%= sel ? 'checked' : '' %>" data-role-id="<%= r.id %>" data-role-name="<%= r.name %>" data-role-color="<%= r.color || '#7289da' %>">
                      <input type="checkbox" name="spawnAdminRoleIds" value="<%= r.id %>" <%= sel ? 'checked' : '' %> onchange="rpUpdate('rolePickerSpawn')">
                      <span class="role-option-dot" style="background:<%= r.color || '#7289da' %>"></span>
                      <span class="role-option-name"><%= r.name %></span>
                    </label>
                    <% }); %>
                    <% if (!discordRoles || discordRoles.length === 0) { %>
                    <div style="padding:14px;text-align:center;color:var(--text-muted);font-size:13px">Aucun rôle disponible (bot hors ligne ?)</div>
                    <% } %>
                  </div>
                </div>
                <p class="help-text">Ces rôles voient et gèrent tous les tickets spawn</p>
              </div>
              <div class="form-group">
                <label for="spawnMemberRoleId">🔓 Rôle à retirer pour débloquer les salons</label>
                <select id="spawnMemberRoleId" name="spawnMemberRoleId" class="form-control">
                  <option value="">-- Aucun --</option>
                  <% (discordRoles || []).forEach(r => { %>
                    <option value="<%= r.id %>" <%= (spawnTicket.memberRoleId === r.id) ? 'selected' : '' %>>
                      <%= r.name %>
                    </option>
                  <% }); %>
                </select>
                <p class="help-text">Rôle retiré au joueur via le bouton "🔓 Débloquer les salons" dans le ticket (et automatiquement lors de la finalisation)</p>
              </div>
            </div>

            <p class="tk-section-title" style="margin-top:8px">🔔 Notification admin à l'ouverture d'un ticket</p>
            <div class="tk-form-row">
              <div class="form-group">
                <label for="spawnNotifChannelId">📣 Salon de notification admin</label>
                <select id="spawnNotifChannelId" name="spawnNotifChannelId" class="form-control">
                  <option value="">-- Aucun --</option>
                  <% channels.forEach(ch => { %>
                    <option value="<%= ch.id %>" <%= (spawnTicket.notifChannelId === ch.id) ? 'selected' : '' %>>
                      <% if (ch.category) { %>[<%= ch.category %>] <% } %># <%= ch.name %>
                    </option>
                  <% }); %>
                </select>
                <p class="help-text">Salon où le bot envoie une alerte dès qu'un joueur ouvre un ticket spawn</p>
              </div>
              <div class="form-group">
                <label for="spawnNotifText">💬 Texte de la notification</label>
                <input type="text" id="spawnNotifText" name="spawnNotifText" class="form-control"
                  value="<%= spawnTicket.notifText || '' %>"
                  placeholder="🐣 Un nouveau joueur vient d'ouvrir un ticket de spawn !">
                <p class="help-text">Le lien direct vers le ticket est ajouté automatiquement après ce texte</p>
              </div>
            </div>

            <p class="tk-section-title" style="margin-top:8px">🖼️ Message automatique à la création du ticket</p>
            <div class="tk-form-row">
              <div class="form-group">
                <label for="spawnAutoMessageText">📝 Texte du message automatique</label>
                <textarea id="spawnAutoMessageText" name="spawnAutoMessageText" class="form-control" rows="4"
                  placeholder="Ex : Bienvenue ! Voici quelques informations sur le serveur…"><%= spawnTicket.autoMessageText || '' %></textarea>
                <p class="help-text">Publié dans le ticket dès sa création (laisse vide pour ne rien envoyer)</p>
              </div>
              <div class="form-group">
                <label>🖼️ Image du message automatique</label>
                <% if (spawnTicket.autoMessageImageUrl) { %>
                <div style="margin-bottom:10px">
                  <img src="<%= spawnTicket.autoMessageImageUrl === 'pgstore' ? '/tickets/spawn/image' : spawnTicket.autoMessageImageUrl %>"
                    alt="Image actuelle"
                    style="max-width:100%;max-height:160px;border-radius:8px;border:1px solid var(--border);display:block">
                  <p class="help-text" style="margin-top:6px">Image actuellement configurée — uploade une nouvelle image pour la remplacer</p>
                </div>
                <% } %>
                <label for="spawnAutoMessageImage" class="file-upload-label">
                  <span class="file-upload-icon">📁</span>
                  <span id="spawnImageFileName"><%= spawnTicket.autoMessageImageUrl ? 'Changer l\'image…' : 'Choisir une image…' %></span>
                </label>
                <input type="file" id="spawnAutoMessageImage" name="spawnAutoMessageImage"
                  accept="image/*" style="display:none"
                  onchange="document.getElementById('spawnImageFileName').textContent = this.files[0]?.name || 'Choisir une image…'">
                <p class="help-text">PNG, JPG, GIF… — affichée en bas de l'embed automatique dans le ticket</p>
              </div>
            </div>

            <p class="tk-section-title" style="margin-top:8px">🔑 Mot de passe in-game</p>
            <div class="tk-form-row">
              <div class="form-group" style="max-width:400px">
                <label for="spawnMapPassword">Mot de passe des maps</label>
                <div style="position:relative">
                  <input type="password" id="spawnMapPassword" name="spawnMapPassword"
                    class="form-control" style="padding-right:44px"
                    value="<%= spawnTicket.mapPassword || '' %>"
                    placeholder="Ex : ArkiFamily2025">
                  <button type="button" onclick="togglePwd()" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-muted);font-size:16px" title="Afficher / masquer">👁️</button>
                </div>
                <p class="help-text">Envoyé en message privé au joueur via le bouton "🔑 Envoyer le mot de passe"</p>
              </div>
            </div>

            <div style="margin-top:8px">
              <button type="submit" class="btn btn-primary">💾 Sauvegarder</button>
            </div>
          </form>
        </div>
      </div>

    </main>
  </div>

  <script>
    // ── Accordéons ────────────────────────────────────────────────────────────
    function tkToggle(id) {
      document.getElementById(id).classList.toggle('open');
    }

    // ── Toggle mot de passe ───────────────────────────────────────────────────
    function togglePwd() {
      const f = document.getElementById('spawnMapPassword');
      f.type = f.type === 'password' ? 'text' : 'password';
    }

    // ── Sélecteur de rôles ────────────────────────────────────────────────────
    function rpToggle(pickerId) {
      const el = document.getElementById(pickerId);
      el.classList.toggle('open');
    }

    function rpUpdate(pickerId) {
      const picker = document.getElementById(pickerId);
      const tagsContainer = picker.querySelector('[id^="rpTags"]');
      const placeholder = picker.querySelector('[id^="rpPlaceholder"]');
      const checked = [...picker.querySelectorAll('input[type=checkbox]:checked')];

      tagsContainer.innerHTML = '';
      checked.forEach(cb => {
        const label = cb.closest('.role-option');
        const name  = label.dataset.roleName;
        const color = label.dataset.roleColor || '#7289da';
        const id    = cb.value;
        const tag   = document.createElement('span');
        tag.className = 'role-tag';
        tag.innerHTML = `<span class="role-tag-dot" style="background:${color}"></span>${name}<button type="button" class="role-tag-remove" onclick="rpRemove('${pickerId}','${id}')">✕</button>`;
        tagsContainer.appendChild(tag);
      });

      placeholder.style.display = checked.length ? 'none' : 'inline';

      picker.querySelectorAll('.role-option').forEach(opt => {
        opt.classList.toggle('checked', opt.querySelector('input').checked);
      });
    }

    function rpRemove(pickerId, roleId) {
      const picker = document.getElementById(pickerId);
      const cb = picker.querySelector(`input[value="${roleId}"]`);
      if (cb) { cb.checked = false; rpUpdate(pickerId); }
    }

    function rpFilter(input, pickerId) {
      const q = input.value.toLowerCase();
      document.getElementById(pickerId).querySelectorAll('.role-option').forEach(opt => {
        opt.style.display = opt.dataset.roleName.toLowerCase().includes(q) ? '' : 'none';
      });
    }

    // Fermer les dropdowns en cliquant en dehors
    document.addEventListener('click', function(e) {
      document.querySelectorAll('.role-picker.open').forEach(picker => {
        if (!picker.contains(e.target)) picker.classList.remove('open');
      });
    });

    // Init : afficher les tags des rôles déjà sélectionnés
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.role-picker').forEach(picker => {
        rpUpdate(picker.id);
      });
    });
  </script>
</body>
</html>
