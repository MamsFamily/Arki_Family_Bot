<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Votes - Arki Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="layout">
    <%- include('sidebar') %>
    <main class="main-content">
      <div class="page-header">
        <h1>📊 Classement des votes</h1>
        <p>Résultats du mois : <%= monthName || 'N/A' %></p>
      </div>

      <% if (error) { %>
        <div class="alert alert-error">❌ <%= error %></div>
      <% } %>

      <div class="card" style="margin-bottom: 20px;">
        <div class="card-header" style="display:flex; align-items:center; justify-content:space-between;">
          <h2 style="margin:0;">🔌 Diagnostic UnbelievaBoat</h2>
          <button id="btn-test-unb" class="btn btn-secondary" onclick="testUnb()">Tester la connexion</button>
        </div>
        <div class="card-body">
          <div id="unb-result" style="font-size:14px; color: var(--text-muted);">Cliquez sur le bouton pour tester la connexion au bot UnbelievaBoat et vérifier que le token est valide.</div>
        </div>
      </div>

      <% if (ranking.length === 0) { %>
        <div class="empty-state">
          <div class="icon">📊</div>
          <p>Aucune donnée de votes disponible</p>
        </div>
      <% } else { %>
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon">🗳️</div>
            <div class="stat-value"><%= ranking.length %></div>
            <div class="stat-label">Votants</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon">📈</div>
            <div class="stat-value"><%= ranking.reduce((s, p) => s + p.votes, 0) %></div>
            <div class="stat-label">Votes totaux</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon">🏆</div>
            <div class="stat-value"><%= ranking[0] ? ranking[0].playername : '-' %></div>
            <div class="stat-label">Premier</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon">💎</div>
            <div class="stat-value"><%= ranking.reduce((s, p) => s + p.votes * votesConfig.DIAMONDS_PER_VOTE, 0).toLocaleString('fr-FR') %></div>
            <div class="stat-label">Diamants à distribuer</div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h2>Classement</h2>
            <span style="color: var(--text-muted); font-size: 13px;">Top <%= Math.min(ranking.length, 30) %></span>
          </div>
          <div class="card-body" style="padding: 0;">
            <table class="votes-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Joueur</th>
                  <th>Votes</th>
                  <th>Gains</th>
                  <th>Bonus</th>
                </tr>
              </thead>
              <tbody>
                <% ranking.slice(0, 30).forEach((p, i) => {
                  const diamonds = p.votes * votesConfig.DIAMONDS_PER_VOTE;
                  const bonus = votesConfig.TOP_DIAMONDS[i + 1] || 0;
                  const total = diamonds + bonus;
                  const rankClass = i === 0 ? 'rank-1' : i === 1 ? 'rank-2' : i === 2 ? 'rank-3' : '';
                %>
                  <tr>
                    <td class="rank <%= rankClass %>"><%= i + 1 %></td>
                    <td class="player-name">
                      <%= p.playername %>
                      <% if (i === 0) { %><span class="badge badge-gold">🥇 1er</span><% } %>
                      <% if (i === 1) { %><span class="badge badge-silver">🥈 2ème</span><% } %>
                      <% if (i === 2) { %><span class="badge badge-bronze">🥉 3ème</span><% } %>
                    </td>
                    <td><%= p.votes %></td>
                    <td class="diamonds">💎 <%= total.toLocaleString('fr-FR') %></td>
                    <td>
                      <% if (bonus > 0) { %>
                        + <%= bonus.toLocaleString('fr-FR') %> bonus
                      <% } else if (i < 3) { %>
                        Pack vote
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>
    </main>
  </div>
  <script>
    async function testUnb() {
      const btn = document.getElementById('btn-test-unb');
      const result = document.getElementById('unb-result');
      btn.disabled = true;
      btn.textContent = 'Test en cours…';
      result.style.color = 'var(--text-muted)';
      result.textContent = '⏳ Connexion à UnbelievaBoat en cours…';
      try {
        const res = await fetch('/votes/test-unb');
        const data = await res.json();
        if (data.success) {
          result.style.color = 'var(--success)';
          result.innerHTML = `✅ <strong>Connexion réussie !</strong> Serveur : <strong>${data.guildName}</strong> — Monnaie : <strong>${data.currency}</strong>`;
        } else {
          result.style.color = 'var(--danger)';
          result.innerHTML = `❌ <strong>Échec de connexion :</strong> <code>${data.error}</code><br><small>Vérifiez que UNBELIEVABOAT_TOKEN est correct dans les variables d'environnement Railway.</small>`;
        }
      } catch (e) {
        result.style.color = 'var(--danger)';
        result.textContent = '❌ Erreur réseau : ' + e.message;
      }
      btn.disabled = false;
      btn.textContent = 'Tester la connexion';
    }
  </script>
</body>
</html>
